#!/usr/bin/env php
<?php
declare(strict_types=1);

/**
 * PHP-native launcher.
 *
 * The default path stays entirely in PHP. The upstream Schemathesis bridge is
 * kept as an explicit compatibility command while this project closes parity
 * gaps natively:
 *
 *   php bin/openapi-contract run ...
 *   php bin/openapi-contract schemathesis run ...
 */

main($argv);

function main(array $argv): void {
    $args = array_slice($argv, 1);
    if (!$args || in_array($args[0], ['-h', '--help'], true)) {
        printUsage();
        exit(0);
    }

    if (($args[0] ?? '') === 'schemathesis' || getenv('OPENAPI_CONTRACT_SCHEMATHESIS') === '1') {
        if (($args[0] ?? '') === 'schemathesis') array_shift($args);
        exit(runSchemathesis($args));
    }

    if (($args[0] ?? '') === 'native') {
        if (($args[0] ?? '') === 'native') array_shift($args);
    }

    exit(runNative($args));
}

function runSchemathesis(array $args): int {
    $binary = findSchemathesisBinary();
    if ($binary === null) {
        fwrite(STDERR, "Could not find Schemathesis.\n\n");
        fwrite(STDERR, "Install it, then rerun this command:\n");
        fwrite(STDERR, "  pipx install schemathesis\n");
        fwrite(STDERR, "or:\n");
        fwrite(STDERR, "  python3 -m pip install schemathesis\n\n");
        fwrite(STDERR, "You can also set OPENAPI_CONTRACT_SCHEMATHESIS_BIN=/path/to/schemathesis.\n");
        return 2;
    }

    return runCommand(array_merge([$binary], $args));
}

function printUsage(): void {
    echo "openapi-contract-php\n";
    echo "\n";
    echo "Usage:\n";
    echo "  php bin/openapi-contract run [OPTIONS] LOCATION\n";
    echo "  php bin/openapi-contract native run [OPTIONS] LOCATION\n";
    echo "  php bin/openapi-contract schemathesis [SCHEMATHESIS OPTIONS]\n";
    echo "\n";
    echo "Default mode runs the PHP-native implementation.\n";
    echo "Use the schemathesis command only when comparing behavior with upstream.\n";
    echo "Set OPENAPI_CONTRACT_SCHEMATHESIS_BIN to choose a specific upstream binary.\n";
}

function findSchemathesisBinary(): ?string {
    $configured = getenv('OPENAPI_CONTRACT_SCHEMATHESIS_BIN');
    if (is_string($configured) && trim($configured) !== '') {
        $configured = trim($configured);
        return isExecutableCommand($configured) ? $configured : null;
    }

    foreach (['schemathesis', 'st'] as $candidate) {
        $resolved = which($candidate);
        if ($resolved !== null) return $resolved;
    }
    return null;
}

function isExecutableCommand(string $command): bool {
    if (str_contains($command, DIRECTORY_SEPARATOR)) {
        return is_file($command) && is_executable($command);
    }
    return which($command) !== null;
}

function which(string $command): ?string {
    $path = getenv('PATH') ?: '';
    foreach (explode(PATH_SEPARATOR, $path) as $directory) {
        if ($directory === '') continue;
        $candidate = rtrim($directory, DIRECTORY_SEPARATOR) . DIRECTORY_SEPARATOR . $command;
        if (is_file($candidate) && is_executable($candidate)) return $candidate;
    }
    return null;
}

function runNative(array $args): int {
    $native = __DIR__ . DIRECTORY_SEPARATOR . 'openapi-contract-native';
    if (!is_file($native)) {
        fwrite(STDERR, "PHP-native runner not found at {$native}\n");
        return 2;
    }
    return runCommand(array_merge([$native], $args));
}

function runCommand(array $command): int {
    $descriptorSpec = [
        0 => STDIN,
        1 => STDOUT,
        2 => STDERR
    ];
    $process = proc_open($command, $descriptorSpec, $pipes, null, null, ['bypass_shell' => true]);
    if (!is_resource($process)) {
        fwrite(STDERR, "Could not start command: " . implode(' ', $command) . "\n");
        return 2;
    }
    $status = proc_close($process);
    return is_int($status) ? $status : 1;
}
