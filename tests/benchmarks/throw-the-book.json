            "schema": "tests/fixtures/random-openapi/broken-header.json",
            "url": "{base_url}",
            "options": {
                "phases": "examples",
                "checks": "response_headers_conformance",
                "max-failures": 1
            },
            "expected_exit_code": 1,
            "expected_failures": 1
        },
        {
            "name": "broken-ignored-auth",
            "command": "run",
            "schema": "tests/fixtures/random-openapi/broken-auth.json",
            "url": "{base_url}",
            "options": {
                "phases": "coverage",
                "checks": "ignored_auth",
                "auth-api-key": "ApiKeyAuth:secret",
                "max-failures": 1
            },
            "expected_exit_code": 1,
            "expected_failures": 1
        },
        {
            "name": "broken-negative-rejection",
            "command": "fuzz",
            "schema": "tests/fixtures/random-openapi/broken-negative-rejection.json",
            "url": "{base_url}",
            "options": {
                "mode": "negative",
