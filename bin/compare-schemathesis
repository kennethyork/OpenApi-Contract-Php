#!/usr/bin/env php
<?php
declare(strict_types=1);

/**
 * Run this PHP CLI and upstream Schemathesis with the same shared options.
 *
 * This file is only for parity checks. The product CLI remains
 * `bin/openapi-contract` and does not delegate to Schemathesis.
 */

main($argv);

function main(array $argv): void {
    if (!isset($argv[1]) || in_array($argv[1], ['-h', '--help'], true)) {
        printUsage();
        exit(0);
    }

    try {
        $parsed = parseCli($argv);
    } catch (InvalidArgumentException $e) {
        fwrite(STDERR, $e->getMessage() . "\n\n");
        printUsage();
        exit(2);
    }

    $schemathesis = findSchemathesisCommand($parsed['schemathesis_bin']);
    if ($schemathesis === null) {
        fwrite(STDERR, "Could not find Schemathesis or uvx.\n\n");
        fwrite(STDERR, "Install Schemathesis with:\n");
        fwrite(STDERR, "  pipx install schemathesis\n");
        fwrite(STDERR, "or install uv and rerun this helper.\n");
        fwrite(STDERR, "You can also pass --schemathesis-bin /path/to/schemathesis.\n");
        exit(2);
    }

    $location = $parsed['location'];
    $options = $parsed['options'];
    $phpCli = __DIR__ . DIRECTORY_SEPARATOR . 'openapi-contract';

    $phpCommand = array_merge([PHP_BINARY, $phpCli, 'run'], $options, [$location]);
    $schemathesisCommand = array_merge($schemathesis, ['run'], $options, [$location]);

    $phpStatus = runCommand('openapi-contract-php', $phpCommand);
    $schemathesisStatus = runCommand('schemathesis', $schemathesisCommand);

    echo "\n=================================== COMPARE ====================================\n";
    echo "openapi-contract-php exit code: {$phpStatus}\n";
    echo "schemathesis exit code:        {$schemathesisStatus}\n";

    exit($phpStatus === $schemathesisStatus ? 0 : 1);
}

function printUsage(): void {
    echo "Usage: php bin/compare-schemathesis [OPTIONS] LOCATION\n\n";
    echo "Runs both:\n";
    echo "  php bin/openapi-contract run [OPTIONS] LOCATION\n";
    echo "  schemathesis run [OPTIONS] LOCATION\n\n";
    echo "Comparison helper options:\n";
    echo "  --schemathesis-bin PATH        Use a specific schemathesis/st executable\n\n";
    echo "Shared options are passed to both commands. Useful shared options:\n";
    echo "  -u, --url URL\n";
    echo "  -H, --header NAME:VALUE\n";
    echo "  --phases examples,coverage,fuzzing\n";
    echo "  --checks LIST\n";
    echo "  --exclude-checks LIST\n";
    echo "  -n, --max-examples N\n";
    echo "  --max-failures N\n";
    echo "  --seed N\n";
    echo "  --no-color\n";
}

function parseCli(array $argv): array {
    $location = null;
    $options = [];
    $schemathesisBin = null;
    $count = count($argv);

    for ($i = 1; $i < $count; $i++) {
        $arg = $argv[$i];

        if ($arg === '--schemathesis-bin') {
            $schemathesisBin = requireValue($argv, ++$i, '--schemathesis-bin');
            continue;
        }
        if (str_starts_with($arg, '--schemathesis-bin=')) {
            $schemathesisBin = substr($arg, strlen('--schemathesis-bin='));
            continue;
        }
        if (str_starts_with($arg, '-')) {
            $options[] = $arg;
            if (optionConsumesValue($arg)) {
                $options[] = requireValue($argv, ++$i, $arg);
            }
            continue;
        }
        if ($location !== null) {
            throw new InvalidArgumentException("Unexpected extra location: {$arg}");
        }
        $location = $arg;
    }

    if ($location === null) {
        throw new InvalidArgumentException('Missing LOCATION.');
    }

    return [
        'location' => $location,
        'options' => $options,
        'schemathesis_bin' => $schemathesisBin
    ];
}

function optionConsumesValue(string $option): bool {
    if (str_contains($option, '=')) return false;
    return in_array($option, [
        '-u',
        '--url',
        '-H',
        '--header',
        '-n',
        '--max-examples',
        '-a',
        '--auth',
        '--phases',
        '--checks',
        '--exclude-checks',
        '--max-failures',
        '--request-timeout',
        '--seed'
    ], true);
}

function requireValue(array $argv, int $index, string $option): string {
    if (!isset($argv[$index]) || $argv[$index] === '') {
        throw new InvalidArgumentException("Missing value for {$option}.");
    }
    return $argv[$index];
}

function findSchemathesisCommand(?string $configured): ?array {
    if ($configured !== null && trim($configured) !== '') {
        $parts = preg_split('/\s+/', trim($configured)) ?: [];
        if ($parts && isExecutableCommand($parts[0])) return $parts;
        return null;
    }

    $env = getenv('OPENAPI_CONTRACT_SCHEMATHESIS_BIN');
    if (is_string($env) && trim($env) !== '') {
        $parts = preg_split('/\s+/', trim($env)) ?: [];
        if ($parts && isExecutableCommand($parts[0])) return $parts;
        return null;
    }

    foreach (['schemathesis', 'st'] as $candidate) {
        if (isExecutableCommand($candidate)) return [$candidate];
    }

    return isExecutableCommand('uvx') ? ['uvx', 'schemathesis'] : null;
}

function isExecutableCommand(string $command): bool {
    if (str_contains($command, DIRECTORY_SEPARATOR)) {
        return is_file($command) && is_executable($command);
    }
    return which($command) !== null;
}

function which(string $command): ?string {
    $path = getenv('PATH') ?: '';
    foreach (explode(PATH_SEPARATOR, $path) as $directory) {
        if ($directory === '') continue;
        $candidate = rtrim($directory, DIRECTORY_SEPARATOR) . DIRECTORY_SEPARATOR . $command;
        if (is_file($candidate) && is_executable($candidate)) return $candidate;
    }
    return null;
}

function runCommand(string $label, array $command): int {
    echo "\n=================================== {$label} ===================================\n";
    echo commandToString($command) . "\n\n";

    $process = proc_open(
        $command,
        [0 => STDIN, 1 => STDOUT, 2 => STDERR],
        $pipes,
        null,
        null,
        ['bypass_shell' => true]
    );
    if (!is_resource($process)) {
        fwrite(STDERR, "Could not start {$label}.\n");
        return 2;
    }

    $status = proc_close($process);
    return is_int($status) ? $status : 1;
}

function commandToString(array $command): string {
    return implode(' ', array_map('shellQuote', $command));
}

function shellQuote(string $value): string {
    if ($value !== '' && preg_match('/^[A-Za-z0-9_\/.=:,@+-]+$/', $value)) {
        return $value;
    }
    return "'" . str_replace("'", "'\\''", $value) . "'";
}
