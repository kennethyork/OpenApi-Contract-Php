#!/usr/bin/env php
<?php
declare(strict_types=1);

/**
 * PHP-native OpenAPI contract and fuzz testing runner.
 *
 * The CLI is designed for local OpenAPI contract and fuzz testing:
 *
 *   php bin/openapi-contract run LOCATION --phases examples,coverage,fuzzing --max-examples 5
 *
 * It supports core OpenAPI HTTP checks:
 * - not_a_server_error
 * - status_code_conformance
 * - content_type_conformance
 * - response_headers_conformance
 * - response_schema_conformance
 * - unsupported_method
 *
 * Full feature coverage still requires a property-based testing engine,
 * shrinking, link-aware stateful workflows, GraphQL support, and a much larger
 * OpenAPI implementation.
 */

const DEFAULT_CHECKS = [
    'not_a_server_error',
    'status_code_conformance',
    'content_type_conformance',
    'response_headers_conformance',
    'response_schema_conformance',
    'unsupported_method'
];

const KNOWN_CHECKS = [
    'not_a_server_error',
    'status_code_conformance',
    'content_type_conformance',
    'response_headers_conformance',
    'response_schema_conformance',
    'negative_data_rejection',
    'positive_data_acceptance',
    'use_after_free',
    'ensure_resource_availability',
    'ignored_auth',
    'missing_required_header',
    'unsupported_method'
];

const IMPLEMENTED_CHECKS = [
    'not_a_server_error',
    'status_code_conformance',
    'content_type_conformance',
    'response_headers_conformance',
    'response_schema_conformance',
    'negative_data_rejection',
    'positive_data_acceptance',
    'unsupported_method'
];
const HTTP_OPERATION_METHODS = ['get', 'post', 'put', 'patch', 'delete'];
const DEFAULT_CACHE_DIR = '.openapi-contract/cache';
const DEFAULT_REPORT_DIR = 'openapi-contract-report';

main($argv);

function main(array $argv): void {
    if (!isset($argv[1]) || in_array($argv[1], ['-h', '--help'], true)) {
        printUsage();
        exit(0);
    }

    $parsed = parseCli($argv);
    $command = $parsed['command'] ?? null;

    if ($command === 'init') {
        exit(runInitCommand($parsed['location'], $parsed['options']));
    }

    if ($command === 'interactive') {
        exit(runInteractiveCommand($parsed['location'], $parsed['options']));
    }

    $options = mergeConfigOptions($parsed['options']);
    if ($command === 'doctor') {
        exit(runDoctorCommand($parsed['location'], $options));
    }

    if ($command === 'replay') {
        exit(runReplayCommand($parsed['location'], $options));
    }

    exit(runTestCommand((string)$command, $parsed['location'], $options));
}

function runTestCommand(string $command, ?string $providedLocation, array $options): int {
    if (!in_array($command, ['run', 'fuzz'], true)) {
        printUsage();
        return 2;
    }

    $location = schemaLocationFromOptions($providedLocation, $options);
    if ($location === null) {
        fwrite(STDERR, "No OpenAPI schema location provided. Pass LOCATION or set schema-location in config.\n");
        return 2;
    }

    $phases = $command === 'fuzz' ? ['fuzzing'] : csvOption($options, 'phases', ['examples', 'coverage', 'fuzzing']);
    $maxTime = isset($options['max-time']) ? max(1.0, (float)$options['max-time']) : null;
    $maxExamplesDefault = $command === 'fuzz' ? ($maxTime === null ? 100 : PHP_INT_MAX) : 5;
    $maxExamples = max(1, (int)($options['max-examples'] ?? $maxExamplesDefault));
    $maxFailures = isset($options['max-failures']) ? max(1, (int)$options['max-failures']) : null;
    $mode = in_array(($options['mode'] ?? 'positive'), ['positive', 'negative', 'all'], true) ? (string)($options['mode'] ?? 'positive') : 'positive';
    $timeout = isset($options['request-timeout']) ? max(1.0, (float)$options['request-timeout']) : 10.0;
    $headers = headersFromOptions($options);
    $checks = selectedChecks($options);
    $seed = isset($options['seed']) ? (int)$options['seed'] : random_int(1, PHP_INT_MAX);
    $transport = transportOptionsFromOptions($options);
    mt_srand($seed);

    echo "openapi-contract-php v0.1\n";
    echo str_repeat("-", 20) . "\n\n";

    try {
        $schema = loadSchema($location, $timeout, isset($options['wait-for-schema']) ? (float)$options['wait-for-schema'] : 0.0, $transport);
        $baseUrl = baseUrlFromSchema($schema, $options['url'] ?? null);
    } catch (Throwable $e) {
        echo " FAIL Could not load specification: {$e->getMessage()}\n";
        return 1;
    }

    $warnings = [];
    addCompatibilityWarnings($options, $phases, $checks, $command, $schema, $warnings);
    $allOperations = collectOperations($schema);
    $operations = filterOperations($allOperations, $options, $warnings);
    echo " OK   Loaded specification from {$location}\n\n";
    echo "     Base URL:         {$baseUrl}\n";
    echo "     Specification:    OpenAPI " . ($schema['openapi'] ?? 'unknown') . "\n";
    echo "     Operations:       " . count($operations) . " selected / " . count($allOperations) . " total\n";
    echo "     Seed:             {$seed}\n\n";

    $state = [
        'schema' => $schema,
        'components' => $schema['components'] ?? [],
        'base_url' => $baseUrl,
        'headers' => $headers,
        'checks' => $checks,
        'timeout' => $timeout,
        'transport' => $transport,
        'max_response_time' => isset($options['max-response-time']) ? max(PHP_FLOAT_EPSILON, (float)$options['max-response-time']) : null,
        'mode' => $mode,
        'max_failures' => $maxFailures,
        'failures' => [],
        'warnings' => $warnings,
        'cases' => 0,
        'case_records' => [],
        'total_operations' => count($allOperations),
        'seed' => $seed,
        'last_request_at' => null,
        'schema_location' => $location,
        'report' => reportOptionsFromOptions($options),
        'cache_dir' => (string)($options['cache-dir'] ?? DEFAULT_CACHE_DIR)
    ];

    $phaseResults = [];
    $deadline = $maxTime === null ? null : microtime(true) + $maxTime;
    foreach ($phases as $phase) {
        if (failureLimitReached($state)) break;
        if ($deadline !== null && microtime(true) >= $deadline) break;
        $started = microtime(true);
        $result = match ($phase) {
            'examples' => runExamplesPhase($operations, $state),
            'coverage' => runCoveragePhase($operations, $state),
            'fuzzing' => runFuzzingPhase($operations, $state, $maxExamples, $deadline),
            'stateful' => runStatefulPhase($operations, $state, $maxExamples, $deadline),
            default => ['passed' => 0, 'failed' => 0, 'skipped' => count($operations), 'label' => ucfirst($phase), 'unsupported' => true]
        };
        $result['duration'] = microtime(true) - $started;
        $phaseResults[$phase] = $result;
        printPhaseResult($phase, $result);
    }

    printFailures($state);
    printWarnings($state);
    printSummary($operations, $phaseResults, $state);
    writeReports($state, $phaseResults);
    return $state['failures'] ? 1 : 0;
}

function printUsage(): void {
    echo "Usage:\n";
    echo "  php bin/openapi-contract init [OPTIONS] [LOCATION]\n";
    echo "  php bin/openapi-contract interactive [OPTIONS] [LOCATION]\n";
    echo "  php bin/openapi-contract doctor [OPTIONS] [LOCATION]\n";
    echo "  php bin/openapi-contract run [OPTIONS] [LOCATION]\n";
    echo "  php bin/openapi-contract fuzz [OPTIONS] [LOCATION]\n";
    echo "  php bin/openapi-contract replay [OPTIONS] [PATH|CASE_ID]\n\n";
    echo "Options:\n";
    echo "  --config FILE                  Load JSON config defaults, or init target file\n";
    echo "  --schema-location LOCATION     OpenAPI schema location for config-backed runs\n";
    echo "  -u, --url URL                  API base URL for file-based schemas\n";
    echo "  -w, --workers N|auto           Worker count (currently sequential)\n";
    echo "  -H, --header NAME:VALUE        Add a custom HTTP header\n";
    echo "  -a, --auth USER:PASS           Basic authentication\n";
    echo "  --phases LIST                  examples,coverage,fuzzing,stateful\n";
    echo "  --checks LIST                  Checks to run, or all\n";
    echo "  --exclude-checks LIST          Checks to skip\n";
    echo "  --max-response-time SECONDS    Fail responses slower than this limit\n";
    echo "  --include-TYPE VALUE           TYPE: path, method, tag, operation-id\n";
    echo "  --exclude-TYPE VALUE           TYPE: path, method, tag, operation-id\n";
    echo "  --include-TYPE-regex PATTERN   Regex include filter\n";
    echo "  --exclude-TYPE-regex PATTERN   Regex exclude filter\n";
    echo "  --exclude-deprecated           Skip deprecated operations\n";
    echo "  -n, --max-examples N           Fuzz examples per operation\n";
    echo "  --max-failures N               Stop after N failures\n";
    echo "  --max-time SECONDS             Stop fuzz command after this duration\n";
    echo "  --request-timeout SECONDS      Per-request timeout\n";
    echo "  --request-retries N            Retry network failures\n";
    echo "  --max-redirects N              Follow up to N redirects\n";
    echo "  --proxy URL                    HTTP proxy URL\n";
    echo "  --tls-verify true|false|PATH   TLS verification setting\n";
    echo "  --report FORMAT                junit,har,ndjson,vcr\n";
    echo "  --report-dir DIRECTORY         Directory for generated reports\n";
    echo "  --report-junit-path FILE       JUnit XML output path\n";
    echo "  --report-har-path FILE         HAR output path\n";
    echo "  --report-ndjson-path FILE      NDJSON events output path\n";
    echo "  --report-vcr-path FILE         Request/response cassette path\n";
    echo "  --cache-dir DIRECTORY          Crash/replay cache directory\n";
    echo "  --seed N                       Reproducible random seed\n";
    echo "  --no-interaction               Write init defaults without prompting\n";
    echo "  --force                        Allow init to overwrite an existing config\n";
    echo "  --no-color                     Accepted for CLI compatibility\n";
}

function runInitCommand(?string $target, array $options): int {
    $interactive = !truthyOption($options['no-interaction'] ?? false);
    $configPath = optionString($options, 'config', 'openapi-contract.json');
    $schemaLocation = optionString($options, 'schema-location', $target ?? 'openapi.json');
    $baseUrl = optionString($options, 'url', guessBaseUrl($schemaLocation));
    $phases = optionString($options, 'phases', 'examples,coverage,fuzzing');
    $checks = optionString($options, 'checks', '');
    $maxExamples = optionString($options, 'max-examples', '25');
    $requestTimeout = optionString($options, 'request-timeout', '10');
    $requestRetries = optionString($options, 'request-retries', '0');
    $maxRedirects = optionString($options, 'max-redirects', '0');
    $auth = optionString($options, 'auth', '');
    $headers = optionValues($options, 'header');
    $reports = csvOption($options, 'report', ['ndjson', 'junit']);
    $reportDir = optionString($options, 'report-dir', DEFAULT_REPORT_DIR);
    $cacheDir = optionString($options, 'cache-dir', DEFAULT_CACHE_DIR);

    if ($interactive) {
        echo "openapi-contract-php init\n";
        echo str_repeat("-", 25) . "\n\n";
        if (!truthyOption($options['fixed-config'] ?? false)) {
            $configPath = promptText('Config file', $configPath);
        }
        $schemaLocation = promptText('OpenAPI schema location', $schemaLocation);
        $guessedUrl = $baseUrl !== '' ? $baseUrl : guessBaseUrl($schemaLocation);
        $baseUrl = promptText('API base URL', $guessedUrl);
        $phases = promptText('Phases', $phases);
        $checks = promptText('Checks, empty for default', $checks);
        $maxExamples = promptText('Max fuzz examples per operation', $maxExamples);
        $requestTimeout = promptText('Request timeout seconds', $requestTimeout);
        $requestRetries = promptText('Request retries', $requestRetries);
        $maxRedirects = promptText('Max redirects', $maxRedirects);
        $auth = promptText('Basic auth USER:PASS, empty for none', $auth);
        $headerText = promptText('Extra headers, comma-separated NAME: VALUE', implode(', ', $headers));
        $headers = parseHeaderInput($headerText);
        $reportText = promptText('Reports, comma-separated or none', implode(',', $reports));
        $reports = csvList($reportText);
        $reportDir = promptText('Report directory', $reportDir);
        $cacheDir = promptText('Crash/replay cache directory', $cacheDir);
    }

    if (trim($schemaLocation) === '') {
        fwrite(STDERR, "Schema location is required.\n");
        return 2;
    }

    if (is_file($configPath) && !truthyOption($options['force'] ?? false)) {
        if (!$interactive || !promptYesNo("Overwrite existing {$configPath}?", false)) {
            fwrite(STDERR, "Config file already exists: {$configPath}\n");
            return 2;
        }
    }

    $config = [
        'schema-location' => $schemaLocation,
        'phases' => $phases,
        'max-examples' => max(1, (int)$maxExamples),
        'request-timeout' => max(1.0, (float)$requestTimeout),
        'request-retries' => max(0, (int)$requestRetries),
        'max-redirects' => max(0, (int)$maxRedirects),
        'cache-dir' => $cacheDir
    ];

    if (trim($baseUrl) !== '') $config['url'] = trim($baseUrl);
    if (trim($checks) !== '') $config['checks'] = trim($checks);
    if ($headers) $config['headers'] = array_values($headers);
    if (trim($auth) !== '') {
        [$username, $password] = array_pad(explode(':', $auth, 2), 2, '');
        $config['auth'] = ['basic' => ['username' => $username, 'password' => $password]];
    }
    $reports = array_values(array_intersect($reports, ['junit', 'har', 'ndjson', 'vcr']));
    if ($reports) {
        $config['reports'] = ['directory' => $reportDir];
        foreach ($reports as $format) {
            $config['reports'][$format] = ['enabled' => true];
        }
    }

    $dir = dirname($configPath);
    if ($dir !== '.' && !is_dir($dir) && !mkdir($dir, 0777, true) && !is_dir($dir)) {
        fwrite(STDERR, "Could not create config directory: {$dir}\n");
        return 1;
    }

    $json = json_encode($config, JSON_PRETTY_PRINT | JSON_UNESCAPED_SLASHES);
    if ($json === false || file_put_contents($configPath, $json . "\n") === false) {
        fwrite(STDERR, "Could not write config file: {$configPath}\n");
        return 1;
    }

    echo "Wrote {$configPath}\n";
    echo "Run: php bin/openapi-contract doctor --config {$configPath}\n";
    echo "Run: php bin/openapi-contract run --config {$configPath}\n";
    return 0;
}

function runInteractiveCommand(?string $target, array $options): int {
    echo "openapi-contract-php interactive\n";
    echo str_repeat("-", 32) . "\n\n";

    $configPath = optionString($options, 'config', defaultConfigPath());
    $configPath = promptText('Config file', $configPath);
    $options['config'] = $configPath;

    if (!is_file($configPath)) {
        echo "\nNo config file found at {$configPath}.\n";
        if (promptYesNo('Create it now?', true)) {
            $initOptions = $options;
            $initOptions['fixed-config'] = true;
            $initCode = runInitCommand($target, $initOptions);
            if ($initCode !== 0) return $initCode;
        } else {
            unset($options['config']);
        }
    } elseif (promptYesNo('Update config now?', false)) {
        $initOptions = $options;
        $initOptions['fixed-config'] = true;
        $initCode = runInitCommand($target, $initOptions);
        if ($initCode !== 0) return $initCode;
    }

    $lastExitCode = 0;
    while (true) {
        echo "\nActions:\n";
        echo "  1. Doctor\n";
        echo "  2. Run\n";
        echo "  3. Fuzz\n";
        echo "  4. Replay\n";
        echo "  5. Init\n";
        echo "  6. Quit\n";
        $choice = strtolower(promptText('Choose action', '2'));

        if (in_array($choice, ['6', 'q', 'quit', 'exit'], true)) {
            return $lastExitCode;
        }

        try {
            $mergedOptions = mergeConfigOptions($options);
        } catch (Throwable $e) {
            fwrite(STDERR, "Could not load config: {$e->getMessage()}\n");
            return 2;
        }

        switch ($choice) {
            case '1':
            case 'doctor':
                $doctorLocation = schemaLocationFromOptions($target, $mergedOptions);
                $doctorLocation = promptText('OpenAPI schema location', $doctorLocation ?? '');
                $lastExitCode = runDoctorCommand($doctorLocation, promptUrlOption($mergedOptions, $doctorLocation));
                break;

            case '2':
            case 'run':
                $runLocation = schemaLocationFromOptions($target, $mergedOptions);
                $runOptions = promptRunOptions($mergedOptions, 'run', $runLocation);
                $lastExitCode = runTestCommand('run', $runLocation, $runOptions);
                break;

            case '3':
            case 'fuzz':
                $fuzzLocation = schemaLocationFromOptions($target, $mergedOptions);
                $fuzzOptions = promptRunOptions($mergedOptions, 'fuzz', $fuzzLocation);
                $lastExitCode = runTestCommand('fuzz', $fuzzLocation, $fuzzOptions);
                break;

            case '4':
            case 'replay':
                $replayTarget = promptText('Crash path or case id, empty for all', '');
                $lastExitCode = runReplayCommand($replayTarget === '' ? null : $replayTarget, $mergedOptions);
                break;

            case '5':
            case 'init':
                $initOptions = $options;
                $initOptions['fixed-config'] = isset($options['config']);
                $lastExitCode = runInitCommand($target, $initOptions);
                break;

            default:
                echo "Unknown action: {$choice}\n";
                $lastExitCode = 2;
                break;
        }

        if (!promptYesNo('Choose another action?', false)) return $lastExitCode;
    }
}

function defaultConfigPath(): string {
    foreach (['openapi-contract.json', '.openapi-contract.json'] as $candidate) {
        if (is_file($candidate)) return $candidate;
    }
    return 'openapi-contract.json';
}

function promptUrlOption(array $options, ?string $location): array {
    $defaultUrl = optionString($options, 'url', $location === null ? '' : guessBaseUrl($location));
    $url = promptText('API base URL', $defaultUrl);
    if ($url !== '') $options['url'] = $url;
    return $options;
}

function promptRunOptions(array $options, string $command, ?string &$location): array {
    $location = promptText('OpenAPI schema location', $location ?? 'openapi.json');
    $options = promptUrlOption($options, $location);

    if ($command === 'run') {
        $options['phases'] = promptText('Phases', optionString($options, 'phases', 'examples,coverage,fuzzing'));
    } else {
        $mode = promptText('Mode', optionString($options, 'mode', 'positive'));
        $options['mode'] = in_array($mode, ['positive', 'negative', 'all'], true) ? $mode : 'positive';
    }

    $defaultExamples = $command === 'fuzz' ? '100' : '5';
    $options['max-examples'] = promptText('Max examples per operation', optionString($options, 'max-examples', $defaultExamples));
    $reports = promptText('Reports, comma-separated or none', implode(',', csvOption($options, 'report', [])));
    if ($reports === '') unset($options['report']);
    else $options['report'] = csvList($reports);
    return $options;
}

function runDoctorCommand(?string $target, array $options): int {
    $failures = 0;
    $warnings = [];
    $timeout = isset($options['request-timeout']) ? max(1.0, (float)$options['request-timeout']) : 10.0;
    $transport = transportOptionsFromOptions($options);
    $location = schemaLocationFromOptions($target, $options);

    echo "openapi-contract-php doctor\n";
    echo str_repeat("-", 27) . "\n\n";

    if (PHP_VERSION_ID >= 80200) {
        doctorLine('OK', 'PHP', PHP_VERSION);
    } else {
        doctorLine('FAIL', 'PHP', 'PHP 8.2 or newer is required; current version is ' . PHP_VERSION);
        $failures++;
    }

    foreach (['json', 'curl'] as $extension) {
        if (extension_loaded($extension)) {
            doctorLine('OK', "Extension {$extension}", 'loaded');
        } else {
            doctorLine('FAIL', "Extension {$extension}", 'missing');
            $failures++;
        }
    }

    if (isset($options['config'])) {
        doctorLine('OK', 'Config', (string)$options['config']);
    } else {
        doctorLine('WARN', 'Config', 'no config file loaded');
        $warnings[] = 'No config file was found; run init to create one.';
    }

    if ($location === null) {
        doctorLine('FAIL', 'Schema', 'no location provided');
        $failures++;
    } else {
        $isYaml = (bool)preg_match('/\.(ya?ml)$/i', parse_url($location, PHP_URL_PATH) ?? $location);
        if ($isYaml && !function_exists('yaml_parse')) {
            doctorLine('WARN', 'YAML parser', 'php-yaml is not loaded; using the built-in limited YAML parser');
            $warnings[] = 'Complex YAML features may require the php-yaml extension.';
        }

        try {
            $schema = loadSchema($location, $timeout, isset($options['wait-for-schema']) ? (float)$options['wait-for-schema'] : 0.0, $transport);
            doctorLine('OK', 'Schema', $location);
            doctorLine('OK', 'OpenAPI', (string)($schema['openapi'] ?? 'unknown'));

            $baseUrl = baseUrlFromSchema($schema, $options['url'] ?? null);
            if (preg_match('#^https?://#', $baseUrl)) {
                doctorLine('OK', 'Base URL', $baseUrl);
            } else {
                doctorLine('FAIL', 'Base URL', "{$baseUrl} is not an absolute HTTP URL");
                $failures++;
            }

            $allOperations = collectOperations($schema);
            $selectedOperations = filterOperations($allOperations, $options, $warnings);
            if ($selectedOperations) {
                doctorLine('OK', 'Operations', count($selectedOperations) . ' selected / ' . count($allOperations) . ' total');
            } else {
                doctorLine('FAIL', 'Operations', 'no operations selected');
                $failures++;
            }

            $phases = csvOption($options, 'phases', ['examples', 'coverage', 'fuzzing']);
            $checks = selectedChecks($options);
            addCompatibilityWarnings($options, $phases, $checks, 'run', $schema, $warnings);
            doctorLine('OK', 'Phases', implode(',', $phases));
            doctorLine('OK', 'Checks', implode(',', $checks));

            $report = reportOptionsFromOptions($options);
            doctorLine('OK', 'Reports', ($report['formats'] ?? []) ? implode(',', $report['formats']) : 'disabled');
            doctorLine('OK', 'Cache', (string)($options['cache-dir'] ?? DEFAULT_CACHE_DIR));
        } catch (Throwable $e) {
            doctorLine('FAIL', 'Schema', $e->getMessage());
            $failures++;
        }
    }

    foreach (array_values(array_unique($warnings)) as $warning) {
        doctorLine('WARN', 'Note', $warning);
    }

    echo "\n";
    echo $failures ? "Doctor found {$failures} blocking issue(s).\n" : "Doctor found no blocking issues.\n";
    return $failures ? 1 : 0;
}

function schemaLocationFromOptions(?string $location, array $options): ?string {
    foreach ([$location, $options['schema-location'] ?? null, $options['schema'] ?? null, $options['location'] ?? null] as $candidate) {
        if ($candidate === null || $candidate === true) continue;
        $value = trim((string)$candidate);
        if ($value !== '') return $value;
    }
    return null;
}

function optionString(array $options, string $name, string $default = ''): string {
    if (!array_key_exists($name, $options) || $options[$name] === true || $options[$name] === null) return $default;
    $value = $options[$name];
    if (is_array($value)) return implode(',', array_map('strval', $value));
    return trim((string)$value);
}

function truthyOption($value): bool {
    if ($value === true) return true;
    if ($value === false || $value === null) return false;
    return !in_array(strtolower(trim((string)$value)), ['', '0', 'false', 'no', 'off'], true);
}

function promptText(string $label, string $default = ''): string {
    $suffix = $default === '' ? '' : " [{$default}]";
    fwrite(STDOUT, "{$label}{$suffix}: ");
    $line = fgets(STDIN);
    if ($line === false) return $default;
    $value = trim($line);
    return $value === '' ? $default : $value;
}

function promptYesNo(string $label, bool $default): bool {
    $suffix = $default ? 'Y/n' : 'y/N';
    while (true) {
        fwrite(STDOUT, "{$label} [{$suffix}]: ");
        $line = fgets(STDIN);
        if ($line === false) return $default;
        $value = strtolower(trim($line));
        if ($value === '') return $default;
        if (in_array($value, ['y', 'yes'], true)) return true;
        if (in_array($value, ['n', 'no'], true)) return false;
    }
}

function parseHeaderInput(string $value): array {
    $headers = [];
    foreach (explode(',', $value) as $header) {
        $header = trim($header);
        if ($header !== '' && str_contains($header, ':')) $headers[] = $header;
    }
    return $headers;
}

function csvList(string $value): array {
    return array_values(array_filter(array_map('trim', explode(',', $value)), fn(string $item) => $item !== ''));
}

function guessBaseUrl(string $schemaLocation): string {
    if (trim($schemaLocation) === '') return '';
    try {
        $schema = loadSchemaOnce($schemaLocation, 3.0, []);
        return isset($schema['servers'][0]['url']) ? rtrim((string)$schema['servers'][0]['url'], '/') : '';
    } catch (Throwable) {
        return '';
    }
}

function doctorLine(string $status, string $label, string $detail): void {
    printf(" %-4s %-20s %s\n", $status, $label . ':', $detail);
}

function runReplayCommand(?string $target, array $options): int {
    $cacheDir = (string)($options['cache-dir'] ?? DEFAULT_CACHE_DIR);
    $crashes = resolveReplayTargets($target, $cacheDir);
    if (!$crashes) {
        fwrite(STDERR, "No crash files found to replay.\n");
        return 2;
    }

    $timeout = isset($options['request-timeout']) ? max(1.0, (float)$options['request-timeout']) : 10.0;
    $transport = transportOptionsFromOptions($options);
    $failures = [];
    $passed = 0;

    echo "openapi-contract-php replay\n";
    echo str_repeat("-", 27) . "\n\n";

    foreach ($crashes as $path) {
        $crash = json_decode((string)file_get_contents($path), true);
        if (!is_array($crash)) {
            $failures[] = "{$path}: invalid crash file";
            continue;
        }

        $request = $crash['request'] ?? [];
        $method = (string)($request['method'] ?? 'GET');
        $url = replayUrl($crash, $options);
        $headers = array_map('strval', $request['headers'] ?? []);
        $body = array_key_exists('body', $request) && $request['body'] !== null ? (string)$request['body'] : null;

        try {
            $response = httpRequest($method, $url, $headers, $body, $timeout, $transport);
            $failure = null;
            if (isset($crash['operation'], $crash['components'], $crash['checks']) && is_array($crash['operation'])) {
                $failure = validateResponse(
                    ['operation' => $crash['operation'], 'path' => $crash['operation_path'] ?? $request['path_query'] ?? '', 'method' => $method],
                    $response,
                    is_array($crash['components']) ? $crash['components'] : [],
                    is_array($crash['checks']) ? $crash['checks'] : DEFAULT_CHECKS,
                    $crash['max_response_time'] ?? null,
                    (string)($request['mode'] ?? 'positive')
                );
            }
            if ($failure === null) {
                echo " OK   {$crash['id']} {$method} {$url}\n";
                $passed++;
                if (!($options['keep'] ?? false)) @unlink($path);
            } else {
                echo " FAIL {$crash['id']} {$method} {$url}: {$failure}\n";
                $failures[] = "{$crash['id']}: {$failure}";
            }
        } catch (Throwable $e) {
            echo " FAIL {$crash['id']} {$method} {$url}: {$e->getMessage()}\n";
            $failures[] = "{$crash['id']}: {$e->getMessage()}";
        }
    }

    echo "\n=================================== SUMMARY ====================================\n";
    echo "Replayed: " . count($crashes) . "\n";
    echo "Passed: {$passed}\n";
    echo "Failed: " . count($failures) . "\n";
    return $failures ? 1 : 0;
}

function resolveReplayTargets(?string $target, string $cacheDir): array {
    $crashDir = rtrim($cacheDir, DIRECTORY_SEPARATOR) . DIRECTORY_SEPARATOR . 'crashes';
    if ($target === null || $target === '') {
        return array_values(array_filter(glob($crashDir . DIRECTORY_SEPARATOR . '*.json') ?: [], 'is_file'));
    }
    if (is_file($target)) return [$target];
    if (is_dir($target)) return array_values(array_filter(glob(rtrim($target, DIRECTORY_SEPARATOR) . DIRECTORY_SEPARATOR . '*.json') ?: [], 'is_file'));
    $candidate = $crashDir . DIRECTORY_SEPARATOR . $target . '.json';
    if (is_file($candidate)) return [$candidate];
    $matches = glob($crashDir . DIRECTORY_SEPARATOR . $target . '*.json') ?: [];
    return array_values(array_filter($matches, 'is_file'));
}

function replayUrl(array $crash, array $options): string {
    if (!isset($options['url']) || trim((string)$options['url']) === '') {
        return (string)($crash['request']['url'] ?? '');
    }
    $pathQuery = (string)($crash['request']['path_query'] ?? parse_url((string)($crash['request']['url'] ?? ''), PHP_URL_PATH) ?? '/');
    return rtrim((string)$options['url'], '/') . $pathQuery;
}

function parseCli(array $argv): array {
    $command = $argv[1] ?? null;
    $options = [];
    $location = null;
    $count = count($argv);
    for ($i = 2; $i < $count; $i++) {
        $arg = $argv[$i];
        if ($arg === '-H' || $arg === '--header') {
            $options['header'][] = $argv[++$i] ?? '';
            continue;
        }
        if ($arg === '-a' || $arg === '--auth') {
            $options['auth'] = $argv[++$i] ?? '';
            continue;
        }
        if ($arg === '-c' || $arg === '--checks') {
            appendOption($options, 'checks', $argv[++$i] ?? '');
            continue;
        }
        if ($arg === '-m' || $arg === '--mode') {
            $options['mode'] = $argv[++$i] ?? '';
            continue;
        }
        if ($arg === '-w' || $arg === '--workers') {
            $options['workers'] = $argv[++$i] ?? '';
            continue;
        }
        if ($arg === '-u' || $arg === '--url') {
            $options['url'] = $argv[++$i] ?? '';
            continue;
        }
        if ($arg === '-n' || $arg === '--max-examples') {
            $options['max-examples'] = $argv[++$i] ?? '1';
            continue;
        }
        if (str_starts_with($arg, '--')) {
            $arg = substr($arg, 2);
            if (str_contains($arg, '=')) {
                [$key, $value] = explode('=', $arg, 2);
                if ($key === 'header') $options['header'][] = $value;
                elseif (isRepeatableOption($key)) appendOption($options, $key, $value);
                else $options[$key] = $value;
            } elseif (longOptionRequiresValue($arg)) {
                $value = $argv[++$i] ?? '';
                if (isRepeatableOption($arg)) appendOption($options, $arg, $value);
                else $options[$arg] = $value;
            } elseif ($arg === 'header') {
                $options['header'][] = $argv[++$i] ?? '';
            } else {
                $options[$arg] = true;
            }
            continue;
        }
        $location = $arg;
    }
    return ['command' => $command, 'location' => $location, 'options' => $options];
}

function longOptionRequiresValue(string $option): bool {
    return in_array($option, [
        'config',
        'url',
        'workers',
        'max-examples',
        'max-time',
        'phases',
        'suppress-health-check',
        'wait-for-schema',
        'warnings',
        'checks',
        'exclude-checks',
        'max-failures',
        'max-response-time',
        'include-path',
        'include-method',
        'include-tag',
        'include-operation-id',
        'exclude-path',
        'exclude-method',
        'exclude-tag',
        'exclude-operation-id',
        'include-path-regex',
        'include-method-regex',
        'include-tag-regex',
        'include-operation-id-regex',
        'exclude-path-regex',
        'exclude-method-regex',
        'exclude-tag-regex',
        'exclude-operation-id-regex',
        'include-by',
        'exclude-by',
        'request-timeout',
        'request-retries',
        'request-cert',
        'request-cert-key',
        'proxy',
        'tls-verify',
        'rate-limit',
        'max-redirects',
        'report',
        'report-dir',
        'cache-dir',
        'report-junit-path',
        'report-vcr-path',
        'report-har-path',
        'report-ndjson-path',
        'output-sanitize',
        'output-truncate',
        'mode',
        'seed',
        'auth',
        'generation-allow-x00',
        'generation-codec',
        'generation-maximize',
        'generation-with-security-parameters',
        'generation-graphql-allow-null',
        'generation-database',
        'schema-location'
    ], true);
}

function isRepeatableOption(string $option): bool {
    return in_array($option, [
        'checks',
        'exclude-checks',
        'include-path',
        'include-method',
        'include-tag',
        'include-operation-id',
        'exclude-path',
        'exclude-method',
        'exclude-tag',
        'exclude-operation-id',
        'include-path-regex',
        'include-method-regex',
        'include-tag-regex',
        'include-operation-id-regex',
        'exclude-path-regex',
        'exclude-method-regex',
        'exclude-tag-regex',
        'exclude-operation-id-regex',
        'include-by',
        'exclude-by',
        'report'
    ], true);
}

function appendOption(array &$options, string $name, string $value): void {
    if (!isset($options[$name])) {
        $options[$name] = [$value];
        return;
    }
    if (!is_array($options[$name])) {
        $options[$name] = [$options[$name]];
    }
    $options[$name][] = $value;
}

function mergeConfigOptions(array $options): array {
    $configPath = $options['config'] ?? null;
    if ($configPath === null) {
        foreach (['openapi-contract.json', '.openapi-contract.json'] as $candidate) {
            if (is_file($candidate)) {
                $configPath = $candidate;
                break;
            }
        }
    }
    if ($configPath === null || $configPath === true || trim((string)$configPath) === '') return $options;
    if (!is_file((string)$configPath)) {
        fwrite(STDERR, "Config file not found: {$configPath}\n");
        exit(2);
    }

    $json = file_get_contents((string)$configPath);
    $config = json_decode((string)$json, true);
    if (!is_array($config)) {
        fwrite(STDERR, "Config file is not valid JSON: {$configPath}\n");
        exit(2);
    }

    $defaults = flattenConfigOptions($config);
    foreach ($options as $key => $value) {
        if ($key === 'config') continue;
        $defaults[$key] = mergeOptionValue($defaults[$key] ?? null, $value);
    }
    $defaults['config'] = $configPath;
    return $defaults;
}

function flattenConfigOptions(array $config): array {
    $options = [];
    foreach ($config as $key => $value) {
        if ($key === 'headers' && is_array($value)) {
            foreach ($value as $header) $options['header'][] = (string)$header;
            continue;
        }
        if ($key === 'auth' && is_array($value) && isset($value['basic'])) {
            $basic = $value['basic'];
            if (is_array($basic) && isset($basic['username'], $basic['password'])) {
                $options['auth'] = $basic['username'] . ':' . $basic['password'];
            }
            continue;
        }
        if ($key === 'reports' && is_array($value)) {
            flattenReportConfig($value, $options);
            continue;
        }
        if ($key === 'generation' && is_array($value)) {
            foreach ($value as $generationKey => $generationValue) {
                $options['generation-' . kebabCase((string)$generationKey)] = scalarConfigValue($generationValue);
            }
            continue;
        }
        if ($key === 'request' && is_array($value)) {
            foreach ($value as $requestKey => $requestValue) {
                $options['request-' . kebabCase((string)$requestKey)] = scalarConfigValue($requestValue);
            }
            continue;
        }
        $options[kebabCase((string)$key)] = scalarConfigValue($value);
    }
    return $options;
}

function flattenReportConfig(array $reports, array &$options): void {
    if (isset($reports['directory'])) $options['report-dir'] = (string)$reports['directory'];
    foreach (['junit', 'har', 'ndjson', 'vcr'] as $format) {
        if (!isset($reports[$format]) || !is_array($reports[$format])) continue;
        if (($reports[$format]['enabled'] ?? false) || isset($reports[$format]['path'])) {
            appendOption($options, 'report', $format);
        }
        if (isset($reports[$format]['path'])) {
            $options["report-{$format}-path"] = (string)$reports[$format]['path'];
        }
    }
}

function scalarConfigValue($value) {
    if (is_array($value)) return $value;
    if (is_bool($value)) return $value ? 'true' : 'false';
    return $value;
}

function kebabCase(string $value): string {
    return strtolower(str_replace('_', '-', $value));
}

function mergeOptionValue($default, $override) {
    if ($default === null) return $override;
    if (is_array($default) || is_array($override)) {
        return array_merge((array)$default, (array)$override);
    }
    return $override;
}

function reportOptionsFromOptions(array $options): array {
    $formats = csvOption($options, 'report', []);
    foreach (['junit', 'har', 'ndjson', 'vcr'] as $format) {
        if (isset($options["report-{$format}-path"])) $formats[] = $format;
    }
    $formats = array_values(array_unique(array_filter($formats, fn(string $format) => in_array($format, ['junit', 'har', 'ndjson', 'vcr'], true))));
    $dir = rtrim((string)($options['report-dir'] ?? DEFAULT_REPORT_DIR), DIRECTORY_SEPARATOR);
    return [
        'formats' => $formats,
        'dir' => $dir,
        'paths' => [
            'junit' => $options['report-junit-path'] ?? ($dir . DIRECTORY_SEPARATOR . 'junit.xml'),
            'har' => $options['report-har-path'] ?? ($dir . DIRECTORY_SEPARATOR . 'traffic.har'),
            'ndjson' => $options['report-ndjson-path'] ?? ($dir . DIRECTORY_SEPARATOR . 'events.ndjson'),
            'vcr' => $options['report-vcr-path'] ?? ($dir . DIRECTORY_SEPARATOR . 'cassette.yaml')
        ],
        'preserve_bytes' => (bool)($options['report-preserve-bytes'] ?? false)
    ];
}

function csvOption(array $options, string $name, array $default): array {
    $value = $options[$name] ?? null;
    if ($value === null || $value === true || $value === '') return $default;
    if (is_array($value)) {
        $items = [];
        foreach ($value as $item) {
            $items = array_merge($items, array_map('trim', explode(',', (string)$item)));
        }
        return array_values(array_filter($items, fn($item) => $item !== ''));
    }
    return array_values(array_filter(array_map('trim', explode(',', (string)$value)), fn($item) => $item !== ''));
}

function headersFromOptions(array $options): array {
    $headers = ['Accept: application/json'];
    foreach ((array)($options['header'] ?? []) as $header) {
        if (trim((string)$header) !== '') $headers[] = trim((string)$header);
    }
    if (isset($options['auth']) && !hasHeader($headers, 'authorization')) {
        $headers[] = 'Authorization: Basic ' . base64_encode((string)$options['auth']);
    }
    return $headers;
}

function hasHeader(array $headers, string $name): bool {
    $prefix = strtolower($name) . ':';
    foreach ($headers as $header) {
        if (str_starts_with(strtolower($header), $prefix)) return true;
    }
    return false;
}

function selectedChecks(array $options): array {
    $checks = csvOption($options, 'checks', DEFAULT_CHECKS);
    if (in_array('all', $checks, true)) $checks = KNOWN_CHECKS;
    $exclude = csvOption($options, 'exclude-checks', []);
    if (in_array('all', $exclude, true)) return [];
    return array_values(array_diff($checks, $exclude));
}

function transportOptionsFromOptions(array $options): array {
    return [
        'request_retries' => isset($options['request-retries']) ? max(0, (int)$options['request-retries']) : 0,
        'max_redirects' => isset($options['max-redirects']) ? max(0, (int)$options['max-redirects']) : 0,
        'proxy' => isset($options['proxy']) ? trim((string)$options['proxy']) : null,
        'tls_verify' => parseTlsVerify($options['tls-verify'] ?? true),
        'request_cert' => isset($options['request-cert']) ? trim((string)$options['request-cert']) : null,
        'request_cert_key' => isset($options['request-cert-key']) ? trim((string)$options['request-cert-key']) : null,
        'rate_limit_interval' => isset($options['rate-limit']) ? parseRateLimit((string)$options['rate-limit']) : null
    ];
}

function parseTlsVerify($value) {
    if ($value === true || $value === null) return true;
    $normalized = strtolower(trim((string)$value));
    return match ($normalized) {
        'false', '0', 'no', 'off' => false,
        'true', '1', 'yes', 'on' => true,
        default => (string)$value
    };
}

function parseRateLimit(string $value): ?float {
    if (!preg_match('/^\s*(\d+(?:\.\d+)?)\s*\/\s*([smh])\s*$/i', $value, $match)) return null;
    $limit = (float)$match[1];
    if ($limit <= 0.0) return null;
    $seconds = match (strtolower($match[2])) {
        'h' => 3600.0,
        'm' => 60.0,
        default => 1.0
    };
    return $seconds / $limit;
}

function addCompatibilityWarnings(array $options, array $phases, array $checks, string $command, array $schema, array &$warnings): void {
    foreach (array_diff($checks, IMPLEMENTED_CHECKS) as $check) {
        $warnings[] = "Check '{$check}' is accepted but is not implemented yet.";
    }
    if (in_array('stateful', $phases, true)) {
        $warnings[] = "Stateful testing currently runs a linear workflow; link-based workflow extraction is not implemented yet.";
    }
    if (isset($options['workers']) && (string)$options['workers'] !== '1') {
        $warnings[] = "--workers is accepted but execution is currently sequential.";
    }
    if ($command === 'fuzz' && !isset($options['max-time']) && !isset($options['max-examples'])) {
        $warnings[] = "fuzz currently runs 100 examples per operation by default; pass --max-time for time-bounded fuzzing.";
    }
    if (($options['generation-deterministic'] ?? false) === true) {
        $warnings[] = "--generation-deterministic is accepted; use --seed for current reproducibility.";
    }
    foreach ([
        'no-shrink' => 'shrinking',
        'generation-maximize' => 'targeted generation',
        'generation-database' => 'example database persistence',
        'generation-unique-inputs' => 'unique-input filtering',
        'generation-graphql-allow-null' => 'GraphQL generation'
    ] as $option => $feature) {
        if (isset($options[$option])) {
            $warnings[] = "--{$option} is accepted, but {$feature} is not implemented yet.";
        }
    }
    if (!str_starts_with((string)($schema['openapi'] ?? ''), '3.')) {
        $warnings[] = "Only OpenAPI 3.x JSON is actively supported by this runner today.";
    }
}

function loadSchema(string $location, float $timeout, float $waitForSchema = 0.0, array $transport = []): array {
    $deadline = $waitForSchema > 0.0 ? microtime(true) + $waitForSchema : null;
    $lastError = null;

    do {
        try {
            return loadSchemaOnce($location, $timeout, $transport);
        } catch (Throwable $e) {
            $lastError = $e;
            if ($deadline === null || microtime(true) >= $deadline) break;
            usleep(250000);
        }
    } while (true);

    throw $lastError ?? new RuntimeException('schema could not be loaded');
}

function loadSchemaOnce(string $location, float $timeout, array $transport = []): array {
    if (preg_match('#^https?://#', $location)) {
        $response = httpRequest('GET', $location, ['Accept: application/json'], null, $timeout, $transport);
        if ($response['status'] < 200 || $response['status'] >= 300) {
            throw new RuntimeException("schema returned HTTP {$response['status']}");
        }
        $json = $response['body'];
    } else {
        if (!is_file($location)) throw new RuntimeException("schema file not found: {$location}");
        $json = file_get_contents($location);
    }
    $schema = decodeSchemaDocument((string)$json, $location);
    if (!is_array($schema)) throw new RuntimeException('schema is not a supported JSON or YAML object');
    return $schema;
}

function decodeSchemaDocument(string $document, string $location): array {
    $json = json_decode($document, true);
    if (is_array($json)) return $json;

    if (function_exists('yaml_parse')) {
        $yaml = @yaml_parse($document);
        if (is_array($yaml)) return $yaml;
    }

    if (preg_match('/\.(ya?ml)$/i', parse_url($location, PHP_URL_PATH) ?? $location)) {
        $yaml = parseSimpleYaml($document);
        if (is_array($yaml)) return $yaml;
    }

    throw new RuntimeException('schema is not valid JSON and could not be parsed as YAML');
}

function parseSimpleYaml(string $document): array {
    $lines = preg_split('/\r\n|\n|\r/', $document) ?: [];
    $index = 0;
    $parsed = parseYamlBlock($lines, $index, 0);
    return is_array($parsed) ? $parsed : [];
}

function parseYamlBlock(array $lines, int &$index, int $indent) {
    $result = [];
    $isList = null;
    $count = count($lines);

    while ($index < $count) {
        $raw = rtrim($lines[$index]);
        if (trim($raw) === '' || str_starts_with(ltrim($raw), '#')) {
            $index++;
            continue;
        }
        $currentIndent = strlen($raw) - strlen(ltrim($raw, ' '));
        if ($currentIndent < $indent) break;
        if ($currentIndent > $indent) break;

        $line = ltrim($raw);
        if (str_starts_with($line, '- ')) {
            if ($isList === false) break;
            $isList = true;
            $item = substr($line, 2);
            $index++;
            $result[] = parseYamlValueOrNested($item, $lines, $index, $indent + 2);
            continue;
        }

        if ($isList === true || !str_contains($line, ':')) break;
        $isList = false;
        [$key, $value] = explode(':', $line, 2);
        $index++;
        $result[trim($key, "\"' ")] = parseYamlValueOrNested(ltrim($value), $lines, $index, $indent + 2);
    }

    return $result;
}

function parseYamlValueOrNested(string $value, array $lines, int &$index, int $indent) {
    $value = stripYamlComment($value);
    if ($value === '') return parseYamlBlock($lines, $index, $indent);
    if (str_contains($value, ': ') && !str_starts_with($value, '"') && !str_starts_with($value, "'")) {
        [$key, $nestedValue] = explode(':', $value, 2);
        return [trim($key, "\"' ") => parseYamlScalar(trim($nestedValue))];
    }
    return parseYamlScalar($value);
}

function stripYamlComment(string $value): string {
    $inSingle = false;
    $inDouble = false;
    $length = strlen($value);
    for ($i = 0; $i < $length; $i++) {
        $char = $value[$i];
        if ($char === "'" && !$inDouble) $inSingle = !$inSingle;
        elseif ($char === '"' && !$inSingle) $inDouble = !$inDouble;
        elseif ($char === '#' && !$inSingle && !$inDouble && ($i === 0 || ctype_space($value[$i - 1]))) {
            return trim(substr($value, 0, $i));
        }
    }
    return trim($value);
}

function parseYamlScalar(string $value) {
    $value = trim($value);
    if ($value === 'null' || $value === '~') return null;
    if ($value === 'true') return true;
    if ($value === 'false') return false;
    if (is_numeric($value)) return str_contains($value, '.') ? (float)$value : (int)$value;
    if ((str_starts_with($value, '"') && str_ends_with($value, '"')) || (str_starts_with($value, "'") && str_ends_with($value, "'"))) {
        return stripcslashes(substr($value, 1, -1));
    }
    if (str_starts_with($value, '[') && str_ends_with($value, ']')) {
        $json = json_decode($value, true);
        if (is_array($json)) return $json;
        $inner = trim(substr($value, 1, -1));
        if ($inner === '') return [];
        return array_map(fn(string $item) => parseYamlScalar($item), array_map('trim', explode(',', $inner)));
    }
    if (str_starts_with($value, '{') && str_ends_with($value, '}')) {
        $json = json_decode($value, true);
        if (is_array($json)) return $json;
    }
    return $value;
}

function httpRequest(string $method, string $url, array $headers, ?string $body, float $timeout, array $transport = []): array {
    $ch = curl_init($url);
    $curlOptions = [
        CURLOPT_CUSTOMREQUEST => $method,
        CURLOPT_RETURNTRANSFER => true,
        CURLOPT_HEADER => true,
        CURLOPT_FOLLOWLOCATION => ((int)($transport['max_redirects'] ?? 0)) > 0,
        CURLOPT_MAXREDIRS => (int)($transport['max_redirects'] ?? 0),
        CURLOPT_CONNECTTIMEOUT => min(5.0, $timeout),
        CURLOPT_TIMEOUT => $timeout,
        CURLOPT_HTTPHEADER => $headers
    ];
    if (!empty($transport['proxy'])) $curlOptions[CURLOPT_PROXY] = (string)$transport['proxy'];
    $tlsVerify = $transport['tls_verify'] ?? true;
    if ($tlsVerify === false) {
        $curlOptions[CURLOPT_SSL_VERIFYPEER] = false;
        $curlOptions[CURLOPT_SSL_VERIFYHOST] = false;
    } elseif (is_string($tlsVerify)) {
        $curlOptions[CURLOPT_CAINFO] = $tlsVerify;
    }
    if (!empty($transport['request_cert'])) $curlOptions[CURLOPT_SSLCERT] = (string)$transport['request_cert'];
    if (!empty($transport['request_cert_key'])) $curlOptions[CURLOPT_SSLKEY] = (string)$transport['request_cert_key'];
    curl_setopt_array($ch, $curlOptions);
    if ($body !== null) curl_setopt($ch, CURLOPT_POSTFIELDS, $body);
    $started = microtime(true);
    $raw = curl_exec($ch);
    $duration = microtime(true) - $started;
    if ($raw === false) {
        $error = curl_error($ch);
        curl_close($ch);
        throw new RuntimeException($error);
    }
    $headerSize = curl_getinfo($ch, CURLINFO_HEADER_SIZE);
    $status = (int)curl_getinfo($ch, CURLINFO_RESPONSE_CODE);
    $rawHeaders = substr($raw, 0, $headerSize);
    $responseBody = substr($raw, $headerSize);
    curl_close($ch);

    $parsedHeaders = [];
    foreach (preg_split('/\r\n|\n|\r/', trim($rawHeaders)) as $line) {
        if (!str_contains($line, ':')) continue;
        [$name, $value] = explode(':', $line, 2);
        $parsedHeaders[strtolower(trim($name))] = trim($value);
    }
    return ['status' => $status, 'headers' => $parsedHeaders, 'body' => $responseBody, 'duration' => $duration];
}

function baseUrlFromSchema(array $schema, ?string $override): string {
    if ($override) return rtrim($override, '/');
    $server = $schema['servers'][0]['url'] ?? null;
    if (!$server) throw new RuntimeException('schema has no servers[0].url; pass --url');
    return rtrim((string)$server, '/');
}

function collectOperations(array $schema): array {
    $operations = [];
    foreach (($schema['paths'] ?? []) as $path => $pathItem) {
        if (!is_array($pathItem)) continue;
        foreach (HTTP_OPERATION_METHODS as $method) {
            if (!isset($pathItem[$method]) || !is_array($pathItem[$method])) continue;
            $operations[] = [
                'method' => strtoupper($method),
                'method_key' => $method,
                'path' => $path,
                'path_item' => $pathItem,
                'operation' => $pathItem[$method]
            ];
        }
    }
    return $operations;
}

function filterOperations(array $operations, array $options, array &$warnings): array {
    $selected = [];
    foreach ($operations as $operation) {
        if (operationIncluded($operation, $options, $warnings)) $selected[] = $operation;
    }
    return $selected;
}

function operationIncluded(array $operation, array $options, array &$warnings): bool {
    if (($options['exclude-deprecated'] ?? false) && ($operation['operation']['deprecated'] ?? false)) return false;

    foreach (['path', 'method', 'tag', 'operation-id'] as $type) {
        $include = optionValues($options, "include-{$type}");
        if ($include && !operationMatchesAny($operation, $type, $include, false, $warnings)) return false;

        $includeRegex = optionValues($options, "include-{$type}-regex");
        if ($includeRegex && !operationMatchesAny($operation, $type, $includeRegex, true, $warnings)) return false;

        $exclude = optionValues($options, "exclude-{$type}");
        if ($exclude && operationMatchesAny($operation, $type, $exclude, false, $warnings)) return false;

        $excludeRegex = optionValues($options, "exclude-{$type}-regex");
        if ($excludeRegex && operationMatchesAny($operation, $type, $excludeRegex, true, $warnings)) return false;
    }

    foreach (optionValues($options, 'include-by') as $expression) {
        $matches = operationMatchesExpression($operation, $expression, $warnings);
        if ($matches === false) return false;
    }
    foreach (optionValues($options, 'exclude-by') as $expression) {
        $matches = operationMatchesExpression($operation, $expression, $warnings);
        if ($matches === true) return false;
    }

    return true;
}

function optionValues(array $options, string $name): array {
    if (!isset($options[$name]) || $options[$name] === true) return [];
    $value = $options[$name];
    if (!is_array($value)) $value = [$value];
    return array_values(array_filter(array_map('strval', $value), fn(string $item) => $item !== ''));
}

function operationMatchesAny(array $operation, string $type, array $needles, bool $regex, array &$warnings): bool {
    $values = operationFilterValues($operation, $type);
    foreach ($needles as $needle) {
        foreach ($values as $value) {
            if ($regex) {
                if (@preg_match('/' . str_replace('/', '\/', $needle) . '/', '') === false) {
                    $warnings[] = "Ignoring invalid regex filter '{$needle}'.";
                    continue 2;
                }
                if (preg_match('/' . str_replace('/', '\/', $needle) . '/', $value)) return true;
            } elseif (strcasecmp($value, $needle) === 0) {
                return true;
            }
        }
    }
    return false;
}

function operationFilterValues(array $operation, string $type): array {
    return match ($type) {
        'path' => [$operation['path']],
        'method' => [$operation['method']],
        'tag' => array_map('strval', $operation['operation']['tags'] ?? []),
        'operation-id' => isset($operation['operation']['operationId']) ? [(string)$operation['operation']['operationId']] : [],
        default => []
    };
}

function operationMatchesExpression(array $operation, string $expression, array &$warnings): ?bool {
    if (!preg_match('/^\s*(\/\S*)\s*(==|!=)\s*(.+?)\s*$/', $expression, $match)) {
        $warnings[] = "Ignoring unsupported filter expression '{$expression}'.";
        return null;
    }
    $document = array_merge($operation['operation'], [
        'path' => $operation['path'],
        'method' => $operation['method'],
        'operation' => $operation['operation']
    ]);
    $actual = jsonPointer($document, $match[1]);
    $expected = trim($match[3]);
    if ((str_starts_with($expected, "'") && str_ends_with($expected, "'")) || (str_starts_with($expected, '"') && str_ends_with($expected, '"'))) {
        $expected = substr($expected, 1, -1);
    }
    $matches = (string)$actual === $expected;
    return $match[2] === '!=' ? !$matches : $matches;
}

function jsonPointer($document, string $pointer) {
    if ($pointer === '') return $document;
    $current = $document;
    foreach (explode('/', ltrim($pointer, '/')) as $segment) {
        $segment = str_replace(['~1', '~0'], ['/', '~'], $segment);
        if (is_array($current) && array_key_exists($segment, $current)) {
            $current = $current[$segment];
        } else {
            return null;
        }
    }
    return is_scalar($current) || $current === null ? $current : json_encode($current);
}

function runExamplesPhase(array $operations, array &$state): array {
    $result = ['passed' => 0, 'failed' => 0, 'skipped' => 0];
    foreach ($operations as $operation) {
        runCase($operation, $state, 'examples', exampleRequestBody($operation['operation']), true, $result);
        if (failureLimitReached($state)) break;
    }
    return $result;
}

function runCoveragePhase(array $operations, array &$state): array {
    $result = ['passed' => 0, 'failed' => 0, 'skipped' => 0];
    foreach ($operations as $operation) {
        runCase($operation, $state, 'coverage', exampleRequestBody($operation['operation']), true, $result);
        if (!failureLimitReached($state)) runInvalidPathCase($operation, $state, $result);
        if (!failureLimitReached($state)) runUnsupportedMethodCase($operation, $state, $result);
        if (failureLimitReached($state)) break;
    }
    return $result;
}

function runFuzzingPhase(array $operations, array &$state, int $maxExamples, ?float $deadline = null): array {
    $result = ['passed' => 0, 'failed' => 0, 'skipped' => 0];
    $modes = match ($state['mode'] ?? 'positive') {
        'negative' => ['negative'],
        'all' => ['positive', 'negative'],
        default => ['positive']
    };
    foreach ($operations as $operation) {
        for ($i = 0; $i < $maxExamples; $i++) {
            if ($deadline !== null && microtime(true) >= $deadline) break 2;
            foreach ($modes as $mode) {
                if ($mode === 'negative' && !operationHasInput($operation['operation'])) {
                    $result['skipped']++;
                    continue;
                }
                runCase($operation, $state, 'fuzzing', generatedRequestBody($operation['operation'], $state['components'], $mode), false, $result, $mode);
                if (failureLimitReached($state)) break 3;
                if ($deadline !== null && microtime(true) >= $deadline) break 3;
            }
        }
    }
    return $result;
}

function operationHasInput(array $operation): bool {
    if (isset($operation['requestBody'])) return true;
    foreach (operationParameters($operation) as $parameter) {
        if (in_array($parameter['in'] ?? '', ['path', 'query', 'header', 'cookie'], true)) return true;
    }
    return false;
}

function runStatefulPhase(array $operations, array &$state, int $maxExamples, ?float $deadline = null): array {
    $result = ['passed' => 0, 'failed' => 0, 'skipped' => 0];
    $iterations = max(1, min($maxExamples, 25));
    for ($i = 0; $i < $iterations; $i++) {
        foreach ($operations as $operation) {
            if ($deadline !== null && microtime(true) >= $deadline) return $result;
            runCase($operation, $state, 'stateful', generatedRequestBody($operation['operation'], $state['components'], 'positive'), false, $result, 'positive');
            if (failureLimitReached($state)) return $result;
        }
    }
    return $result;
}

function exampleRequestBody(array $operation): ?string {
    $json = $operation['requestBody']['content']['application/json'] ?? null;
    if (!$json) return null;
    if (array_key_exists('example', $json)) return json_encode($json['example']);
    return '{}';
}

function generatedRequestBody(array $operation, array $components, string $mode = 'positive'): ?string {
    $json = $operation['requestBody']['content']['application/json'] ?? null;
    if (!$json) return null;
    $schema = $json['schema'] ?? ['type' => 'object'];
    $value = $mode === 'negative' ? generateInvalidValue($schema, $components) : generateValue($schema, $components);
    return json_encode($value);
}

function runCase(array $op, array &$state, string $phase, ?string $body, bool $useExamples, array &$result, string $caseMode = 'positive'): void {
    $method = $op['method'];
    $path = concretePath($op['path'], $op['operation'], $useExamples);
    $query = queryString($op['operation'], $state['components'], $useExamples, $caseMode);
    $pathQuery = $path . $query;
    $url = $state['base_url'] . $pathQuery;
    $headers = $state['headers'];
    foreach (operationParameterHeaders($op['operation'], $state['components'], $useExamples, $caseMode) as $header) $headers[] = $header;
    if ($body !== null && !hasHeader($headers, 'content-type')) $headers[] = 'Content-Type: application/json';
    $request = buildRequestRecord($phase, $op, $method, $url, $pathQuery, $headers, $body, $caseMode);

    try {
        $response = requestWithState($method, $url, $headers, $body, $state);
    } catch (Throwable $e) {
        $case = recordCase($state, $request, null, "{$phase} {$method} {$op['path']} request failed: {$e->getMessage()}");
        recordFailure($state, $result, "{$phase} {$method} {$op['path']} request failed: {$e->getMessage()}", $case);
        return;
    }

    $state['cases']++;
    $failure = validateResponse($op, $response, $state['components'], $state['checks'], $state['max_response_time'], $caseMode);
    $case = recordCase($state, $request, $response, $failure);
    if ($failure) {
        recordFailure($state, $result, "{$phase} {$method} {$op['path']}: {$failure}", $case);
    } else {
        $result['passed']++;
    }
}

function runInvalidPathCase(array $op, array &$state, array &$result): void {
    if (!str_contains($op['path'], '{')) return;
    $path = preg_replace('/\{[^}]+\}/', 'not-an-id', $op['path'], 1);
    $url = $state['base_url'] . $path;
    $request = buildRequestRecord('coverage', $op, $op['method'], $url, $path, $state['headers'], null);
    try {
        $response = requestWithState($op['method'], $url, $state['headers'], null, $state);
    } catch (Throwable $e) {
        $case = recordCase($state, $request, null, "coverage {$op['method']} {$path} request failed: {$e->getMessage()}");
        recordFailure($state, $result, "coverage {$op['method']} {$path} request failed: {$e->getMessage()}", $case);
        return;
    }
    $state['cases']++;
    $contentType = strtolower($response['headers']['content-type'] ?? '');
    if ($response['status'] === 404 && str_contains($contentType, 'application/json')) {
        recordCase($state, $request, $response, null);
        $result['passed']++;
    } else {
        $failure = "coverage {$op['method']} {$path}: expected JSON 404, got HTTP {$response['status']} {$contentType}";
        $case = recordCase($state, $request, $response, $failure);
        recordFailure($state, $result, $failure, $case);
    }
}

function runUnsupportedMethodCase(array $op, array &$state, array &$result): void {
    if (!in_array('unsupported_method', $state['checks'], true)) return;
    $allowed = allowedMethodsForPathItem($op['path_item']);
    if (!$allowed) return;
    $path = concretePath($op['path'], $op['operation'], true);
    $url = $state['base_url'] . $path;
    $request = buildRequestRecord('coverage', $op, 'TRACE', $url, $path, $state['headers'], null);
    try {
        $response = requestWithState('TRACE', $url, $state['headers'], null, $state);
    } catch (Throwable $e) {
        $case = recordCase($state, $request, null, "coverage TRACE {$op['path']} request failed: {$e->getMessage()}");
        recordFailure($state, $result, "coverage TRACE {$op['path']} request failed: {$e->getMessage()}", $case);
        return;
    }
    $state['cases']++;
    $allow = $response['headers']['allow'] ?? '';
    $missing = array_filter($allowed, fn($method) => !str_contains($allow, $method));
    if ($response['status'] === 405 && !$missing) {
        recordCase($state, $request, $response, null);
        $result['passed']++;
    } else {
        $failure = "coverage TRACE {$op['path']}: expected 405 with Allow [" . implode(', ', $allowed) . "], got HTTP {$response['status']} Allow '{$allow}'";
        $case = recordCase($state, $request, $response, $failure);
        recordFailure($state, $result, $failure, $case);
    }
}

function requestWithState(string $method, string $url, array $headers, ?string $body, array &$state): array {
    $interval = $state['transport']['rate_limit_interval'] ?? null;
    if ($interval !== null && $state['last_request_at'] !== null) {
        $wait = $interval - (microtime(true) - $state['last_request_at']);
        if ($wait > 0) usleep((int)round($wait * 1000000));
    }

    $retries = (int)($state['transport']['request_retries'] ?? 0);
    $attempt = 0;
    do {
        try {
            $response = httpRequest($method, $url, $headers, $body, $state['timeout'], $state['transport']);
            $state['last_request_at'] = microtime(true);
            return $response;
        } catch (Throwable $e) {
            if ($attempt >= $retries) throw $e;
            usleep((int)(100000 * (2 ** $attempt)));
            $attempt++;
        }
    } while (true);
}

function validateResponse(array $op, array $response, array $components, array $checks, ?float $maxResponseTime, string $caseMode = 'positive'): ?string {
    $status = $response['status'];
    if ($maxResponseTime !== null && ($response['duration'] ?? 0.0) > $maxResponseTime) {
        return sprintf('response time %.6fs exceeded %.6fs', $response['duration'], $maxResponseTime);
    }

    if ($caseMode === 'negative' && in_array('negative_data_rejection', $checks, true) && ($status < 400 || $status >= 500)) {
        return "negative input was not rejected with a 4xx response; got HTTP {$status}";
    }
    if ($caseMode === 'positive' && in_array('positive_data_acceptance', $checks, true) && $status >= 400 && $status < 500) {
        return "positive input was rejected with HTTP {$status}";
    }

    if (in_array('not_a_server_error', $checks, true) && $status >= 500) {
        return "server error HTTP {$status}";
    }

    $responses = $op['operation']['responses'] ?? [];
    $documented = documentedResponseForStatus($responses, $status);
    if (in_array('status_code_conformance', $checks, true) && $documented === null) {
        return "undocumented HTTP {$status}";
    }

    if (!$documented) return null;

    if (in_array('response_headers_conformance', $checks, true)) {
        $headerFailure = validateResponseHeaders($documented['headers'] ?? [], $response['headers'], $components);
        if ($headerFailure !== null) return $headerFailure;
    }

    $json = $documented['content']['application/json'] ?? null;
    if (!$json) return null;

    $contentType = strtolower($response['headers']['content-type'] ?? '');
    if (in_array('content_type_conformance', $checks, true) && !str_contains($contentType, 'application/json')) {
        return "undocumented Content-Type '{$contentType}'";
    }

    $decoded = json_decode($response['body'], true);
    if (!is_array($decoded)) return 'invalid JSON response body';

    if (in_array('response_schema_conformance', $checks, true)) {
        $errors = validateSchema($decoded, $json['schema'] ?? [], $components);
        if ($errors) return 'response schema mismatch: ' . $errors[0];
    }
    return null;
}

function documentedResponseForStatus(array $responses, int $status): ?array {
    $statusKey = (string)$status;
    $wildcard = substr($statusKey, 0, 1) . 'XX';
    foreach ([$statusKey, $wildcard, strtolower($wildcard), 'default'] as $key) {
        if (isset($responses[$key]) && is_array($responses[$key])) return $responses[$key];
    }
    return null;
}

function validateResponseHeaders(array $documentedHeaders, array $actualHeaders, array $components): ?string {
    foreach ($documentedHeaders as $name => $header) {
        if (!is_array($header)) continue;
        $header = resolveHeaderRef($header, $components);
        $lookup = strtolower((string)$name);
        $present = array_key_exists($lookup, $actualHeaders);

        if (($header['required'] ?? false) && !$present) {
            return "missing required response header '{$name}'";
        }
        if (!$present || !isset($header['schema']) || !is_array($header['schema'])) {
            continue;
        }

        $schema = resolveSchemaRef($header['schema'], $components);
        $value = coerceHeaderValue($actualHeaders[$lookup], $schema, $components);
        $errors = validateSchema($value, $schema, $components, '$headers.' . $name);
        if ($errors) {
            return "response header '{$name}' schema mismatch: {$errors[0]}";
        }
    }
    return null;
}

function resolveHeaderRef(array $header, array $components): array {
    if (!isset($header['$ref'])) return $header;
    $prefix = '#/components/headers/';
    $ref = (string)$header['$ref'];
    if (!str_starts_with($ref, $prefix)) return $header;
    $name = substr($ref, strlen($prefix));
    return $components['headers'][$name] ?? $header;
}

function coerceHeaderValue(string $value, array $schema, array $components) {
    $schema = resolveSchemaRef($schema, $components);
    $type = $schema['type'] ?? null;
    if (is_array($type)) {
        foreach ($type as $candidate) {
            if ($candidate === 'null' && strtolower($value) === 'null') return null;
            $candidateSchema = $schema;
            $candidateSchema['type'] = $candidate;
            $coerced = coerceHeaderValue($value, $candidateSchema, $components);
            if (!validateSchema($coerced, $candidateSchema, $components)) return $coerced;
        }
        return $value;
    }

    return match ($type) {
        'array' => coerceHeaderArray($value, $schema, $components),
        'integer' => preg_match('/^-?\d+$/', $value) ? (int)$value : $value,
        'number' => is_numeric($value) ? (float)$value : $value,
        'boolean' => coerceHeaderBoolean($value),
        default => $value
    };
}

function coerceHeaderArray(string $value, array $schema, array $components): array {
    $itemSchema = $schema['items'] ?? ['type' => 'string'];
    return array_map(
        fn(string $item) => coerceHeaderValue(trim($item), $itemSchema, $components),
        $value === '' ? [] : explode(',', $value)
    );
}

function coerceHeaderBoolean(string $value) {
    return match (strtolower($value)) {
        'true', '1' => true,
        'false', '0' => false,
        default => $value
    };
}

function buildRequestRecord(string $phase, array $op, string $method, string $url, string $pathQuery, array $headers, ?string $body, string $mode = 'positive'): array {
    return [
        'phase' => $phase,
        'mode' => $mode,
        'operation' => $op,
        'method' => $method,
        'url' => $url,
        'path_query' => $pathQuery,
        'headers' => $headers,
        'body' => $body
    ];
}

function recordCase(array &$state, array $request, ?array $response, ?string $failure): array {
    $id = caseId($request, $response, $failure, count($state['case_records'] ?? []));
    $case = [
        'id' => $id,
        'time' => gmdate('c'),
        'schema_location' => $state['schema_location'] ?? null,
        'base_url' => $state['base_url'] ?? null,
        'checks' => $state['checks'] ?? [],
        'max_response_time' => $state['max_response_time'] ?? null,
        'components' => $state['components'] ?? [],
        'request' => $request,
        'response' => normalizeResponseForRecord($response),
        'failure' => $failure
    ];
    $state['case_records'][] = $case;
    return $case;
}

function caseId(array $request, ?array $response, ?string $failure, int $index): string {
    return substr(hash('sha256', json_encode([
        $request['method'] ?? '',
        $request['url'] ?? '',
        $request['body'] ?? '',
        $response['status'] ?? null,
        $failure,
        microtime(true),
        $index,
        random_int(1, PHP_INT_MAX)
    ])), 0, 12);
}

function normalizeResponseForRecord(?array $response): ?array {
    if ($response === null) return null;
    return [
        'status' => $response['status'] ?? 0,
        'headers' => $response['headers'] ?? [],
        'body' => $response['body'] ?? '',
        'duration' => $response['duration'] ?? 0.0
    ];
}

function recordFailure(array &$state, array &$result, string $message, ?array $case = null): void {
    $result['failed']++;
    $state['failures'][] = $case ? "{$message} (case {$case['id']})" : $message;
    if ($case !== null) saveCrashFile($state, $case);
}

function saveCrashFile(array $state, array $case): void {
    $dir = rtrim((string)($state['cache_dir'] ?? DEFAULT_CACHE_DIR), DIRECTORY_SEPARATOR) . DIRECTORY_SEPARATOR . 'crashes';
    if (!is_dir($dir) && !mkdir($dir, 0777, true) && !is_dir($dir)) return;
    $path = $dir . DIRECTORY_SEPARATOR . $case['id'] . '.json';
    $crash = [
        'id' => $case['id'],
        'created_at' => $case['time'],
        'schema_location' => $case['schema_location'],
        'base_url' => $case['base_url'],
        'checks' => $case['checks'],
        'max_response_time' => $case['max_response_time'],
        'components' => $case['components'],
        'operation' => $case['request']['operation']['operation'] ?? null,
        'operation_path' => $case['request']['operation']['path'] ?? null,
        'request' => $case['request'],
        'failure' => $case['failure']
    ];
    file_put_contents($path, json_encode($crash, JSON_PRETTY_PRINT | JSON_UNESCAPED_SLASHES));
}

function failureLimitReached(array $state): bool {
    return $state['max_failures'] !== null && count($state['failures']) >= $state['max_failures'];
}

function concretePath(string $path, array $operation, bool $useExamples): string {
    return preg_replace_callback('/\{([^}]+)\}/', function(array $match) use ($operation, $useExamples) {
        $name = $match[1];
        foreach (operationParameters($operation) as $parameter) {
            if (($parameter['in'] ?? '') === 'path' && ($parameter['name'] ?? '') === $name) {
                if ($useExamples && array_key_exists('example', $parameter)) return rawurlencode((string)$parameter['example']);
                return rawurlencode((string)generateValue($parameter['schema'] ?? ['type' => 'integer'], []));
            }
        }
        return '1';
    }, $path);
}

function queryString(array $operation, array $components, bool $useExamples, string $caseMode = 'positive'): string {
    $query = [];
    foreach (operationParameters($operation) as $parameter) {
        if (($parameter['in'] ?? '') !== 'query') continue;
        $required = (bool)($parameter['required'] ?? false);
        if (!$required && !$useExamples && mt_rand(0, 1) === 0) continue;
        if ($useExamples && array_key_exists('example', $parameter)) {
            $query[$parameter['name']] = $parameter['example'];
        } elseif ($required || !$useExamples) {
            $query[$parameter['name']] = $caseMode === 'negative'
                ? generateInvalidValue($parameter['schema'] ?? ['type' => 'string'], $components)
                : generateValue($parameter['schema'] ?? ['type' => 'string'], $components);
        }
    }
    return $query ? '?' . http_build_query($query) : '';
}

function operationParameterHeaders(array $operation, array $components, bool $useExamples, string $caseMode): array {
    $headers = [];
    $cookies = [];
    foreach (operationParameters($operation) as $parameter) {
        $location = $parameter['in'] ?? '';
        if ($location !== 'header' && $location !== 'cookie') continue;
        $required = (bool)($parameter['required'] ?? false);
        if (!$required && !$useExamples && mt_rand(0, 1) === 0) continue;
        $value = parameterValue($parameter, $components, $useExamples, $caseMode);
        if ($location === 'header') {
            $headers[] = $parameter['name'] . ': ' . serializeParameterValue($value);
        } else {
            $cookies[] = rawurlencode((string)$parameter['name']) . '=' . rawurlencode(serializeParameterValue($value));
        }
    }
    if ($cookies) $headers[] = 'Cookie: ' . implode('; ', $cookies);
    return $headers;
}

function operationParameters(array $operation): array {
    return array_values(array_filter($operation['parameters'] ?? [], 'is_array'));
}

function parameterValue(array $parameter, array $components, bool $useExamples, string $caseMode) {
    if ($useExamples && array_key_exists('example', $parameter)) return $parameter['example'];
    $schema = $parameter['schema'] ?? ['type' => 'string'];
    return $caseMode === 'negative' ? generateInvalidValue($schema, $components) : generateValue($schema, $components);
}

function serializeParameterValue($value): string {
    if (is_array($value)) {
        if (isAssocArray($value)) return implode(',', array_map(fn($key, $item) => $key . ',' . $item, array_keys($value), $value));
        return implode(',', array_map('strval', $value));
    }
    if (is_bool($value)) return $value ? 'true' : 'false';
    return (string)$value;
}

function allowedMethodsForPathItem(array $pathItem): array {
    $methods = [];
    foreach (HTTP_OPERATION_METHODS as $method) {
        if (isset($pathItem[$method])) $methods[] = strtoupper($method);
    }
    return $methods;
}

function resolveSchemaRef(array $schema, array $components): array {
    if (!isset($schema['$ref'])) return $schema;
    $prefix = '#/components/schemas/';
    $ref = (string)$schema['$ref'];
    if (!str_starts_with($ref, $prefix)) return $schema;
    $name = substr($ref, strlen($prefix));
    return $components['schemas'][$name] ?? $schema;
}

function generateValue(array $schema, array $components) {
    $schema = resolveSchemaRef($schema, $components);
    if (($schema['nullable'] ?? false) && mt_rand(0, 5) === 0) return null;
    if (isset($schema['enum']) && is_array($schema['enum']) && $schema['enum']) {
        return $schema['enum'][array_rand($schema['enum'])];
    }
    if (isset($schema['oneOf'][0])) return generateValue($schema['oneOf'][array_rand($schema['oneOf'])], $components);
    if (isset($schema['allOf'][0])) return generateValue($schema['allOf'][0], $components);

    $type = $schema['type'] ?? 'string';
    if (is_array($type)) $type = $type[array_rand($type)];
    return match ($type) {
        'object' => generateObject($schema, $components),
        'array' => generateArrayValue($schema, $components),
        'integer' => generateInteger($schema),
        'number' => generateInteger($schema) + (mt_rand(0, 99) / 100),
        'boolean' => (bool)mt_rand(0, 1),
        default => generateString($schema)
    };
}

function generateInvalidValue(array $schema, array $components) {
    $schema = resolveSchemaRef($schema, $components);
    if (isset($schema['enum']) && is_array($schema['enum'])) return '__invalid_enum_' . mt_rand(1, 100000);
    if (isset($schema['oneOf'][0])) return generateInvalidValue($schema['oneOf'][0], $components);
    if (isset($schema['allOf'][0])) return generateInvalidValue($schema['allOf'][0], $components);

    $type = $schema['type'] ?? 'string';
    if (is_array($type)) $type = $type[0] ?? 'string';
    return match ($type) {
        'object' => generateInvalidObject($schema, $components),
        'array' => 'not-an-array',
        'integer' => 'not-an-integer',
        'number' => 'not-a-number',
        'boolean' => 'not-a-boolean',
        'string' => generateInvalidString($schema),
        default => null
    };
}

function generateInvalidObject(array $schema, array $components): array {
    $properties = $schema['properties'] ?? [];
    $required = $schema['required'] ?? [];
    $value = [];
    foreach ($properties as $name => $propertySchema) {
        if (in_array($name, $required, true) && mt_rand(0, 1) === 0) continue;
        $value[$name] = mt_rand(0, 2) === 0 ? generateInvalidValue($propertySchema, $components) : generateValue($propertySchema, $components);
    }
    if (($schema['additionalProperties'] ?? null) === false) {
        $value['__unexpected_' . mt_rand(1, 1000)] = true;
    }
    if (!$value && $properties) {
        $firstName = array_key_first($properties);
        $value[$firstName] = generateInvalidValue($properties[$firstName], $components);
    }
    return $value;
}

function generateInvalidString(array $schema) {
    if (isset($schema['maxLength'])) return str_repeat('x', max(1, (int)$schema['maxLength'] + 1));
    if (isset($schema['minLength']) && (int)$schema['minLength'] > 0) return '';
    if (($schema['format'] ?? '') === 'uri') return 'not a uri';
    return 12345;
}

function generateObject(array $schema, array $components): array {
    $value = [];
    $required = $schema['required'] ?? [];
    foreach (($schema['properties'] ?? []) as $name => $propertySchema) {
        if (in_array($name, $required, true) || mt_rand(0, 1) === 1) {
            $value[$name] = generateValue($propertySchema, $components);
        }
    }
    return $value;
}

function generateArrayValue(array $schema, array $components): array {
    $count = mt_rand(0, 2);
    $items = [];
    for ($i = 0; $i < $count; $i++) $items[] = generateValue($schema['items'] ?? ['type' => 'string'], $components);
    return $items;
}

function generateInteger(array $schema): int {
    $min = isset($schema['minimum']) ? (int)$schema['minimum'] : 0;
    $max = isset($schema['maximum']) ? (int)$schema['maximum'] : $min + 100;
    if ($max < $min) $max = $min;
    return mt_rand($min, $max);
}

function generateString(array $schema): string {
    if (($schema['format'] ?? '') === 'uri') return 'https://example.com/' . mt_rand(1, 100000);
    $max = min(32, max(1, (int)($schema['maxLength'] ?? 12)));
    $min = min($max, max(1, (int)($schema['minLength'] ?? 1)));
    $length = mt_rand($min, $max);
    $alphabet = 'abcdefghijklmnopqrstuvwxyz0123456789-_';
    $value = '';
    for ($i = 0; $i < $length; $i++) $value .= $alphabet[mt_rand(0, strlen($alphabet) - 1)];
    return $value;
}

function isAssocArray($value): bool {
    return is_array($value) && array_keys($value) !== range(0, count($value) - 1);
}

function validateSchema($value, array $schema, array $components, string $path = '$'): array {
    $schema = resolveSchemaRef($schema, $components);
    if (($schema['nullable'] ?? false) && $value === null) return [];
    if (isset($schema['allOf']) && is_array($schema['allOf'])) {
        foreach ($schema['allOf'] as $part) {
            $errors = validateSchema($value, $part, $components, $path);
            if ($errors) return $errors;
        }
        return [];
    }
    if (isset($schema['oneOf']) && is_array($schema['oneOf'])) {
        foreach ($schema['oneOf'] as $part) {
            if (!validateSchema($value, $part, $components, $path)) return [];
        }
        return ["{$path} did not match any oneOf schema"];
    }
    if (array_key_exists('enum', $schema) && !in_array($value, $schema['enum'], true)) return ["{$path} is not in enum"];

    $type = $schema['type'] ?? null;
    if ($type === null) return [];
    if (is_array($type)) {
        foreach ($type as $candidate) {
            $candidateSchema = $schema;
            $candidateSchema['type'] = $candidate;
            if (!validateSchema($value, $candidateSchema, $components, $path)) return [];
        }
        return ["{$path} did not match any type"];
    }

    return match ($type) {
        'object' => validateObjectSchema($value, $schema, $components, $path),
        'array' => validateArraySchema($value, $schema, $components, $path),
        'integer' => is_int($value) ? [] : ["{$path} is not an integer"],
        'number' => (is_int($value) || is_float($value)) ? [] : ["{$path} is not a number"],
        'string' => is_string($value) ? [] : ["{$path} is not a string"],
        'boolean' => is_bool($value) ? [] : ["{$path} is not a boolean"],
        default => []
    };
}

function validateObjectSchema($value, array $schema, array $components, string $path): array {
    if (!isAssocArray($value)) return ["{$path} is not an object"];
    foreach (($schema['required'] ?? []) as $required) {
        if (!array_key_exists($required, $value)) return ["{$path}.{$required} is required"];
    }
    foreach (($schema['properties'] ?? []) as $name => $propertySchema) {
        if (array_key_exists($name, $value)) {
            $errors = validateSchema($value[$name], $propertySchema, $components, "{$path}.{$name}");
            if ($errors) return $errors;
        }
    }
    if (($schema['additionalProperties'] ?? null) === false) {
        $known = array_keys($schema['properties'] ?? []);
        foreach (array_keys($value) as $name) {
            if (!in_array($name, $known, true)) return ["{$path}.{$name} is not documented"];
        }
    }
    return [];
}

function validateArraySchema($value, array $schema, array $components, string $path): array {
    if (!is_array($value) || isAssocArray($value)) return ["{$path} is not an array"];
    foreach ($value as $index => $item) {
        $errors = validateSchema($item, $schema['items'] ?? [], $components, "{$path}[{$index}]");
        if ($errors) return $errors;
    }
    return [];
}

function printPhaseResult(string $phase, array $result): void {
    $icon = $result['failed'] > 0 ? 'FAIL' : 'OK';
    $label = ucfirst($phase);
    printf(" %s  %s (in %.2fs)\n", $icon, $label, $result['duration']);
    echo "     {$result['passed']} passed";
    if ($result['failed']) echo "  {$result['failed']} failed";
    if ($result['skipped']) echo "  {$result['skipped']} skipped";
    echo "\n\n";
}

function printFailures(array $state): void {
    if (!$state['failures']) return;
    echo "=================================== FAILURES ===================================\n";
    foreach ($state['failures'] as $index => $failure) {
        $number = $index + 1;
        echo "{$number}. {$failure}\n";
    }
    echo "\n";
}

function printWarnings(array $state): void {
    if (!$state['warnings']) return;
    echo "=================================== WARNINGS ===================================\n";
    foreach ($state['warnings'] as $warning) echo "- {$warning}\n";
    echo "\n";
}

function printSummary(array $operations, array $phaseResults, array $state): void {
    $failed = count($state['failures']);
    $passed = array_sum(array_column($phaseResults, 'passed'));
    $skipped = array_sum(array_column($phaseResults, 'skipped'));
    echo "=================================== SUMMARY ====================================\n";
    echo "API Operations:\n";
    echo "  Selected: " . count($operations) . '/' . ($state['total_operations'] ?? count($operations)) . "\n";
    echo "  Tested cases: {$state['cases']}\n\n";
    echo "Test Phases:\n";
    foreach ($phaseResults as $phase => $result) {
        echo '  ' . ($result['failed'] ? 'FAIL' : 'OK') . ' ' . ucfirst($phase) . "\n";
    }
    echo "\n";
    echo "Test cases:\n";
    echo "  {$passed} passed";
    if ($failed) echo ", {$failed} failed";
    if ($skipped) echo ", {$skipped} skipped";
    echo "\n";
    echo "Seed: {$state['seed']}\n";
}

function writeReports(array $state, array $phaseResults): void {
    $report = $state['report'] ?? ['formats' => []];
    foreach (($report['formats'] ?? []) as $format) {
        $path = (string)($report['paths'][$format] ?? '');
        if ($path === '') continue;
        $dir = dirname($path);
        if (!is_dir($dir) && !mkdir($dir, 0777, true) && !is_dir($dir)) {
            fwrite(STDERR, "Could not create report directory: {$dir}\n");
            continue;
        }
        $content = match ($format) {
            'junit' => junitReport($state, $phaseResults),
            'har' => harReport($state),
            'ndjson' => ndjsonReport($state, $phaseResults),
            'vcr' => vcrReport($state),
            default => null
        };
        if ($content !== null) {
            file_put_contents($path, $content);
            echo "Report written: {$path}\n";
        }
    }
}

function junitReport(array $state, array $phaseResults): string {
    $cases = $state['case_records'] ?? [];
    $failures = array_values(array_filter($cases, fn(array $case) => $case['failure'] !== null));
    $time = array_sum(array_map(fn(array $case) => (float)($case['response']['duration'] ?? 0.0), $cases));
    $xml = [];
    $xml[] = '<?xml version="1.0" encoding="UTF-8"?>';
    $xml[] = sprintf(
        '<testsuite name="openapi-contract-php" tests="%d" failures="%d" errors="0" skipped="0" time="%.6f">',
        count($cases),
        count($failures),
        $time
    );
    foreach ($cases as $case) {
        $name = trim(($case['request']['method'] ?? '') . ' ' . (($case['request']['operation']['path'] ?? $case['request']['path_query'] ?? '')));
        $xml[] = sprintf(
            '  <testcase classname="%s" name="%s" time="%.6f">',
            xmlEscape((string)($case['request']['phase'] ?? 'case')),
            xmlEscape($name),
            (float)($case['response']['duration'] ?? 0.0)
        );
        if ($case['failure'] !== null) {
            $xml[] = sprintf('    <failure message="%s">%s</failure>', xmlEscape($case['failure']), xmlEscape(json_encode($case, JSON_PRETTY_PRINT | JSON_UNESCAPED_SLASHES)));
        }
        $xml[] = '  </testcase>';
    }
    $xml[] = '</testsuite>';
    return implode("\n", $xml) . "\n";
}

function harReport(array $state): string {
    $entries = [];
    foreach (($state['case_records'] ?? []) as $case) {
        $request = $case['request'];
        $response = $case['response'] ?? [];
        $entries[] = [
            'startedDateTime' => $case['time'],
            'time' => round((float)($response['duration'] ?? 0.0) * 1000, 3),
            'request' => [
                'method' => $request['method'],
                'url' => $request['url'],
                'httpVersion' => 'HTTP/1.1',
                'headers' => headerLinesToHar($request['headers'] ?? []),
                'queryString' => queryStringToHar((string)parse_url($request['url'], PHP_URL_QUERY)),
                'cookies' => [],
                'headersSize' => -1,
                'bodySize' => $request['body'] === null ? 0 : strlen((string)$request['body']),
                'postData' => $request['body'] === null ? null : ['mimeType' => 'application/json', 'text' => $request['body']]
            ],
            'response' => [
                'status' => (int)($response['status'] ?? 0),
                'statusText' => '',
                'httpVersion' => 'HTTP/1.1',
                'headers' => assocHeadersToHar($response['headers'] ?? []),
                'cookies' => [],
                'content' => [
                    'size' => strlen((string)($response['body'] ?? '')),
                    'mimeType' => $response['headers']['content-type'] ?? '',
                    'text' => (string)($response['body'] ?? '')
                ],
                'redirectURL' => '',
                'headersSize' => -1,
                'bodySize' => strlen((string)($response['body'] ?? ''))
            ],
            'cache' => new stdClass(),
            'timings' => ['send' => 0, 'wait' => round((float)($response['duration'] ?? 0.0) * 1000, 3), 'receive' => 0]
        ];
    }
    return json_encode(['log' => ['version' => '1.2', 'creator' => ['name' => 'openapi-contract-php', 'version' => '0.1'], 'entries' => $entries]], JSON_PRETTY_PRINT | JSON_UNESCAPED_SLASHES) . "\n";
}

function ndjsonReport(array $state, array $phaseResults): string {
    $lines = [];
    foreach (($state['case_records'] ?? []) as $case) {
        $lines[] = json_encode(['type' => 'case', 'case' => $case], JSON_UNESCAPED_SLASHES);
    }
    $lines[] = json_encode([
        'type' => 'summary',
        'cases' => $state['cases'],
        'failures' => count($state['failures'] ?? []),
        'phases' => $phaseResults,
        'seed' => $state['seed'] ?? null
    ], JSON_UNESCAPED_SLASHES);
    return implode("\n", $lines) . "\n";
}

function vcrReport(array $state): string {
    $lines = ["interactions:"];
    foreach (($state['case_records'] ?? []) as $case) {
        $request = $case['request'];
        $response = $case['response'] ?? [];
        $lines[] = "  - id: " . yamlScalar($case['id']);
        $lines[] = "    request:";
        $lines[] = "      method: " . yamlScalar($request['method']);
        $lines[] = "      uri: " . yamlScalar($request['url']);
        $lines[] = "      body: " . yamlScalar((string)($request['body'] ?? ''));
        $lines[] = "    response:";
        $lines[] = "      status: " . (int)($response['status'] ?? 0);
        $lines[] = "      body: " . yamlScalar((string)($response['body'] ?? ''));
        if ($case['failure'] !== null) $lines[] = "    failure: " . yamlScalar($case['failure']);
    }
    return implode("\n", $lines) . "\n";
}

function headerLinesToHar(array $headers): array {
    $result = [];
    foreach ($headers as $header) {
        if (!str_contains((string)$header, ':')) continue;
        [$name, $value] = explode(':', (string)$header, 2);
        $result[] = ['name' => trim($name), 'value' => trim($value)];
    }
    return $result;
}

function assocHeadersToHar(array $headers): array {
    $result = [];
    foreach ($headers as $name => $value) $result[] = ['name' => (string)$name, 'value' => (string)$value];
    return $result;
}

function queryStringToHar(string $query): array {
    if ($query === '') return [];
    $result = [];
    parse_str($query, $values);
    foreach ($values as $name => $value) {
        $result[] = ['name' => (string)$name, 'value' => is_array($value) ? json_encode($value) : (string)$value];
    }
    return $result;
}

function xmlEscape(string $value): string {
    return htmlspecialchars($value, ENT_QUOTES | ENT_XML1, 'UTF-8');
}

function yamlScalar(string $value): string {
    return json_encode($value, JSON_UNESCAPED_SLASHES);
}
