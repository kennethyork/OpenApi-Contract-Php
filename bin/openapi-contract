#!/usr/bin/env php
<?php
declare(strict_types=1);

/**
 * PHP-native OpenAPI contract and fuzz testing runner.
 *
 * The CLI is designed for local OpenAPI contract and fuzz testing:
 *
 *   php bin/openapi-contract run LOCATION --phases examples,coverage,fuzzing --max-examples 5
 *
 * It supports core OpenAPI HTTP checks:
 * - not_a_server_error
 * - status_code_conformance
 * - content_type_conformance
 * - response_headers_conformance
 * - response_schema_conformance
 * - unsupported_method
 *
 * Full feature coverage still requires a property-based testing engine,
 * shrinking, link-aware stateful workflows, GraphQL support, and a much larger
 * OpenAPI implementation.
 */

const DEFAULT_CHECKS = [
    'not_a_server_error',
    'status_code_conformance',
    'content_type_conformance',
    'response_headers_conformance',
    'response_schema_conformance',
    'unsupported_method'
];

const KNOWN_CHECKS = [
    'not_a_server_error',
    'status_code_conformance',
    'content_type_conformance',
    'response_headers_conformance',
    'response_schema_conformance',
    'negative_data_rejection',
    'positive_data_acceptance',
    'use_after_free',
    'ensure_resource_availability',
    'ignored_auth',
    'missing_required_header',
    'unsupported_method'
];

const IMPLEMENTED_CHECKS = [
    'not_a_server_error',
    'status_code_conformance',
    'content_type_conformance',
    'response_headers_conformance',
    'response_schema_conformance',
    'negative_data_rejection',
    'positive_data_acceptance',
    'use_after_free',
    'ensure_resource_availability',
    'ignored_auth',
    'missing_required_header',
    'unsupported_method'
];
const HTTP_OPERATION_METHODS = ['get', 'post', 'put', 'patch', 'delete'];
const DEFAULT_CACHE_DIR = '.openapi-contract/cache';
const DEFAULT_REPORT_DIR = 'openapi-contract-report';
const JSON_MEDIA_TYPES = ['application/json', 'application/problem+json', 'application/vnd.api+json'];
const PRO_EXTENSION_PATHS = ['openapi-contract-pro.php', 'pro/openapi-contract-pro.php', '.openapi-contract/pro.php'];

main($argv);

function main(array $argv): void {
    if (!isset($argv[1]) || in_array($argv[1], ['-h', '--help'], true)) {
        printUsage();
        exit(0);
    }

    $parsed = parseCli($argv);
    $command = $parsed['command'] ?? null;
    $proExtension = loadProExtension($parsed['options']);

    if ($command === 'init') {
        exit(runInitCommand($parsed['location'], $parsed['options']));
    }

    if ($command === 'interactive') {
        exit(runInteractiveCommand($parsed['location'], $parsed['options']));
    }

    if ($command === 'benchmark') {
        exit(runBenchmarkCommand($parsed['location'], $parsed['options']));
    }

    if ($command === 'pro') {
        exit(runProCommand($parsed['location'], $parsed['options'], $proExtension));
    }

    $options = mergeConfigOptions($parsed['options']);
    if ($command === 'doctor') {
        exit(runDoctorCommand($parsed['location'], $options));
    }

    if ($command === 'replay') {
        exit(runReplayCommand($parsed['location'], $options));
    }

    exit(runTestCommand((string)$command, $parsed['location'], $options));
}

function runTestCommand(string $command, ?string $providedLocation, array $options): int {
    if (!in_array($command, ['run', 'fuzz'], true)) {
        printUsage();
        return 2;
    }

    $location = schemaLocationFromOptions($providedLocation, $options);
    if ($location === null) {
        fwrite(STDERR, "No OpenAPI schema location provided. Pass LOCATION or set schema-location in config.\n");
        return 2;
    }

    $phases = $command === 'fuzz' ? ['fuzzing'] : csvOption($options, 'phases', ['examples', 'coverage', 'fuzzing']);
    $maxTime = isset($options['max-time']) ? max(1.0, (float)$options['max-time']) : null;
    $maxExamplesDefault = $command === 'fuzz' ? ($maxTime === null ? 100 : PHP_INT_MAX) : 5;
    $maxExamples = max(1, (int)($options['max-examples'] ?? $maxExamplesDefault));
    $maxFailures = isset($options['max-failures']) ? max(1, (int)$options['max-failures']) : null;
    $mode = in_array(($options['mode'] ?? 'positive'), ['positive', 'negative', 'all'], true) ? (string)($options['mode'] ?? 'positive') : 'positive';
    $timeout = isset($options['request-timeout']) ? max(1.0, (float)$options['request-timeout']) : 10.0;
    $headers = headersFromOptions($options);
    $checks = selectedChecks($options);
    $seed = isset($options['seed']) ? (int)$options['seed'] : random_int(1, PHP_INT_MAX);
    $transport = transportOptionsFromOptions($options);
    mt_srand($seed);

    echo "openapi-contract-php v0.1\n";
    echo str_repeat("-", 20) . "\n\n";

    try {
        $schema = loadSchema($location, $timeout, isset($options['wait-for-schema']) ? (float)$options['wait-for-schema'] : 0.0, $transport);
        $baseUrl = baseUrlFromSchema($schema, $options['url'] ?? null);
        $headers = mergeHeaders($headers, authHeadersFromSchema($schema, $options));
    } catch (Throwable $e) {
        echo " FAIL Could not load specification: {$e->getMessage()}\n";
        return 1;
    }

    $warnings = [];
    addCompatibilityWarnings($options, $phases, $checks, $command, $schema, $warnings);
    $allOperations = collectOperations($schema);
    $operations = filterOperations($allOperations, $options, $warnings);
    echo " OK   Loaded specification from {$location}\n\n";
    echo "     Base URL:         {$baseUrl}\n";
    echo "     Specification:    " . specificationLabel($schema) . "\n";
    echo "     Operations:       " . count($operations) . " selected / " . count($allOperations) . " total\n";
    echo "     Seed:             {$seed}\n\n";

    $state = [
        'schema' => $schema,
        'components' => $schema['components'] ?? [],
        'base_url' => $baseUrl,
        'headers' => $headers,
        'checks' => $checks,
        'timeout' => $timeout,
        'transport' => $transport,
        'max_response_time' => isset($options['max-response-time']) ? max(PHP_FLOAT_EPSILON, (float)$options['max-response-time']) : null,
        'mode' => $mode,
        'max_failures' => $maxFailures,
        'failures' => [],
        'warnings' => $warnings,
        'cases' => 0,
        'case_records' => [],
        'failure_reproducers' => [],
        'total_operations' => count($allOperations),
        'seed' => $seed,
        'last_request_at' => null,
        'schema_location' => $location,
        'report' => reportOptionsFromOptions($options),
        'cache_dir' => (string)($options['cache-dir'] ?? DEFAULT_CACHE_DIR),
        'options' => $options,
        'resource_values' => [],
        'stateful_links' => discoverStatefulLinks($schema),
        'output_sanitize' => parseBooleanOption($options['output-sanitize'] ?? true),
        'output_truncate' => parseBooleanOption($options['output-truncate'] ?? true)
    ];

    $phaseResults = [];
    $deadline = $maxTime === null ? null : microtime(true) + $maxTime;
    foreach ($phases as $phase) {
        if (failureLimitReached($state)) break;
        if ($deadline !== null && microtime(true) >= $deadline) break;
        $started = microtime(true);
        $result = match ($phase) {
            'examples' => runExamplesPhase($operations, $state),
            'coverage' => runCoveragePhase($operations, $state),
            'fuzzing' => runFuzzingPhase($operations, $state, $maxExamples, $deadline),
            'stateful' => runStatefulPhase($operations, $state, $maxExamples, $deadline),
            default => ['passed' => 0, 'failed' => 0, 'skipped' => count($operations), 'label' => ucfirst($phase), 'unsupported' => true]
        };
        $result['duration'] = microtime(true) - $started;
        $phaseResults[$phase] = $result;
        printPhaseResult($phase, $result);
    }

    printFailures($state);
    printWarnings($state);
    printSummary($operations, $phaseResults, $state);
    writeReports($state, $phaseResults);
    $summary = runSummary($operations, $phaseResults, $state);
    $GLOBALS['openapi_contract_last_run'] = $summary;
    runProAfterRunHook($state, $phaseResults, $summary);
    return $state['failures'] ? 1 : 0;
}

function printUsage(): void {
    echo "Usage:\n";
    echo "  php bin/openapi-contract init [OPTIONS] [LOCATION]\n";
    echo "  php bin/openapi-contract interactive [OPTIONS] [LOCATION]\n";
    echo "  php bin/openapi-contract benchmark [OPTIONS] [SUITE]\n";
    echo "  php bin/openapi-contract doctor [OPTIONS] [LOCATION]\n";
    echo "  php bin/openapi-contract run [OPTIONS] [LOCATION]\n";
    echo "  php bin/openapi-contract fuzz [OPTIONS] [LOCATION]\n";
    echo "  php bin/openapi-contract pro [OPTIONS] [ACTION]\n";
    echo "  php bin/openapi-contract replay [OPTIONS] [PATH|CASE_ID]\n\n";
    echo "Options:\n";
    echo "  --config FILE                  Load JSON config defaults, or init target file\n";
    echo "  --schema-location LOCATION     OpenAPI schema location for config-backed runs\n";
    echo "  -u, --url URL                  API base URL for file-based schemas\n";
    echo "  -w, --workers N|auto           Worker count (currently sequential)\n";
    echo "  -H, --header NAME:VALUE        Add a custom HTTP header\n";
    echo "  -a, --auth USER:PASS           Basic authentication\n";
    echo "  --auth-token TOKEN             Bearer token for HTTP auth schemes\n";
    echo "  --auth-api-key NAME:VALUE      API key value for a named security scheme\n";
    echo "  --phases LIST                  examples,coverage,fuzzing,stateful\n";
    echo "  --checks LIST                  Checks to run, or all\n";
    echo "  --exclude-checks LIST          Checks to skip\n";
    echo "  --max-response-time SECONDS    Fail responses slower than this limit\n";
    echo "  --include-TYPE VALUE           TYPE: path, method, name, tag, operation-id\n";
    echo "  --exclude-TYPE VALUE           TYPE: path, method, name, tag, operation-id\n";
    echo "  --include-TYPE-regex PATTERN   Regex include filter\n";
    echo "  --exclude-TYPE-regex PATTERN   Regex exclude filter\n";
    echo "  --exclude-deprecated           Skip deprecated operations\n";
    echo "  -n, --max-examples N           Fuzz examples per operation\n";
    echo "  --max-failures N               Stop after N failures\n";
    echo "  --max-time SECONDS             Stop fuzz command after this duration\n";
    echo "  --request-timeout SECONDS      Per-request timeout\n";
    echo "  --request-retries N            Retry network failures\n";
    echo "  --max-redirects N              Follow up to N redirects\n";
    echo "  --proxy URL                    HTTP proxy URL\n";
    echo "  --tls-verify true|false|PATH   TLS verification setting\n";
    echo "  --report FORMAT                junit,har,ndjson,vcr,html,curl\n";
    echo "  --report-dir DIRECTORY         Directory for generated reports\n";
    echo "  --report-junit-path FILE       JUnit XML output path\n";
    echo "  --report-har-path FILE         HAR output path\n";
    echo "  --report-ndjson-path FILE      NDJSON events output path\n";
    echo "  --report-vcr-path FILE         Request/response cassette path\n";
    echo "  --report-html-path FILE        Self-contained HTML report path\n";
    echo "  --report-curl-path FILE        Shell reproducers for failing cases\n";
    echo "  --cache-dir DIRECTORY          Crash/replay cache directory\n";
    echo "  --base-url URL                 Benchmark suite base URL placeholder\n";
    echo "  --benchmark-output FILE        Benchmark JSON result path\n";
    echo "  --benchmark-markdown FILE      Benchmark Markdown summary path\n";
    echo "  --benchmark-baseline FILE      Compare benchmark result to a prior JSON result\n";
    echo "  --pro-path FILE                Load an advanced feature extension file\n";
    echo "  --pro-output-dir DIRECTORY     Advanced report output directory\n";
    echo "  --pro-project NAME             Project/baseline name for advanced reports\n";
    echo "  --pro-customer NAME            Customer/audit label for advanced reports\n";
    echo "  --pro-rules LIST               Advanced rule packs to apply\n";
    echo "  --fail-on-regression           Exit non-zero on unexpected benchmark failures\n";
    echo "  --seed N                       Reproducible random seed\n";
    echo "  --no-interaction               Write init defaults without prompting\n";
    echo "  --force                        Allow init to overwrite an existing config\n";
    echo "  --no-color                     Accepted for CLI compatibility\n";
}

function loadProExtension(array $options): ?callable {
    foreach (proExtensionPaths($options) as $path) {
        if (!is_file($path)) continue;
        require_once $path;
        if (function_exists('openapi_contract_pro_command')) {
            return 'openapi_contract_pro_command';
        }
        fwrite(STDERR, "Advanced extension loaded from {$path}, but openapi_contract_pro_command was not found.\n");
        return null;
    }
    return null;
}

function proExtensionPaths(array $options): array {
    $paths = optionValues($options, 'pro-path');
    if (!$paths) $paths = PRO_EXTENSION_PATHS;
    return array_values(array_unique(array_filter(array_map('strval', $paths), fn(string $path): bool => trim($path) !== '')));
}

function runProCommand(?string $action, array $options, ?callable $extension): int {
    $action = $action === null || trim($action) === '' ? 'status' : trim($action);
    if ($extension !== null) {
        return (int)$extension($action, $options);
    }

    echo "openapi-contract-php advanced features\n";
    echo str_repeat("-", 38) . "\n\n";
    echo "No advanced extension is installed.\n\n";
    echo "The bundled open-source extension is expected at one of these paths:\n";
    foreach (PRO_EXTENSION_PATHS as $path) echo "  - {$path}\n";
    echo "\nOr pass an explicit extension file:\n";
    echo "  php bin/openapi-contract pro --pro-path path/to/openapi-contract-pro.php status\n\n";
    echo "The extension file should define:\n";
    echo "  openapi_contract_pro_command(string \$action, array \$options): int\n";
    echo "\nAdvanced features can also hook into the same run and benchmark commands:\n";
    echo "  openapi_contract_pro_after_run(array \$state, array \$phaseResults, array \$summary): void\n";
    echo "  openapi_contract_pro_after_benchmark(array \$report, array \$options): void\n";
    echo "\nBundled additions include HTML/PDF audit reports, team baselines, rule packs,\n";
    echo "framework presets, and PHAR builds.\n";
    return 2;
}

function runProAfterRunHook(array $state, array $phaseResults, array $summary): void {
    if (!function_exists('openapi_contract_pro_after_run')) return;
    try {
        openapi_contract_pro_after_run($state, $phaseResults, $summary);
    } catch (Throwable $e) {
        fwrite(STDERR, "Advanced after-run hook failed: {$e->getMessage()}\n");
    }
}

function runProAfterBenchmarkHook(array $report, array $options): void {
    if (!function_exists('openapi_contract_pro_after_benchmark')) return;
    try {
        openapi_contract_pro_after_benchmark($report, $options);
    } catch (Throwable $e) {
        fwrite(STDERR, "Advanced after-benchmark hook failed: {$e->getMessage()}\n");
    }
}

function runInitCommand(?string $target, array $options): int {
    $interactive = !truthyOption($options['no-interaction'] ?? false);
    $configPath = optionString($options, 'config', 'openapi-contract.json');
    $schemaLocation = optionString($options, 'schema-location', $target ?? 'openapi.json');
    $baseUrl = optionString($options, 'url', guessBaseUrl($schemaLocation));
    $phases = optionString($options, 'phases', 'examples,coverage,fuzzing');
    $checks = optionString($options, 'checks', '');
    $maxExamples = optionString($options, 'max-examples', '25');
    $requestTimeout = optionString($options, 'request-timeout', '10');
    $requestRetries = optionString($options, 'request-retries', '0');
    $maxRedirects = optionString($options, 'max-redirects', '0');
    $auth = optionString($options, 'auth', '');
    $headers = optionValues($options, 'header');
    $reports = csvOption($options, 'report', ['ndjson', 'junit', 'html', 'curl']);
    $reportDir = optionString($options, 'report-dir', DEFAULT_REPORT_DIR);
    $cacheDir = optionString($options, 'cache-dir', DEFAULT_CACHE_DIR);

    if ($interactive) {
        echo "openapi-contract-php init\n";
        echo str_repeat("-", 25) . "\n\n";
        if (!truthyOption($options['fixed-config'] ?? false)) {
            $configPath = promptText('Config file', $configPath);
        }
        $schemaLocation = promptText('OpenAPI schema location', $schemaLocation);
        $guessedUrl = $baseUrl !== '' ? $baseUrl : guessBaseUrl($schemaLocation);
        $baseUrl = promptText('API base URL', $guessedUrl);
        $phases = promptText('Phases', $phases);
        $checks = promptText('Checks, empty for default', $checks);
        $maxExamples = promptText('Max fuzz examples per operation', $maxExamples);
        $requestTimeout = promptText('Request timeout seconds', $requestTimeout);
        $requestRetries = promptText('Request retries', $requestRetries);
        $maxRedirects = promptText('Max redirects', $maxRedirects);
        $auth = promptText('Basic auth USER:PASS, empty for none', $auth);
        $headerText = promptText('Extra headers, comma-separated NAME: VALUE', implode(', ', $headers));
        $headers = parseHeaderInput($headerText);
        $reportText = promptText('Reports, comma-separated or none', implode(',', $reports));
        $reports = csvList($reportText);
        $reportDir = promptText('Report directory', $reportDir);
        $cacheDir = promptText('Crash/replay cache directory', $cacheDir);
    }

    if (trim($schemaLocation) === '') {
        fwrite(STDERR, "Schema location is required.\n");
        return 2;
    }

    if (is_file($configPath) && !truthyOption($options['force'] ?? false)) {
        if (!$interactive || !promptYesNo("Overwrite existing {$configPath}?", false)) {
            fwrite(STDERR, "Config file already exists: {$configPath}\n");
            return 2;
        }
    }

    $config = [
        'schema-location' => $schemaLocation,
        'phases' => $phases,
        'max-examples' => max(1, (int)$maxExamples),
        'request-timeout' => max(1.0, (float)$requestTimeout),
        'request-retries' => max(0, (int)$requestRetries),
        'max-redirects' => max(0, (int)$maxRedirects),
        'cache-dir' => $cacheDir
    ];

    if (trim($baseUrl) !== '') $config['url'] = trim($baseUrl);
    if (trim($checks) !== '') $config['checks'] = trim($checks);
    if ($headers) $config['headers'] = array_values($headers);
    if (trim($auth) !== '') {
        [$username, $password] = array_pad(explode(':', $auth, 2), 2, '');
        $config['auth'] = ['basic' => ['username' => $username, 'password' => $password]];
    }
    $reports = array_values(array_intersect($reports, ['junit', 'har', 'ndjson', 'vcr', 'html', 'curl']));
    if ($reports) {
        $config['reports'] = ['directory' => $reportDir];
        foreach ($reports as $format) {
            $config['reports'][$format] = ['enabled' => true];
        }
    }

    $dir = dirname($configPath);
    if ($dir !== '.' && !is_dir($dir) && !mkdir($dir, 0777, true) && !is_dir($dir)) {
        fwrite(STDERR, "Could not create config directory: {$dir}\n");
        return 1;
    }

    $json = json_encode($config, JSON_PRETTY_PRINT | JSON_UNESCAPED_SLASHES);
    if ($json === false || file_put_contents($configPath, $json . "\n") === false) {
        fwrite(STDERR, "Could not write config file: {$configPath}\n");
        return 1;
    }

    echo "Wrote {$configPath}\n";
    echo "Run: php bin/openapi-contract doctor --config {$configPath}\n";
    echo "Run: php bin/openapi-contract run --config {$configPath}\n";
    return 0;
}

function runInteractiveCommand(?string $target, array $options): int {
    echo "openapi-contract-php interactive\n";
    echo str_repeat("-", 32) . "\n\n";

    $configPath = optionString($options, 'config', defaultConfigPath());
    $configPath = promptText('Config file', $configPath);
    $options['config'] = $configPath;

    if (!is_file($configPath)) {
        echo "\nNo config file found at {$configPath}.\n";
        if (promptYesNo('Create it now?', true)) {
            $initOptions = $options;
            $initOptions['fixed-config'] = true;
            $initCode = runInitCommand($target, $initOptions);
            if ($initCode !== 0) return $initCode;
        } else {
            unset($options['config']);
        }
    } elseif (promptYesNo('Update config now?', false)) {
        $initOptions = $options;
        $initOptions['fixed-config'] = true;
        $initCode = runInitCommand($target, $initOptions);
        if ($initCode !== 0) return $initCode;
    }

    $lastExitCode = 0;
    while (true) {
        echo "\nActions:\n";
        echo "  1. Doctor\n";
        echo "  2. Run\n";
        echo "  3. Fuzz\n";
        echo "  4. Replay\n";
        echo "  5. Init\n";
        echo "  6. Quit\n";
        $choice = strtolower(promptText('Choose action', '2'));

        if (in_array($choice, ['6', 'q', 'quit', 'exit'], true)) {
            return $lastExitCode;
        }

        try {
            $mergedOptions = mergeConfigOptions($options);
        } catch (Throwable $e) {
            fwrite(STDERR, "Could not load config: {$e->getMessage()}\n");
            return 2;
        }

        switch ($choice) {
            case '1':
            case 'doctor':
                $doctorLocation = schemaLocationFromOptions($target, $mergedOptions);
                $doctorLocation = promptText('OpenAPI schema location', $doctorLocation ?? '');
                $lastExitCode = runDoctorCommand($doctorLocation, promptUrlOption($mergedOptions, $doctorLocation));
                break;

            case '2':
            case 'run':
                $runLocation = schemaLocationFromOptions($target, $mergedOptions);
                $runOptions = promptRunOptions($mergedOptions, 'run', $runLocation);
                $lastExitCode = runTestCommand('run', $runLocation, $runOptions);
                break;

            case '3':
            case 'fuzz':
                $fuzzLocation = schemaLocationFromOptions($target, $mergedOptions);
                $fuzzOptions = promptRunOptions($mergedOptions, 'fuzz', $fuzzLocation);
                $lastExitCode = runTestCommand('fuzz', $fuzzLocation, $fuzzOptions);
                break;

            case '4':
            case 'replay':
                $replayTarget = promptText('Crash path or case id, empty for all', '');
                $lastExitCode = runReplayCommand($replayTarget === '' ? null : $replayTarget, $mergedOptions);
                break;

            case '5':
            case 'init':
                $initOptions = $options;
                $initOptions['fixed-config'] = isset($options['config']);
                $lastExitCode = runInitCommand($target, $initOptions);
                break;

            default:
                echo "Unknown action: {$choice}\n";
                $lastExitCode = 2;
                break;
        }

        if (!promptYesNo('Choose another action?', false)) return $lastExitCode;
    }
}

function runBenchmarkCommand(?string $suitePath, array $options): int {
    $suitePath = $suitePath ?: optionString($options, 'suite', 'tests/benchmarks/local.json');
    if (!is_file($suitePath)) {
        fwrite(STDERR, "Benchmark suite not found: {$suitePath}\n");
        return 2;
    }
    $suite = json_decode((string)file_get_contents($suitePath), true);
    if (!is_array($suite)) {
        fwrite(STDERR, "Benchmark suite is not valid JSON: {$suitePath}\n");
        return 2;
    }

    $started = microtime(true);
    $baseUrl = optionString($options, 'base-url', (string)($suite['base-url'] ?? ''));
    $cases = array_values(array_filter($suite['cases'] ?? [], 'is_array'));
    $results = [];
    $unexpected = 0;

    echo "openapi-contract-php benchmark\n";
    echo str_repeat("-", 30) . "\n\n";
    echo "Suite: " . ($suite['name'] ?? basename($suitePath)) . "\n";
    echo "Cases: " . count($cases) . "\n\n";

    foreach ($cases as $case) {
        $caseResult = runBenchmarkCase($case, $suite, $options, $baseUrl);
        $results[] = $caseResult;
        if (!$caseResult['matched_expectation']) $unexpected++;
        printf(
            " %-4s %-28s %4d cases %3d failures %.3fs\n",
            $caseResult['matched_expectation'] ? 'OK' : 'FAIL',
            $caseResult['name'],
            $caseResult['cases'],
            $caseResult['failures'],
            $caseResult['duration']
        );
    }

    $aggregate = aggregateBenchmarkResults($results, microtime(true) - $started);
    $baseline = null;
    if (isset($options['benchmark-baseline']) && is_file((string)$options['benchmark-baseline'])) {
        $baseline = json_decode((string)file_get_contents((string)$options['benchmark-baseline']), true);
        if (!is_array($baseline)) $baseline = null;
    }
    $comparison = $baseline ? compareBenchmarkResults($aggregate, $baseline['aggregate'] ?? []) : null;
    $report = [
        'schema_version' => 1,
        'suite' => [
            'name' => $suite['name'] ?? basename($suitePath),
            'path' => $suitePath,
            'base_url' => $baseUrl
        ],
        'created_at' => gmdate('c'),
        'aggregate' => $aggregate,
        'comparison' => $comparison,
        'results' => $results
    ];

    $jsonPath = optionString($options, 'benchmark-output', 'benchmark-report/results.json');
    writeBenchmarkFile($jsonPath, json_encode($report, JSON_PRETTY_PRINT | JSON_UNESCAPED_SLASHES) . "\n");
    $markdownPath = optionString($options, 'benchmark-markdown', 'benchmark-report/summary.md');
    writeBenchmarkFile($markdownPath, benchmarkMarkdown($report));
    runProAfterBenchmarkHook($report, $options);

    echo "\n================================== BENCHMARK ==================================\n";
    echo "Runtime: " . sprintf('%.3fs', $aggregate['duration']) . "\n";
    echo "Operations: {$aggregate['operations_selected']}/{$aggregate['operations_total']}\n";
    echo "Cases: {$aggregate['cases']}\n";
    echo "Failures: {$aggregate['failures']}\n";
    echo "Unexpected results: {$unexpected}\n";
    echo "Quality score: {$aggregate['quality_score']}/100\n";
    if ($comparison !== null) {
        echo "Baseline delta: " . sprintf('%+.1f', $comparison['quality_score_delta']) . " score, ";
        echo sprintf('%+d', $comparison['failure_delta']) . " failures\n";
    }
    echo "Benchmark JSON: {$jsonPath}\n";
    echo "Benchmark Markdown: {$markdownPath}\n";

    return ($unexpected > 0 && truthyOption($options['fail-on-regression'] ?? false)) ? 1 : 0;
}

function runBenchmarkCase(array $case, array $suite, array $globalOptions, string $baseUrl): array {
    $name = (string)($case['name'] ?? 'case-' . substr(hash('sha256', json_encode($case)), 0, 8));
    $command = in_array(($case['command'] ?? 'run'), ['run', 'fuzz'], true) ? (string)($case['command'] ?? 'run') : 'run';
    $schema = benchmarkInterpolate((string)($case['schema'] ?? ''), $baseUrl);
    $caseOptions = benchmarkCaseOptions($case, $suite, $globalOptions, $baseUrl);
    $expectedExit = isset($case['expect_exit_code']) ? (int)$case['expect_exit_code'] : (int)($case['expected_exit_code'] ?? 0);
    $expectedFailures = isset($case['expected_failures']) ? (int)$case['expected_failures'] : null;

    $GLOBALS['openapi_contract_last_run'] = null;
    $started = microtime(true);
    ob_start();
    $exitCode = runTestCommand($command, $schema, $caseOptions);
    $output = ob_get_clean();
    $duration = microtime(true) - $started;
    $summary = is_array($GLOBALS['openapi_contract_last_run'] ?? null) ? $GLOBALS['openapi_contract_last_run'] : [];
    $failures = (int)($summary['failed'] ?? ($exitCode === 0 ? 0 : 1));
    $matched = $exitCode === $expectedExit && ($expectedFailures === null || $failures === $expectedFailures);

    return [
        'name' => $name,
        'command' => $command,
        'schema' => $schema,
        'url' => $caseOptions['url'] ?? null,
        'exit_code' => $exitCode,
        'expected_exit_code' => $expectedExit,
        'expected_failures' => $expectedFailures,
        'matched_expectation' => $matched,
        'duration' => round($duration, 6),
        'cases' => (int)($summary['cases'] ?? 0),
        'passed' => (int)($summary['passed'] ?? 0),
        'failures' => $failures,
        'skipped' => (int)($summary['skipped'] ?? 0),
        'operations_selected' => (int)($summary['operations_selected'] ?? 0),
        'operations_total' => (int)($summary['operations_total'] ?? 0),
        'warnings' => $summary['warnings'] ?? [],
        'failure_messages' => $summary['failure_messages'] ?? [],
        'output_tail' => benchmarkOutputTail((string)$output)
    ];
}

function benchmarkCaseOptions(array $case, array $suite, array $globalOptions, string $baseUrl): array {
    $options = [];
    foreach (($suite['defaults'] ?? []) as $key => $value) $options[kebabCase((string)$key)] = benchmarkOptionValue($value, $baseUrl);
    foreach (($case['options'] ?? []) as $key => $value) $options[kebabCase((string)$key)] = benchmarkOptionValue($value, $baseUrl);
    foreach (['url', 'seed', 'max-examples', 'max-time', 'phases', 'checks', 'exclude-checks', 'mode', 'request-timeout', 'cache-dir', 'report-dir', 'report', 'report-html-path', 'report-curl-path', 'auth', 'auth-token', 'pro-path', 'pro-output-dir', 'pro-project', 'pro-customer', 'pro-rules'] as $key) {
        if (array_key_exists($key, $globalOptions)) $options[$key] = $globalOptions[$key];
    }
    if (isset($globalOptions['auth-api-key'])) $options['auth-api-key'] = $globalOptions['auth-api-key'];
    if (isset($globalOptions['header'])) $options['header'] = $globalOptions['header'];
    if (isset($case['url'])) $options['url'] = benchmarkInterpolate((string)$case['url'], $baseUrl);
    if (isset($globalOptions['url'])) $options['url'] = benchmarkInterpolate((string)$globalOptions['url'], $baseUrl);
    $options['benchmark-case-name'] = benchmarkCaseSlug($case);
    if (isset($options['report-dir']) && trim((string)$options['report-dir']) !== '') {
        $options['report-dir'] = rtrim((string)$options['report-dir'], DIRECTORY_SEPARATOR) . DIRECTORY_SEPARATOR . $options['benchmark-case-name'];
    }
    return $options;
}

function benchmarkOptionValue($value, string $baseUrl) {
    if (is_array($value)) return array_map(fn($item) => is_string($item) ? benchmarkInterpolate($item, $baseUrl) : $item, $value);
    if (is_string($value)) return benchmarkInterpolate($value, $baseUrl);
    return $value;
}

function benchmarkInterpolate(string $value, string $baseUrl): string {
    return str_replace('{base_url}', rtrim($baseUrl, '/'), $value);
}

function benchmarkCaseSlug(array $case): string {
    $name = trim((string)($case['name'] ?? basename((string)($case['schema'] ?? 'case'))));
    $slug = trim((string)preg_replace('/[^a-zA-Z0-9_.-]+/', '-', $name), '-');
    return $slug === '' ? 'case' : $slug;
}

function benchmarkOutputTail(string $output): string {
    $lines = preg_split('/\r\n|\n|\r/', trim($output)) ?: [];
    return implode("\n", array_slice($lines, -20));
}

function aggregateBenchmarkResults(array $results, float $duration): array {
    $total = count($results);
    $matched = count(array_filter($results, fn(array $result): bool => (bool)$result['matched_expectation']));
    $failures = array_sum(array_column($results, 'failures'));
    $unexpected = $total - $matched;
    $operationsSelected = array_sum(array_column($results, 'operations_selected'));
    $operationsTotal = array_sum(array_column($results, 'operations_total'));
    $cases = array_sum(array_column($results, 'cases'));
    $passed = array_sum(array_column($results, 'passed'));
    $skipped = array_sum(array_column($results, 'skipped'));
    $qualityScore = $total === 0 ? 0.0 : max(0.0, round(($matched / $total) * 100 - min(25, $unexpected * 5), 1));
    return [
        'duration' => round($duration, 6),
        'benchmark_cases' => $total,
        'matched_expectations' => $matched,
        'unexpected_results' => $unexpected,
        'operations_selected' => $operationsSelected,
        'operations_total' => $operationsTotal,
        'cases' => $cases,
        'passed' => $passed,
        'failures' => $failures,
        'skipped' => $skipped,
        'quality_score' => $qualityScore
    ];
}

function compareBenchmarkResults(array $current, array $baseline): array {
    return [
        'quality_score_delta' => round((float)($current['quality_score'] ?? 0) - (float)($baseline['quality_score'] ?? 0), 1),
        'failure_delta' => (int)($current['failures'] ?? 0) - (int)($baseline['failures'] ?? 0),
        'case_delta' => (int)($current['cases'] ?? 0) - (int)($baseline['cases'] ?? 0),
        'unexpected_result_delta' => (int)($current['unexpected_results'] ?? 0) - (int)($baseline['unexpected_results'] ?? 0)
    ];
}

function writeBenchmarkFile(string $path, string $content): void {
    $dir = dirname($path);
    if ($dir !== '.' && !is_dir($dir) && !mkdir($dir, 0777, true) && !is_dir($dir)) {
        fwrite(STDERR, "Could not create benchmark directory: {$dir}\n");
        return;
    }
    file_put_contents($path, $content);
}

function benchmarkMarkdown(array $report): string {
    $aggregate = $report['aggregate'];
    $lines = [
        '# Benchmark Summary',
        '',
        '- Suite: ' . ($report['suite']['name'] ?? ''),
        '- Created: ' . ($report['created_at'] ?? ''),
        '- Quality score: ' . $aggregate['quality_score'] . '/100',
        '- Runtime: ' . sprintf('%.3fs', $aggregate['duration']),
        '- Cases executed: ' . $aggregate['cases'],
        '- Failures observed: ' . $aggregate['failures'],
        '- Unexpected results: ' . $aggregate['unexpected_results'],
        '',
        '| Case | Result | Runtime | Cases | Failures |',
        '| --- | --- | ---: | ---: | ---: |'
    ];
    foreach (($report['results'] ?? []) as $result) {
        $lines[] = '| ' . $result['name'] . ' | ' . ($result['matched_expectation'] ? 'OK' : 'FAIL') . ' | ' . sprintf('%.3fs', $result['duration']) . ' | ' . $result['cases'] . ' | ' . $result['failures'] . ' |';
    }
    if ($report['comparison'] ?? null) {
        $comparison = $report['comparison'];
        $lines[] = '';
        $lines[] = '## Baseline Comparison';
        $lines[] = '';
        $lines[] = '- Quality score delta: ' . sprintf('%+.1f', $comparison['quality_score_delta']);
        $lines[] = '- Failure delta: ' . sprintf('%+d', $comparison['failure_delta']);
        $lines[] = '- Case delta: ' . sprintf('%+d', $comparison['case_delta']);
        $lines[] = '- Unexpected result delta: ' . sprintf('%+d', $comparison['unexpected_result_delta']);
    }
    return implode("\n", $lines) . "\n";
}

function defaultConfigPath(): string {
    foreach (['openapi-contract.json', '.openapi-contract.json'] as $candidate) {
        if (is_file($candidate)) return $candidate;
    }
    return 'openapi-contract.json';
}

function promptUrlOption(array $options, ?string $location): array {
    $defaultUrl = optionString($options, 'url', $location === null ? '' : guessBaseUrl($location));
    $url = promptText('API base URL', $defaultUrl);
    if ($url !== '') $options['url'] = $url;
    return $options;
}

function promptRunOptions(array $options, string $command, ?string &$location): array {
    $location = promptText('OpenAPI schema location', $location ?? 'openapi.json');
    $options = promptUrlOption($options, $location);

    if ($command === 'run') {
        $options['phases'] = promptText('Phases', optionString($options, 'phases', 'examples,coverage,fuzzing'));
    } else {
        $mode = promptText('Mode', optionString($options, 'mode', 'positive'));
        $options['mode'] = in_array($mode, ['positive', 'negative', 'all'], true) ? $mode : 'positive';
    }

    $defaultExamples = $command === 'fuzz' ? '100' : '5';
    $options['max-examples'] = promptText('Max examples per operation', optionString($options, 'max-examples', $defaultExamples));
    $reports = promptText('Reports, comma-separated or none', implode(',', csvOption($options, 'report', [])));
    if ($reports === '') unset($options['report']);
    else $options['report'] = csvList($reports);
    return $options;
}

function runDoctorCommand(?string $target, array $options): int {
    $failures = 0;
    $warnings = [];
    $timeout = isset($options['request-timeout']) ? max(1.0, (float)$options['request-timeout']) : 10.0;
    $transport = transportOptionsFromOptions($options);
    $location = schemaLocationFromOptions($target, $options);

    echo "openapi-contract-php doctor\n";
    echo str_repeat("-", 27) . "\n\n";

    if (PHP_VERSION_ID >= 80200) {
        doctorLine('OK', 'PHP', PHP_VERSION);
    } else {
        doctorLine('FAIL', 'PHP', 'PHP 8.2 or newer is required; current version is ' . PHP_VERSION);
        $failures++;
    }

    foreach (['json', 'curl'] as $extension) {
        if (extension_loaded($extension)) {
            doctorLine('OK', "Extension {$extension}", 'loaded');
        } else {
            doctorLine('FAIL', "Extension {$extension}", 'missing');
            $failures++;
        }
    }

    if (isset($options['config'])) {
        doctorLine('OK', 'Config', (string)$options['config']);
    } else {
        doctorLine('WARN', 'Config', 'no config file loaded');
        $warnings[] = 'No config file was found; run init to create one.';
    }

    if ($location === null) {
        doctorLine('FAIL', 'Schema', 'no location provided');
        $failures++;
    } else {
        $isYaml = (bool)preg_match('/\.(ya?ml)$/i', parse_url($location, PHP_URL_PATH) ?? $location);
        if ($isYaml && !function_exists('yaml_parse')) {
            doctorLine('WARN', 'YAML parser', 'php-yaml is not loaded; using the built-in limited YAML parser');
            $warnings[] = 'Complex YAML features may require the php-yaml extension.';
        }

        try {
            $schema = loadSchema($location, $timeout, isset($options['wait-for-schema']) ? (float)$options['wait-for-schema'] : 0.0, $transport);
            doctorLine('OK', 'Schema', $location);
            doctorLine('OK', 'Specification', specificationLabel($schema));

            $baseUrl = baseUrlFromSchema($schema, $options['url'] ?? null);
            if (preg_match('#^https?://#', $baseUrl)) {
                doctorLine('OK', 'Base URL', $baseUrl);
            } else {
                doctorLine('FAIL', 'Base URL', "{$baseUrl} is not an absolute HTTP URL");
                $failures++;
            }

            $allOperations = collectOperations($schema);
            $selectedOperations = filterOperations($allOperations, $options, $warnings);
            if ($selectedOperations) {
                doctorLine('OK', 'Operations', count($selectedOperations) . ' selected / ' . count($allOperations) . ' total');
            } else {
                doctorLine('FAIL', 'Operations', 'no operations selected');
                $failures++;
            }

            $phases = csvOption($options, 'phases', ['examples', 'coverage', 'fuzzing']);
            $checks = selectedChecks($options);
            addCompatibilityWarnings($options, $phases, $checks, 'run', $schema, $warnings);
            doctorLine('OK', 'Phases', implode(',', $phases));
            doctorLine('OK', 'Checks', implode(',', $checks));

            $report = reportOptionsFromOptions($options);
            doctorLine('OK', 'Reports', ($report['formats'] ?? []) ? implode(',', $report['formats']) : 'disabled');
            doctorLine('OK', 'Cache', (string)($options['cache-dir'] ?? DEFAULT_CACHE_DIR));
        } catch (Throwable $e) {
            doctorLine('FAIL', 'Schema', $e->getMessage());
            $failures++;
        }
    }

    foreach (array_values(array_unique($warnings)) as $warning) {
        doctorLine('WARN', 'Note', $warning);
    }

    echo "\n";
    echo $failures ? "Doctor found {$failures} blocking issue(s).\n" : "Doctor found no blocking issues.\n";
    return $failures ? 1 : 0;
}

function schemaLocationFromOptions(?string $location, array $options): ?string {
    foreach ([$location, $options['schema-location'] ?? null, $options['schema'] ?? null, $options['location'] ?? null] as $candidate) {
        if ($candidate === null || $candidate === true) continue;
        $value = trim((string)$candidate);
        if ($value !== '') return $value;
    }
    return null;
}

function optionString(array $options, string $name, string $default = ''): string {
    if (!array_key_exists($name, $options) || $options[$name] === true || $options[$name] === null) return $default;
    $value = $options[$name];
    if (is_array($value)) return implode(',', array_map('strval', $value));
    return trim((string)$value);
}

function truthyOption($value): bool {
    if ($value === true) return true;
    if ($value === false || $value === null) return false;
    return !in_array(strtolower(trim((string)$value)), ['', '0', 'false', 'no', 'off'], true);
}

function promptText(string $label, string $default = ''): string {
    $suffix = $default === '' ? '' : " [{$default}]";
    fwrite(STDOUT, "{$label}{$suffix}: ");
    $line = fgets(STDIN);
    if ($line === false) return $default;
    $value = trim($line);
    return $value === '' ? $default : $value;
}

function promptYesNo(string $label, bool $default): bool {
    $suffix = $default ? 'Y/n' : 'y/N';
    while (true) {
        fwrite(STDOUT, "{$label} [{$suffix}]: ");
        $line = fgets(STDIN);
        if ($line === false) return $default;
        $value = strtolower(trim($line));
        if ($value === '') return $default;
        if (in_array($value, ['y', 'yes'], true)) return true;
        if (in_array($value, ['n', 'no'], true)) return false;
    }
}

function parseHeaderInput(string $value): array {
    $headers = [];
    foreach (explode(',', $value) as $header) {
        $header = trim($header);
        if ($header !== '' && str_contains($header, ':')) $headers[] = $header;
    }
    return $headers;
}

function csvList(string $value): array {
    return array_values(array_filter(array_map('trim', explode(',', $value)), fn(string $item) => $item !== ''));
}

function guessBaseUrl(string $schemaLocation): string {
    if (trim($schemaLocation) === '') return '';
    try {
        $schema = loadSchemaOnce($schemaLocation, 3.0, []);
        return isset($schema['servers'][0]['url']) ? rtrim((string)$schema['servers'][0]['url'], '/') : '';
    } catch (Throwable) {
        return '';
    }
}

function doctorLine(string $status, string $label, string $detail): void {
    printf(" %-4s %-20s %s\n", $status, $label . ':', $detail);
}

function runReplayCommand(?string $target, array $options): int {
    $cacheDir = (string)($options['cache-dir'] ?? DEFAULT_CACHE_DIR);
    $crashes = resolveReplayTargets($target, $cacheDir);
    if (!$crashes) {
        fwrite(STDERR, "No crash files found to replay.\n");
        return 2;
    }

    $timeout = isset($options['request-timeout']) ? max(1.0, (float)$options['request-timeout']) : 10.0;
    $transport = transportOptionsFromOptions($options);
    $failures = [];
    $passed = 0;

    echo "openapi-contract-php replay\n";
    echo str_repeat("-", 27) . "\n\n";

    foreach ($crashes as $path) {
        $crash = json_decode((string)file_get_contents($path), true);
        if (!is_array($crash)) {
            $failures[] = "{$path}: invalid crash file";
            continue;
        }

        $request = $crash['request'] ?? [];
        $method = (string)($request['method'] ?? 'GET');
        $url = replayUrl($crash, $options);
        $headers = array_map('strval', $request['headers'] ?? []);
        $body = array_key_exists('body', $request) && $request['body'] !== null ? (string)$request['body'] : null;

        try {
            $response = httpRequest($method, $url, $headers, $body, $timeout, $transport);
            $failure = null;
            if (isset($crash['operation'], $crash['components'], $crash['checks']) && is_array($crash['operation'])) {
                $failure = validateResponse(
                    ['operation' => $crash['operation'], 'path' => $crash['operation_path'] ?? $request['path_query'] ?? '', 'method' => $method],
                    $response,
                    is_array($crash['components']) ? $crash['components'] : [],
                    is_array($crash['checks']) ? $crash['checks'] : DEFAULT_CHECKS,
                    $crash['max_response_time'] ?? null,
                    (string)($request['mode'] ?? 'positive')
                );
            }
            if ($failure === null) {
                echo " OK   {$crash['id']} {$method} {$url}\n";
                $passed++;
                if (!($options['keep'] ?? false)) @unlink($path);
            } else {
                echo " FAIL {$crash['id']} {$method} {$url}: {$failure}\n";
                $failures[] = "{$crash['id']}: {$failure}";
            }
        } catch (Throwable $e) {
            echo " FAIL {$crash['id']} {$method} {$url}: {$e->getMessage()}\n";
            $failures[] = "{$crash['id']}: {$e->getMessage()}";
        }
    }

    echo "\n=================================== SUMMARY ====================================\n";
    echo "Replayed: " . count($crashes) . "\n";
    echo "Passed: {$passed}\n";
    echo "Failed: " . count($failures) . "\n";
    return $failures ? 1 : 0;
}

function resolveReplayTargets(?string $target, string $cacheDir): array {
    $crashDir = rtrim($cacheDir, DIRECTORY_SEPARATOR) . DIRECTORY_SEPARATOR . 'crashes';
    if ($target === null || $target === '') {
        return array_values(array_filter(glob($crashDir . DIRECTORY_SEPARATOR . '*.json') ?: [], 'is_file'));
    }
    if (is_file($target)) return [$target];
    if (is_dir($target)) return array_values(array_filter(glob(rtrim($target, DIRECTORY_SEPARATOR) . DIRECTORY_SEPARATOR . '*.json') ?: [], 'is_file'));
    $candidate = $crashDir . DIRECTORY_SEPARATOR . $target . '.json';
    if (is_file($candidate)) return [$candidate];
    $matches = glob($crashDir . DIRECTORY_SEPARATOR . $target . '*.json') ?: [];
    return array_values(array_filter($matches, 'is_file'));
}

function replayUrl(array $crash, array $options): string {
    if (!isset($options['url']) || trim((string)$options['url']) === '') {
        return (string)($crash['request']['url'] ?? '');
    }
    $pathQuery = (string)($crash['request']['path_query'] ?? parse_url((string)($crash['request']['url'] ?? ''), PHP_URL_PATH) ?? '/');
    return rtrim((string)$options['url'], '/') . $pathQuery;
}

function parseCli(array $argv): array {
    $command = $argv[1] ?? null;
    $options = [];
    $location = null;
    $count = count($argv);
    for ($i = 2; $i < $count; $i++) {
        $arg = $argv[$i];
        if ($arg === '-H' || $arg === '--header') {
            $options['header'][] = $argv[++$i] ?? '';
            continue;
        }
        if ($arg === '-a' || $arg === '--auth') {
            $options['auth'] = $argv[++$i] ?? '';
            continue;
        }
        if ($arg === '-c' || $arg === '--checks') {
            appendOption($options, 'checks', $argv[++$i] ?? '');
            continue;
        }
        if ($arg === '-m' || $arg === '--mode') {
            $options['mode'] = $argv[++$i] ?? '';
            continue;
        }
        if ($arg === '-w' || $arg === '--workers') {
            $options['workers'] = $argv[++$i] ?? '';
            continue;
        }
        if ($arg === '-u' || $arg === '--url') {
            $options['url'] = $argv[++$i] ?? '';
            continue;
        }
        if ($arg === '-n' || $arg === '--max-examples') {
            $options['max-examples'] = $argv[++$i] ?? '1';
            continue;
        }
        if (str_starts_with($arg, '--')) {
            $arg = substr($arg, 2);
            if (str_contains($arg, '=')) {
                [$key, $value] = explode('=', $arg, 2);
                if ($key === 'header') $options['header'][] = $value;
                elseif (isRepeatableOption($key)) appendOption($options, $key, $value);
                else $options[$key] = $value;
            } elseif (longOptionRequiresValue($arg)) {
                $value = $argv[++$i] ?? '';
                if (isRepeatableOption($arg)) appendOption($options, $arg, $value);
                else $options[$arg] = $value;
            } elseif ($arg === 'header') {
                $options['header'][] = $argv[++$i] ?? '';
            } else {
                $options[$arg] = true;
            }
            continue;
        }
        $location = $arg;
    }
    return ['command' => $command, 'location' => $location, 'options' => $options];
}

function longOptionRequiresValue(string $option): bool {
    return in_array($option, [
        'config',
        'url',
        'workers',
        'max-examples',
        'max-time',
        'phases',
        'suppress-health-check',
        'wait-for-schema',
        'warnings',
        'checks',
        'exclude-checks',
        'max-failures',
        'max-response-time',
        'include-path',
        'include-method',
        'include-name',
        'include-tag',
        'include-operation-id',
        'exclude-path',
        'exclude-method',
        'exclude-name',
        'exclude-tag',
        'exclude-operation-id',
        'include-path-regex',
        'include-method-regex',
        'include-name-regex',
        'include-tag-regex',
        'include-operation-id-regex',
        'exclude-path-regex',
        'exclude-method-regex',
        'exclude-name-regex',
        'exclude-tag-regex',
        'exclude-operation-id-regex',
        'include-by',
        'exclude-by',
        'request-timeout',
        'request-retries',
        'request-cert',
        'request-cert-key',
        'proxy',
        'tls-verify',
        'rate-limit',
        'max-redirects',
        'report',
        'report-dir',
        'cache-dir',
        'base-url',
        'benchmark-output',
        'benchmark-markdown',
        'benchmark-baseline',
        'pro-path',
        'pro-output-dir',
        'pro-project',
        'pro-customer',
        'pro-rules',
        'pro-phar',
        'report-junit-path',
        'report-vcr-path',
        'report-har-path',
        'report-ndjson-path',
        'report-html-path',
        'report-curl-path',
        'output-sanitize',
        'output-truncate',
        'mode',
        'seed',
        'auth',
        'auth-token',
        'auth-api-key',
        'generation-allow-x00',
        'generation-codec',
        'generation-maximize',
        'generation-with-security-parameters',
        'generation-graphql-allow-null',
        'generation-database',
        'schema-location'
    ], true);
}

function isRepeatableOption(string $option): bool {
    return in_array($option, [
        'checks',
        'exclude-checks',
        'include-path',
        'include-method',
        'include-name',
        'include-tag',
        'include-operation-id',
        'exclude-path',
        'exclude-method',
        'exclude-name',
        'exclude-tag',
        'exclude-operation-id',
        'include-path-regex',
        'include-method-regex',
        'include-name-regex',
        'include-tag-regex',
        'include-operation-id-regex',
        'exclude-path-regex',
        'exclude-method-regex',
        'exclude-name-regex',
        'exclude-tag-regex',
        'exclude-operation-id-regex',
        'include-by',
        'exclude-by',
        'auth-api-key',
        'report'
    ], true);
}

function appendOption(array &$options, string $name, string $value): void {
    if (!isset($options[$name])) {
        $options[$name] = [$value];
        return;
    }
    if (!is_array($options[$name])) {
        $options[$name] = [$options[$name]];
    }
    $options[$name][] = $value;
}

function mergeConfigOptions(array $options): array {
    $configPath = $options['config'] ?? null;
    if ($configPath === null) {
        foreach (['openapi-contract.json', '.openapi-contract.json'] as $candidate) {
            if (is_file($candidate)) {
                $configPath = $candidate;
                break;
            }
        }
    }
    if ($configPath === null || $configPath === true || trim((string)$configPath) === '') return $options;
    if (!is_file((string)$configPath)) {
        fwrite(STDERR, "Config file not found: {$configPath}\n");
        exit(2);
    }

    $json = file_get_contents((string)$configPath);
    $config = json_decode((string)$json, true);
    if (!is_array($config)) {
        fwrite(STDERR, "Config file is not valid JSON: {$configPath}\n");
        exit(2);
    }

    $defaults = flattenConfigOptions($config);
    foreach ($options as $key => $value) {
        if ($key === 'config') continue;
        $defaults[$key] = mergeOptionValue($defaults[$key] ?? null, $value);
    }
    $defaults['config'] = $configPath;
    return $defaults;
}

function flattenConfigOptions(array $config): array {
    $options = [];
    foreach ($config as $key => $value) {
        if ($key === 'headers' && is_array($value)) {
            foreach ($value as $header) $options['header'][] = (string)$header;
            continue;
        }
        if ($key === 'auth' && is_array($value)) {
            flattenAuthConfig($value, $options);
            continue;
        }
        if ($key === 'reports' && is_array($value)) {
            flattenReportConfig($value, $options);
            continue;
        }
        if ($key === 'generation' && is_array($value)) {
            foreach ($value as $generationKey => $generationValue) {
                $options['generation-' . kebabCase((string)$generationKey)] = scalarConfigValue($generationValue);
            }
            continue;
        }
        if ($key === 'request' && is_array($value)) {
            foreach ($value as $requestKey => $requestValue) {
                $options['request-' . kebabCase((string)$requestKey)] = scalarConfigValue($requestValue);
            }
            continue;
        }
        $options[kebabCase((string)$key)] = scalarConfigValue($value);
    }
    return $options;
}

function flattenAuthConfig(array $auth, array &$options): void {
    if (isset($auth['basic']) && is_array($auth['basic']) && isset($auth['basic']['username'], $auth['basic']['password'])) {
        $options['auth'] = $auth['basic']['username'] . ':' . $auth['basic']['password'];
    }
    if (isset($auth['bearer'])) {
        $options['auth-token'] = (string)$auth['bearer'];
    }
    if (isset($auth['openapi']) && is_array($auth['openapi'])) {
        foreach ($auth['openapi'] as $scheme => $settings) {
            if (!is_array($settings)) continue;
            foreach (['api-key', 'api_key', 'key', 'token'] as $keyName) {
                if (isset($settings[$keyName])) {
                    appendOption($options, 'auth-api-key', $scheme . ':' . (string)$settings[$keyName]);
                    break;
                }
            }
            if (isset($settings['bearer'])) {
                $options['auth-token'] = (string)$settings['bearer'];
            }
            if (isset($settings['username'], $settings['password'])) {
                $options['auth'] = $settings['username'] . ':' . $settings['password'];
            }
        }
    }
}

function flattenReportConfig(array $reports, array &$options): void {
    if (isset($reports['directory'])) $options['report-dir'] = (string)$reports['directory'];
    foreach (['junit', 'har', 'ndjson', 'vcr', 'html', 'curl'] as $format) {
        if (!isset($reports[$format]) || !is_array($reports[$format])) continue;
        if (($reports[$format]['enabled'] ?? false) || isset($reports[$format]['path'])) {
            appendOption($options, 'report', $format);
        }
        if (isset($reports[$format]['path'])) {
            $options["report-{$format}-path"] = (string)$reports[$format]['path'];
        }
    }
}

function scalarConfigValue($value) {
    if (is_array($value)) return $value;
    if (is_bool($value)) return $value ? 'true' : 'false';
    return $value;
}

function kebabCase(string $value): string {
    return strtolower(str_replace('_', '-', $value));
}

function mergeOptionValue($default, $override) {
    if ($default === null) return $override;
    if (is_array($default) || is_array($override)) {
        return array_merge((array)$default, (array)$override);
    }
    return $override;
}

function reportOptionsFromOptions(array $options): array {
    $formats = csvOption($options, 'report', []);
    foreach (['junit', 'har', 'ndjson', 'vcr', 'html', 'curl'] as $format) {
        if (isset($options["report-{$format}-path"])) $formats[] = $format;
    }
    $formats = array_values(array_unique(array_filter($formats, fn(string $format) => in_array($format, ['junit', 'har', 'ndjson', 'vcr', 'html', 'curl'], true))));
    $dir = rtrim((string)($options['report-dir'] ?? DEFAULT_REPORT_DIR), DIRECTORY_SEPARATOR);
    return [
        'formats' => $formats,
        'dir' => $dir,
        'paths' => [
            'junit' => $options['report-junit-path'] ?? ($dir . DIRECTORY_SEPARATOR . 'junit.xml'),
            'har' => $options['report-har-path'] ?? ($dir . DIRECTORY_SEPARATOR . 'traffic.har'),
            'ndjson' => $options['report-ndjson-path'] ?? ($dir . DIRECTORY_SEPARATOR . 'events.ndjson'),
            'vcr' => $options['report-vcr-path'] ?? ($dir . DIRECTORY_SEPARATOR . 'cassette.yaml'),
            'html' => $options['report-html-path'] ?? ($dir . DIRECTORY_SEPARATOR . 'report.html'),
            'curl' => $options['report-curl-path'] ?? ($dir . DIRECTORY_SEPARATOR . 'reproducers.sh')
        ],
        'preserve_bytes' => (bool)($options['report-preserve-bytes'] ?? false)
    ];
}

function csvOption(array $options, string $name, array $default): array {
    $value = $options[$name] ?? null;
    if ($value === null || $value === true || $value === '') return $default;
    if (is_array($value)) {
        $items = [];
        foreach ($value as $item) {
            $items = array_merge($items, array_map('trim', explode(',', (string)$item)));
        }
        return array_values(array_filter($items, fn($item) => $item !== ''));
    }
    return array_values(array_filter(array_map('trim', explode(',', (string)$value)), fn($item) => $item !== ''));
}

function headersFromOptions(array $options): array {
    $headers = ['Accept: application/json'];
    foreach ((array)($options['header'] ?? []) as $header) {
        if (trim((string)$header) !== '') $headers[] = trim((string)$header);
    }
    if (isset($options['auth']) && !hasHeader($headers, 'authorization')) {
        $headers[] = 'Authorization: Basic ' . base64_encode((string)$options['auth']);
    }
    return $headers;
}

function authHeadersFromSchema(array $schema, array $options): array {
    $headers = [];
    $schemes = $schema['components']['securitySchemes'] ?? [];
    foreach ($schemes as $name => $scheme) {
        if (!is_array($scheme)) continue;
        $type = strtolower((string)($scheme['type'] ?? ''));
        $httpScheme = strtolower((string)($scheme['scheme'] ?? ''));
        if ($type === 'http' && $httpScheme === 'bearer' && isset($options['auth-token'])) {
            $headers[] = 'Authorization: Bearer ' . (string)$options['auth-token'];
        } elseif ($type === 'http' && $httpScheme === 'basic' && isset($options['auth']) && !hasHeader($headers, 'authorization')) {
            $headers[] = 'Authorization: Basic ' . base64_encode((string)$options['auth']);
        } elseif ($type === 'apikey' && strtolower((string)($scheme['in'] ?? '')) === 'header') {
            $apiKey = apiKeyValueForScheme($name, $options);
            if ($apiKey !== null) $headers[] = ($scheme['name'] ?? $name) . ': ' . $apiKey;
        }
    }
    return $headers;
}

function apiKeyValueForScheme(string $schemeName, array $options): ?string {
    foreach (optionValues($options, 'auth-api-key') as $entry) {
        if (str_contains($entry, ':')) {
            [$name, $value] = explode(':', $entry, 2);
            if ($name === $schemeName) return $value;
        } elseif ($entry !== '') {
            return $entry;
        }
    }
    return null;
}

function mergeHeaders(array ...$headerSets): array {
    $merged = [];
    foreach ($headerSets as $headers) {
        foreach ($headers as $header) {
            if (!str_contains((string)$header, ':')) continue;
            [$name] = explode(':', (string)$header, 2);
            $merged[strtolower(trim($name))] = trim((string)$header);
        }
    }
    return array_values($merged);
}

function stripSecurityHeaders(array $headers, array $schema): array {
    $securityHeaderNames = ['authorization'];
    foreach (($schema['components']['securitySchemes'] ?? []) as $scheme) {
        if (is_array($scheme) && strtolower((string)($scheme['type'] ?? '')) === 'apikey' && strtolower((string)($scheme['in'] ?? '')) === 'header') {
            $securityHeaderNames[] = strtolower((string)($scheme['name'] ?? ''));
        }
    }
    return array_values(array_filter($headers, function($header) use ($securityHeaderNames): bool {
        if (!str_contains((string)$header, ':')) return true;
        [$name] = explode(':', (string)$header, 2);
        return !in_array(strtolower(trim($name)), $securityHeaderNames, true);
    }));
}

function invalidSecurityHeaders(array $schema): array {
    $headers = [];
    foreach (($schema['components']['securitySchemes'] ?? []) as $name => $scheme) {
        if (!is_array($scheme)) continue;
        $type = strtolower((string)($scheme['type'] ?? ''));
        $httpScheme = strtolower((string)($scheme['scheme'] ?? ''));
        if ($type === 'http' && $httpScheme === 'bearer') $headers[] = 'Authorization: Bearer invalid-token';
        elseif ($type === 'http' && $httpScheme === 'basic') $headers[] = 'Authorization: Basic ' . base64_encode('invalid:invalid');
        elseif ($type === 'apikey' && strtolower((string)($scheme['in'] ?? '')) === 'header') $headers[] = ($scheme['name'] ?? $name) . ': invalid';
    }
    return $headers;
}

function apiKeyCookieHeaders(array $schema, array $options): array {
    $cookies = [];
    foreach (($schema['components']['securitySchemes'] ?? []) as $schemeName => $scheme) {
        if (!is_array($scheme) || strtolower((string)($scheme['type'] ?? '')) !== 'apikey' || strtolower((string)($scheme['in'] ?? '')) !== 'cookie') continue;
        $value = apiKeyValueForScheme((string)$schemeName, $options);
        if ($value !== null) $cookies[] = rawurlencode((string)($scheme['name'] ?? $schemeName)) . '=' . rawurlencode($value);
    }
    return $cookies ? ['Cookie: ' . implode('; ', $cookies)] : [];
}

function hasHeader(array $headers, string $name): bool {
    $prefix = strtolower($name) . ':';
    foreach ($headers as $header) {
        if (str_starts_with(strtolower($header), $prefix)) return true;
    }
    return false;
}

function selectedChecks(array $options): array {
    $checks = csvOption($options, 'checks', DEFAULT_CHECKS);
    if (in_array('all', $checks, true)) $checks = KNOWN_CHECKS;
    $exclude = csvOption($options, 'exclude-checks', []);
    if (in_array('all', $exclude, true)) return [];
    return array_values(array_diff($checks, $exclude));
}

function transportOptionsFromOptions(array $options): array {
    return [
        'request_retries' => isset($options['request-retries']) ? max(0, (int)$options['request-retries']) : 0,
        'max_redirects' => isset($options['max-redirects']) ? max(0, (int)$options['max-redirects']) : 0,
        'proxy' => isset($options['proxy']) ? trim((string)$options['proxy']) : null,
        'tls_verify' => parseTlsVerify($options['tls-verify'] ?? true),
        'request_cert' => isset($options['request-cert']) ? trim((string)$options['request-cert']) : null,
        'request_cert_key' => isset($options['request-cert-key']) ? trim((string)$options['request-cert-key']) : null,
        'rate_limit_interval' => isset($options['rate-limit']) ? parseRateLimit((string)$options['rate-limit']) : null
    ];
}

function parseTlsVerify($value) {
    if ($value === true || $value === null) return true;
    $normalized = strtolower(trim((string)$value));
    return match ($normalized) {
        'false', '0', 'no', 'off' => false,
        'true', '1', 'yes', 'on' => true,
        default => (string)$value
    };
}

function parseBooleanOption($value): bool {
    if ($value === true || $value === null) return true;
    if ($value === false) return false;
    return !in_array(strtolower(trim((string)$value)), ['false', '0', 'no', 'off'], true);
}

function parseRateLimit(string $value): ?float {
    if (!preg_match('/^\s*(\d+(?:\.\d+)?)\s*\/\s*([smh])\s*$/i', $value, $match)) return null;
    $limit = (float)$match[1];
    if ($limit <= 0.0) return null;
    $seconds = match (strtolower($match[2])) {
        'h' => 3600.0,
        'm' => 60.0,
        default => 1.0
    };
    return $seconds / $limit;
}

function addCompatibilityWarnings(array $options, array $phases, array $checks, string $command, array $schema, array &$warnings): void {
    foreach (array_diff($checks, IMPLEMENTED_CHECKS) as $check) {
        $warnings[] = "Check '{$check}' is accepted but is not implemented yet.";
    }
    if (in_array('stateful', $phases, true)) {
        $warnings[] = "Stateful testing uses explicit links, Location headers, and simple dependency inference; complex workflows may need schema links.";
    }
    if (isset($options['workers']) && (string)$options['workers'] !== '1') {
        $warnings[] = "--workers is accepted for config compatibility; this dependency-free runner still executes HTTP calls sequentially.";
    }
    if ($command === 'fuzz' && !isset($options['max-time']) && !isset($options['max-examples'])) {
        $warnings[] = "fuzz currently runs 100 examples per operation by default; pass --max-time for time-bounded fuzzing.";
    }
    if (($options['generation-deterministic'] ?? false) === true) {
        $warnings[] = "--generation-deterministic is accepted; use --seed for current reproducibility.";
    }
    foreach ([
        'generation-maximize' => 'targeted generation',
        'generation-database' => 'example database persistence',
        'generation-unique-inputs' => 'unique-input filtering'
    ] as $option => $feature) {
        if (isset($options[$option])) {
            $warnings[] = "--{$option} is accepted, but {$feature} is not implemented yet.";
        }
    }
    if (($schema['x-graphql'] ?? false) === true) {
        $warnings[] = "GraphQL SDL support covers simple Query and Mutation fields over a JSON HTTP endpoint.";
    }
}

function loadSchema(string $location, float $timeout, float $waitForSchema = 0.0, array $transport = []): array {
    $deadline = $waitForSchema > 0.0 ? microtime(true) + $waitForSchema : null;
    $lastError = null;

    do {
        try {
            return loadSchemaOnce($location, $timeout, $transport);
        } catch (Throwable $e) {
            $lastError = $e;
            if ($deadline === null || microtime(true) >= $deadline) break;
            usleep(250000);
        }
    } while (true);

    throw $lastError ?? new RuntimeException('schema could not be loaded');
}

function loadSchemaOnce(string $location, float $timeout, array $transport = []): array {
    if (preg_match('#^https?://#', $location)) {
        $response = httpRequest('GET', $location, ['Accept: application/json'], null, $timeout, $transport);
        if ($response['status'] < 200 || $response['status'] >= 300) {
            throw new RuntimeException("schema returned HTTP {$response['status']}");
        }
        $json = $response['body'];
    } else {
        if (!is_file($location)) throw new RuntimeException("schema file not found: {$location}");
        $json = file_get_contents($location);
    }
    $schema = decodeSchemaDocument((string)$json, $location);
    if (!is_array($schema)) throw new RuntimeException('schema is not a supported JSON or YAML object');
    return normalizeSchemaDocument($schema, $location);
}

function decodeSchemaDocument(string $document, string $location): array {
    $json = json_decode($document, true);
    if (is_array($json)) return $json;

    if (function_exists('yaml_parse')) {
        $yaml = @yaml_parse($document);
        if (is_array($yaml)) return $yaml;
    }

    if (preg_match('/\.(ya?ml)$/i', parse_url($location, PHP_URL_PATH) ?? $location)) {
        $yaml = parseSimpleYaml($document);
        if (is_array($yaml)) return $yaml;
    }

    if (preg_match('/\.(gql|graphql)$/i', parse_url($location, PHP_URL_PATH) ?? $location)) {
        return parseGraphqlSchema($document);
    }

    throw new RuntimeException('schema is not valid JSON and could not be parsed as YAML');
}

function normalizeSchemaDocument(array $schema, string $location): array {
    if (isset($schema['x-graphql'])) return $schema;
    if (isset($schema['swagger']) && str_starts_with((string)$schema['swagger'], '2.')) {
        return normalizeSwagger2($schema);
    }
    if (!isset($schema['openapi'])) {
        throw new RuntimeException('schema is missing openapi or swagger version');
    }
    $schema['x-specification'] = 'OpenAPI ' . (string)$schema['openapi'];
    return $schema;
}

function normalizeSwagger2(array $schema): array {
    $scheme = $schema['schemes'][0] ?? 'http';
    $host = $schema['host'] ?? 'localhost';
    $basePath = $schema['basePath'] ?? '';
    $serverUrl = $scheme . '://' . $host . rtrim((string)$basePath, '/');
    $normalized = [
        'openapi' => '3.0.0',
        'x-source-specification' => 'Swagger ' . (string)($schema['swagger'] ?? '2.0'),
        'x-specification' => 'Swagger ' . (string)($schema['swagger'] ?? '2.0'),
        'info' => $schema['info'] ?? ['title' => 'API', 'version' => 'unknown'],
        'servers' => [['url' => $serverUrl]],
        'paths' => [],
        'components' => [
            'schemas' => $schema['definitions'] ?? [],
            'parameters' => $schema['parameters'] ?? [],
            'responses' => $schema['responses'] ?? [],
            'securitySchemes' => normalizeSwagger2SecuritySchemes($schema['securityDefinitions'] ?? [])
        ],
        'security' => $schema['security'] ?? []
    ];

    foreach (($schema['paths'] ?? []) as $path => $pathItem) {
        if (!is_array($pathItem)) continue;
        $normalizedPathItem = [];
        if (isset($pathItem['parameters'])) $normalizedPathItem['parameters'] = $pathItem['parameters'];
        foreach (HTTP_OPERATION_METHODS as $method) {
            if (!isset($pathItem[$method]) || !is_array($pathItem[$method])) continue;
            $operation = $pathItem[$method];
            $operation['responses'] = normalizeSwagger2Responses($operation['responses'] ?? [], $operation['produces'] ?? $schema['produces'] ?? ['application/json']);
            $operation = normalizeSwagger2RequestBody($operation, $operation['consumes'] ?? $schema['consumes'] ?? ['application/json']);
            $normalizedPathItem[$method] = $operation;
        }
        $normalized['paths'][$path] = $normalizedPathItem;
    }

    return $normalized;
}

function normalizeSwagger2SecuritySchemes(array $definitions): array {
    $schemes = [];
    foreach ($definitions as $name => $definition) {
        if (!is_array($definition)) continue;
        $type = $definition['type'] ?? '';
        if ($type === 'apiKey') {
            $schemes[$name] = ['type' => 'apiKey', 'name' => $definition['name'] ?? $name, 'in' => $definition['in'] ?? 'header'];
        } elseif ($type === 'basic') {
            $schemes[$name] = ['type' => 'http', 'scheme' => 'basic'];
        } elseif ($type === 'oauth2') {
            $schemes[$name] = ['type' => 'oauth2', 'flows' => []];
        }
    }
    return $schemes;
}

function normalizeSwagger2Responses(array $responses, array $produces): array {
    $normalized = [];
    foreach ($responses as $status => $response) {
        if (!is_array($response)) continue;
        if (isset($response['schema'])) {
            $mediaType = $produces[0] ?? 'application/json';
            $response['content'][$mediaType]['schema'] = $response['schema'];
            unset($response['schema']);
        }
        $normalized[(string)$status] = $response;
    }
    return $normalized;
}

function normalizeSwagger2RequestBody(array $operation, array $consumes): array {
    $parameters = [];
    $bodyParameter = null;
    $formProperties = [];
    $formRequired = [];
    foreach (($operation['parameters'] ?? []) as $parameter) {
        if (!is_array($parameter)) continue;
        if (($parameter['in'] ?? '') === 'body') {
            $bodyParameter = $parameter;
            continue;
        }
        if (($parameter['in'] ?? '') === 'formData') {
            $name = (string)($parameter['name'] ?? 'field');
            $formProperties[$name] = schemaFromParameter($parameter);
            if (($parameter['required'] ?? false) === true) $formRequired[] = $name;
            continue;
        }
        $parameters[] = $parameter;
    }
    $operation['parameters'] = $parameters;
    if ($bodyParameter !== null) {
        $mediaType = $consumes[0] ?? 'application/json';
        $operation['requestBody'] = [
            'required' => (bool)($bodyParameter['required'] ?? false),
            'content' => [
                $mediaType => ['schema' => $bodyParameter['schema'] ?? ['type' => 'object']]
            ]
        ];
    } elseif ($formProperties) {
        $mediaType = in_array('multipart/form-data', $consumes, true) ? 'multipart/form-data' : 'application/x-www-form-urlencoded';
        $schema = ['type' => 'object', 'properties' => $formProperties];
        if ($formRequired) $schema['required'] = $formRequired;
        $operation['requestBody'] = ['required' => true, 'content' => [$mediaType => ['schema' => $schema]]];
    }
    return $operation;
}

function schemaFromParameter(array $parameter): array {
    if (isset($parameter['schema']) && is_array($parameter['schema'])) return $parameter['schema'];
    $schema = ['type' => $parameter['type'] ?? 'string'];
    foreach (['format', 'items', 'enum', 'minimum', 'maximum', 'minLength', 'maxLength', 'pattern'] as $key) {
        if (isset($parameter[$key])) $schema[$key] = $parameter[$key];
    }
    return $schema;
}

function parseGraphqlSchema(string $document): array {
    $types = parseGraphqlTypes($document);
    $paths = [];
    foreach (['Query' => 'query', 'Mutation' => 'mutation'] as $typeName => $operationType) {
        foreach (($types[$typeName] ?? []) as $field => $definition) {
            $operationId = $operationType . ucfirst($field);
            $paths["/__graphql/{$operationId}"]['post'] = [
                'operationId' => $operationId,
                'tags' => [$operationType],
                'x-graphql-endpoint-path' => '',
                'x-graphql-field' => $field,
                'x-graphql-operation' => $operationType,
                'x-graphql-args' => $definition['args'],
                'x-graphql-return' => $definition['return'],
                'x-graphql-types' => $types,
                'requestBody' => ['content' => ['application/json' => ['schema' => ['type' => 'object']]]],
                'responses' => [
                    '200' => [
                        'description' => 'GraphQL response',
                        'content' => ['application/json' => ['schema' => ['type' => 'object']]]
                    ]
                ]
            ];
        }
    }
    return [
        'openapi' => '3.0.0',
        'x-graphql' => true,
        'x-specification' => 'GraphQL SDL',
        'servers' => [],
        'paths' => $paths,
        'components' => ['schemas' => []]
    ];
}

function parseGraphqlTypes(string $document): array {
    $types = [];
    if (!preg_match_all('/type\s+(\w+)\s*\{([^}]*)\}/s', $document, $matches, PREG_SET_ORDER)) return $types;
    foreach ($matches as $match) {
        $typeName = $match[1];
        $fields = [];
        foreach (preg_split('/\r\n|\n|\r/', trim($match[2])) ?: [] as $line) {
            $line = trim(preg_replace('/#.*/', '', $line));
            if ($line === '' || !str_contains($line, ':')) continue;
            if (!preg_match('/^(\w+)\s*(?:\(([^)]*)\))?\s*:\s*([!\[\]\w]+)/', $line, $fieldMatch)) continue;
            $fields[$fieldMatch[1]] = [
                'args' => parseGraphqlArgs($fieldMatch[2] ?? ''),
                'return' => trim($fieldMatch[3])
            ];
        }
        $types[$typeName] = $fields;
    }
    return $types;
}

function parseGraphqlArgs(string $args): array {
    $result = [];
    foreach (array_filter(array_map('trim', explode(',', $args))) as $arg) {
        if (!str_contains($arg, ':')) continue;
        [$name, $type] = array_map('trim', explode(':', $arg, 2));
        $result[$name] = $type;
    }
    return $result;
}

function parseSimpleYaml(string $document): array {
    $lines = preg_split('/\r\n|\n|\r/', $document) ?: [];
    $index = 0;
    $parsed = parseYamlBlock($lines, $index, 0);
    return is_array($parsed) ? $parsed : [];
}

function parseYamlBlock(array $lines, int &$index, int $indent) {
    $result = [];
    $isList = null;
    $count = count($lines);

    while ($index < $count) {
        $raw = rtrim($lines[$index]);
        if (trim($raw) === '' || str_starts_with(ltrim($raw), '#')) {
            $index++;
            continue;
        }
        $currentIndent = strlen($raw) - strlen(ltrim($raw, ' '));
        if ($currentIndent < $indent) break;
        if ($currentIndent > $indent) break;

        $line = ltrim($raw);
        if (str_starts_with($line, '- ')) {
            if ($isList === false) break;
            $isList = true;
            $item = substr($line, 2);
            $index++;
            $result[] = parseYamlValueOrNested($item, $lines, $index, $indent + 2);
            continue;
        }

        if ($isList === true || !str_contains($line, ':')) break;
        $isList = false;
        [$key, $value] = explode(':', $line, 2);
        $index++;
        $result[trim($key, "\"' ")] = parseYamlValueOrNested(ltrim($value), $lines, $index, $indent + 2);
    }

    return $result;
}

function parseYamlValueOrNested(string $value, array $lines, int &$index, int $indent) {
    $value = stripYamlComment($value);
    if ($value === '') return parseYamlBlock($lines, $index, $indent);
    if (str_contains($value, ': ') && !str_starts_with($value, '"') && !str_starts_with($value, "'")) {
        [$key, $nestedValue] = explode(':', $value, 2);
        return [trim($key, "\"' ") => parseYamlScalar(trim($nestedValue))];
    }
    return parseYamlScalar($value);
}

function stripYamlComment(string $value): string {
    $inSingle = false;
    $inDouble = false;
    $length = strlen($value);
    for ($i = 0; $i < $length; $i++) {
        $char = $value[$i];
        if ($char === "'" && !$inDouble) $inSingle = !$inSingle;
        elseif ($char === '"' && !$inSingle) $inDouble = !$inDouble;
        elseif ($char === '#' && !$inSingle && !$inDouble && ($i === 0 || ctype_space($value[$i - 1]))) {
            return trim(substr($value, 0, $i));
        }
    }
    return trim($value);
}

function parseYamlScalar(string $value) {
    $value = trim($value);
    if ($value === 'null' || $value === '~') return null;
    if ($value === 'true') return true;
    if ($value === 'false') return false;
    if (is_numeric($value)) return str_contains($value, '.') ? (float)$value : (int)$value;
    if ((str_starts_with($value, '"') && str_ends_with($value, '"')) || (str_starts_with($value, "'") && str_ends_with($value, "'"))) {
        return stripcslashes(substr($value, 1, -1));
    }
    if (str_starts_with($value, '[') && str_ends_with($value, ']')) {
        $json = json_decode($value, true);
        if (is_array($json)) return $json;
        $inner = trim(substr($value, 1, -1));
        if ($inner === '') return [];
        return array_map(fn(string $item) => parseYamlScalar($item), array_map('trim', explode(',', $inner)));
    }
    if (str_starts_with($value, '{') && str_ends_with($value, '}')) {
        $json = json_decode($value, true);
        if (is_array($json)) return $json;
    }
    return $value;
}

function httpRequest(string $method, string $url, array $headers, ?string $body, float $timeout, array $transport = []): array {
    $ch = curl_init($url);
    $curlOptions = [
        CURLOPT_CUSTOMREQUEST => $method,
        CURLOPT_RETURNTRANSFER => true,
        CURLOPT_HEADER => true,
        CURLOPT_FOLLOWLOCATION => ((int)($transport['max_redirects'] ?? 0)) > 0,
        CURLOPT_MAXREDIRS => (int)($transport['max_redirects'] ?? 0),
        CURLOPT_CONNECTTIMEOUT => min(5.0, $timeout),
        CURLOPT_TIMEOUT => $timeout,
        CURLOPT_HTTPHEADER => $headers
    ];
    if (!empty($transport['proxy'])) $curlOptions[CURLOPT_PROXY] = (string)$transport['proxy'];
    $tlsVerify = $transport['tls_verify'] ?? true;
    if ($tlsVerify === false) {
        $curlOptions[CURLOPT_SSL_VERIFYPEER] = false;
        $curlOptions[CURLOPT_SSL_VERIFYHOST] = false;
    } elseif (is_string($tlsVerify)) {
        $curlOptions[CURLOPT_CAINFO] = $tlsVerify;
    }
    if (!empty($transport['request_cert'])) $curlOptions[CURLOPT_SSLCERT] = (string)$transport['request_cert'];
    if (!empty($transport['request_cert_key'])) $curlOptions[CURLOPT_SSLKEY] = (string)$transport['request_cert_key'];
    curl_setopt_array($ch, $curlOptions);
    if ($body !== null) curl_setopt($ch, CURLOPT_POSTFIELDS, $body);
    $started = microtime(true);
    $raw = curl_exec($ch);
    $duration = microtime(true) - $started;
    if ($raw === false) {
        $error = curl_error($ch);
        curl_close($ch);
        throw new RuntimeException($error);
    }
    $headerSize = curl_getinfo($ch, CURLINFO_HEADER_SIZE);
    $status = (int)curl_getinfo($ch, CURLINFO_RESPONSE_CODE);
    $rawHeaders = substr($raw, 0, $headerSize);
    $responseBody = substr($raw, $headerSize);
    curl_close($ch);

    $parsedHeaders = [];
    foreach (preg_split('/\r\n|\n|\r/', trim($rawHeaders)) as $line) {
        if (!str_contains($line, ':')) continue;
        [$name, $value] = explode(':', $line, 2);
        $parsedHeaders[strtolower(trim($name))] = trim($value);
    }
    return ['status' => $status, 'headers' => $parsedHeaders, 'body' => $responseBody, 'duration' => $duration];
}

function baseUrlFromSchema(array $schema, ?string $override): string {
    if ($override) return rtrim($override, '/');
    if (($schema['x-graphql'] ?? false) === true) throw new RuntimeException('GraphQL SDL has no server URL; pass --url with the GraphQL endpoint');
    $server = $schema['servers'][0]['url'] ?? null;
    if (!$server) throw new RuntimeException('schema has no servers[0].url; pass --url');
    return rtrim((string)$server, '/');
}

function specificationLabel(array $schema): string {
    if (isset($schema['x-specification'])) return (string)$schema['x-specification'];
    if (isset($schema['openapi'])) return 'OpenAPI ' . (string)$schema['openapi'];
    if (isset($schema['swagger'])) return 'Swagger ' . (string)$schema['swagger'];
    return 'unknown';
}

function collectOperations(array $schema): array {
    $operations = [];
    $components = $schema['components'] ?? [];
    foreach (($schema['paths'] ?? []) as $path => $pathItem) {
        if (!is_array($pathItem)) continue;
        $pathParameters = array_values(array_filter($pathItem['parameters'] ?? [], 'is_array'));
        foreach (HTTP_OPERATION_METHODS as $method) {
            if (!isset($pathItem[$method]) || !is_array($pathItem[$method])) continue;
            $operation = $pathItem[$method];
            $operation['parameters'] = mergeOperationParameters($pathParameters, array_values(array_filter($operation['parameters'] ?? [], 'is_array')), $components);
            $operations[] = [
                'method' => strtoupper($method),
                'method_key' => $method,
                'path' => $path,
                'path_item' => $pathItem,
                'operation' => $operation
            ];
        }
    }
    return $operations;
}

function mergeOperationParameters(array $pathParameters, array $operationParameters, array $components): array {
    $merged = [];
    foreach (array_merge($pathParameters, $operationParameters) as $parameter) {
        $parameter = resolveParameterRef($parameter, $components);
        $key = ($parameter['in'] ?? '') . ':' . ($parameter['name'] ?? '');
        if ($key === ':') continue;
        $merged[$key] = $parameter;
    }
    return array_values($merged);
}

function resolveParameterRef(array $parameter, array $components): array {
    if (!isset($parameter['$ref'])) return $parameter;
    $prefix = '#/components/parameters/';
    $ref = (string)$parameter['$ref'];
    if (!str_starts_with($ref, $prefix)) return $parameter;
    $name = substr($ref, strlen($prefix));
    return $components['parameters'][$name] ?? $parameter;
}

function filterOperations(array $operations, array $options, array &$warnings): array {
    $selected = [];
    foreach ($operations as $operation) {
        if (operationIncluded($operation, $options, $warnings)) $selected[] = $operation;
    }
    return $selected;
}

function operationIncluded(array $operation, array $options, array &$warnings): bool {
    if (($options['exclude-deprecated'] ?? false) && ($operation['operation']['deprecated'] ?? false)) return false;

    foreach (['path', 'method', 'name', 'tag', 'operation-id'] as $type) {
        $include = optionValues($options, "include-{$type}");
        if ($include && !operationMatchesAny($operation, $type, $include, false, $warnings)) return false;

        $includeRegex = optionValues($options, "include-{$type}-regex");
        if ($includeRegex && !operationMatchesAny($operation, $type, $includeRegex, true, $warnings)) return false;

        $exclude = optionValues($options, "exclude-{$type}");
        if ($exclude && operationMatchesAny($operation, $type, $exclude, false, $warnings)) return false;

        $excludeRegex = optionValues($options, "exclude-{$type}-regex");
        if ($excludeRegex && operationMatchesAny($operation, $type, $excludeRegex, true, $warnings)) return false;
    }

    foreach (optionValues($options, 'include-by') as $expression) {
        $matches = operationMatchesExpression($operation, $expression, $warnings);
        if ($matches === false) return false;
    }
    foreach (optionValues($options, 'exclude-by') as $expression) {
        $matches = operationMatchesExpression($operation, $expression, $warnings);
        if ($matches === true) return false;
    }

    return true;
}

function optionValues(array $options, string $name): array {
    if (!isset($options[$name]) || $options[$name] === true) return [];
    $value = $options[$name];
    if (!is_array($value)) $value = [$value];
    return array_values(array_filter(array_map('strval', $value), fn(string $item) => $item !== ''));
}

function operationMatchesAny(array $operation, string $type, array $needles, bool $regex, array &$warnings): bool {
    $values = operationFilterValues($operation, $type);
    foreach ($needles as $needle) {
        foreach ($values as $value) {
            if ($regex) {
                if (@preg_match('/' . str_replace('/', '\/', $needle) . '/', '') === false) {
                    $warnings[] = "Ignoring invalid regex filter '{$needle}'.";
                    continue 2;
                }
                if (preg_match('/' . str_replace('/', '\/', $needle) . '/', $value)) return true;
            } elseif (strcasecmp($value, $needle) === 0) {
                return true;
            }
        }
    }
    return false;
}

function operationFilterValues(array $operation, string $type): array {
    return match ($type) {
        'path' => [$operation['path']],
        'method' => [$operation['method']],
        'name' => [$operation['method'] . ' ' . $operation['path']],
        'tag' => array_map('strval', $operation['operation']['tags'] ?? []),
        'operation-id' => isset($operation['operation']['operationId']) ? [(string)$operation['operation']['operationId']] : [],
        default => []
    };
}

function operationMatchesExpression(array $operation, string $expression, array &$warnings): ?bool {
    if (!preg_match('/^\s*(\/\S*)\s*(==|!=)\s*(.+?)\s*$/', $expression, $match)) {
        $warnings[] = "Ignoring unsupported filter expression '{$expression}'.";
        return null;
    }
    $document = array_merge($operation['operation'], [
        'path' => $operation['path'],
        'method' => $operation['method'],
        'operation' => $operation['operation']
    ]);
    $actual = jsonPointer($document, $match[1]);
    $expected = trim($match[3]);
    if ((str_starts_with($expected, "'") && str_ends_with($expected, "'")) || (str_starts_with($expected, '"') && str_ends_with($expected, '"'))) {
        $expected = substr($expected, 1, -1);
    }
    $matches = (string)$actual === $expected;
    return $match[2] === '!=' ? !$matches : $matches;
}

function jsonPointer($document, string $pointer) {
    if ($pointer === '') return $document;
    $current = $document;
    foreach (explode('/', ltrim($pointer, '/')) as $segment) {
        $segment = str_replace(['~1', '~0'], ['/', '~'], $segment);
        if (is_array($current) && array_key_exists($segment, $current)) {
            $current = $current[$segment];
        } else {
            return null;
        }
    }
    return is_scalar($current) || $current === null ? $current : json_encode($current);
}

function runExamplesPhase(array $operations, array &$state): array {
    $result = ['passed' => 0, 'failed' => 0, 'skipped' => 0];
    foreach ($operations as $operation) {
        runCase($operation, $state, 'examples', requestBodyPayload($operation['operation'], $state['components'], 'positive', true), true, $result);
        if (failureLimitReached($state)) break;
    }
    return $result;
}

function runCoveragePhase(array $operations, array &$state): array {
    $result = ['passed' => 0, 'failed' => 0, 'skipped' => 0];
    foreach ($operations as $operation) {
        runCase($operation, $state, 'coverage', requestBodyPayload($operation['operation'], $state['components'], 'positive', true), true, $result);
        if (!failureLimitReached($state)) runInvalidPathCase($operation, $state, $result);
        if (!failureLimitReached($state)) runMissingRequiredHeaderCases($operation, $state, $result);
        if (!failureLimitReached($state)) runIgnoredAuthCases($operation, $state, $result);
        if (!failureLimitReached($state)) runUnsupportedMethodCase($operation, $state, $result);
        if (failureLimitReached($state)) break;
    }
    return $result;
}

function runFuzzingPhase(array $operations, array &$state, int $maxExamples, ?float $deadline = null): array {
    $result = ['passed' => 0, 'failed' => 0, 'skipped' => 0];
    $modes = match ($state['mode'] ?? 'positive') {
        'negative' => ['negative'],
        'all' => ['positive', 'negative'],
        default => ['positive']
    };
    foreach ($operations as $operation) {
        for ($i = 0; $i < $maxExamples; $i++) {
            if ($deadline !== null && microtime(true) >= $deadline) break 2;
            foreach ($modes as $mode) {
                if ($mode === 'negative' && !operationHasInput($operation['operation'])) {
                    $result['skipped']++;
                    continue;
                }
                runCase($operation, $state, 'fuzzing', requestBodyPayload($operation['operation'], $state['components'], $mode, false), false, $result, $mode);
                if (failureLimitReached($state)) break 3;
                if ($deadline !== null && microtime(true) >= $deadline) break 3;
            }
        }
    }
    return $result;
}

function operationHasInput(array $operation): bool {
    if (isset($operation['requestBody'])) return true;
    foreach (operationParameters($operation) as $parameter) {
        if (in_array($parameter['in'] ?? '', ['path', 'query', 'header', 'cookie'], true)) return true;
    }
    return false;
}

function runStatefulPhase(array $operations, array &$state, int $maxExamples, ?float $deadline = null): array {
    $result = ['passed' => 0, 'failed' => 0, 'skipped' => 0];
    $iterations = max(1, min($maxExamples, 25));
    $orderedOperations = orderStatefulOperations($operations);
    for ($i = 0; $i < $iterations; $i++) {
        foreach ($orderedOperations as $operation) {
            if ($deadline !== null && microtime(true) >= $deadline) return $result;
            $context = statefulContextForOperation($operation, $state);
            $case = runCase($operation, $state, 'stateful', requestBodyPayload($operation['operation'], $state['components'], 'positive', false), false, $result, 'positive', $context);
            if ($case !== null) {
                runEnsureResourceAvailabilityChecks($operation, $case, $operations, $state, $result);
                runUseAfterFreeChecks($operation, $case, $operations, $state, $result, $context);
            }
            if (failureLimitReached($state)) return $result;
        }
    }
    return $result;
}

function orderStatefulOperations(array $operations): array {
    $rank = ['POST' => 0, 'PUT' => 1, 'PATCH' => 2, 'GET' => 3, 'DELETE' => 4];
    usort($operations, fn(array $a, array $b): int => ($rank[$a['method']] ?? 9) <=> ($rank[$b['method']] ?? 9));
    return $operations;
}

function statefulContextForOperation(array $operation, array $state): array {
    $pathParameters = [];
    $queryParameters = [];
    foreach (operationParameters($operation['operation']) as $parameter) {
        $name = (string)($parameter['name'] ?? '');
        if ($name === '') continue;
        $value = resourceValueForParameter($name, $state);
        if ($value === null) continue;
        if (($parameter['in'] ?? '') === 'path') $pathParameters[$name] = $value;
        elseif (($parameter['in'] ?? '') === 'query') $queryParameters[$name] = $value;
    }
    return ['path_parameters' => $pathParameters, 'query_parameters' => $queryParameters];
}

function resourceValueForParameter(string $name, array $state) {
    $candidates = parameterResourceNames($name);
    foreach ($candidates as $candidate) {
        if (!empty($state['resource_values'][$candidate])) return end($state['resource_values'][$candidate]);
    }
    return null;
}

function parameterResourceNames(string $name): array {
    $normalized = strtolower(preg_replace('/[^a-zA-Z0-9]/', '', $name));
    $names = [$name, $normalized];
    if (str_ends_with($normalized, 'id')) {
        $names[] = 'id';
        $names[] = substr($normalized, 0, -2) . 'id';
    }
    return array_values(array_unique(array_filter($names)));
}

function runEnsureResourceAvailabilityChecks(array $producer, array $case, array $operations, array &$state, array &$result): void {
    if (!in_array('ensure_resource_availability', $state['checks'], true)) return;
    if ($producer['method'] !== 'POST' || !isSuccessfulResponse($case['response'] ?? null)) return;
    foreach (linkedGetOperations($producer, $case, $operations, $state) as [$consumer, $context]) {
        executeProbeCase(
            $consumer,
            $state,
            'stateful',
            requestBodyPayload($consumer['operation'], $state['components'], 'positive', false),
            false,
            'positive',
            $context,
            function(array $response) use ($consumer): ?string {
                return $response['status'] === 404
                    ? "created resource was not available through {$consumer['method']} {$consumer['path']}"
                    : null;
            },
            $result
        );
        if (failureLimitReached($state)) return;
    }
}

function runUseAfterFreeChecks(array $operation, array $case, array $operations, array &$state, array &$result, array $context): void {
    if (!in_array('use_after_free', $state['checks'], true)) return;
    if ($operation['method'] !== 'DELETE' || !isSuccessfulResponse($case['response'] ?? null)) return;
    $reader = findOperation($operations, 'GET', $operation['path']);
    if ($reader === null) return;
    executeProbeCase(
        $reader,
        $state,
        'stateful',
        requestBodyPayload($reader['operation'], $state['components'], 'positive', false),
        false,
        'positive',
        $context,
        function(array $response) use ($reader): ?string {
            return $response['status'] === 404
                ? null
                : "deleted resource remained available through {$reader['method']} {$reader['path']} with HTTP {$response['status']}";
        },
        $result
    );
}

function linkedGetOperations(array $producer, array $case, array $operations, array $state): array {
    $linked = [];
    $location = $case['response']['headers']['location'] ?? null;
    if (is_string($location)) {
        foreach ($operations as $operation) {
            if ($operation['method'] !== 'GET') continue;
            $params = parametersFromConcretePath(parse_url($location, PHP_URL_PATH) ?: $location, $operation['path']);
            if ($params !== null) $linked[] = [$operation, ['path_parameters' => $params]];
        }
    }

    $sourceOperationId = $producer['operation']['operationId'] ?? null;
    foreach (($state['stateful_links'][$sourceOperationId] ?? []) as $link) {
        $target = findOperationById($operations, $link['operationId'] ?? '');
        if ($target === null || $target['method'] !== 'GET') continue;
        $params = [];
        foreach (($link['parameters'] ?? []) as $name => $expression) {
            $params[(string)$name] = extractLinkValue($expression, $case);
        }
        $linked[] = [$target, ['path_parameters' => array_filter($params, fn($value) => $value !== null)]];
    }

    if (!$linked) {
        foreach ($operations as $operation) {
            if ($operation['method'] !== 'GET') continue;
            $context = statefulContextForOperation($operation, $state);
            if (($context['path_parameters'] ?? []) || ($context['query_parameters'] ?? [])) $linked[] = [$operation, $context];
        }
    }
    return $linked;
}

function parametersFromConcretePath(string $actualPath, string $template): ?array {
    $names = [];
    $pattern = '';
    $offset = 0;
    while (preg_match('/\{([^}]+)\}/', $template, $match, PREG_OFFSET_CAPTURE, $offset)) {
        $start = $match[0][1];
        $pattern .= preg_quote(substr($template, $offset, $start - $offset), '#');
        $name = $match[1][0];
        $key = preg_replace('/\W/', '_', $name);
        $names[$key] = $name;
        $pattern .= '(?P<' . $key . '>[^/]+)';
        $offset = $start + strlen($match[0][0]);
    }
    $pattern .= preg_quote(substr($template, $offset), '#');
    $pattern = '#^' . $pattern . '$#';
    if (!preg_match($pattern, $actualPath, $matches)) return null;
    $params = [];
    foreach ($names as $key => $name) {
        if (isset($matches[$key])) $params[$name] = rawurldecode($matches[$key]);
    }
    return $params;
}

function findOperation(array $operations, string $method, string $path): ?array {
    foreach ($operations as $operation) {
        if ($operation['method'] === $method && $operation['path'] === $path) return $operation;
    }
    return null;
}

function findOperationById(array $operations, string $operationId): ?array {
    foreach ($operations as $operation) {
        if (($operation['operation']['operationId'] ?? null) === $operationId) return $operation;
    }
    return null;
}

function isSuccessfulResponse(?array $response): bool {
    $status = (int)($response['status'] ?? 0);
    return $status >= 200 && $status < 300;
}

function exampleRequestBody(array $operation): ?string {
    $json = $operation['requestBody']['content']['application/json'] ?? null;
    if (!$json) return null;
    if (array_key_exists('example', $json)) return json_encode($json['example']);
    return '{}';
}

function generatedRequestBody(array $operation, array $components, string $mode = 'positive'): ?string {
    return requestBodyPayload($operation, $components, $mode, false)['body'];
}

function requestBodyPayload(array $operation, array $components, string $mode, bool $useExamples): array {
    if (isset($operation['x-graphql-field'])) {
        return [
            'body' => json_encode(['query' => graphqlQueryForOperation($operation, $components, $mode)]),
            'content_type' => 'application/json'
        ];
    }

    $content = $operation['requestBody']['content'] ?? [];
    if (!is_array($content) || !$content) return ['body' => null, 'content_type' => null];
    [$mediaType, $media] = selectRequestMediaType($content);
    $schema = is_array($media) ? ($media['schema'] ?? ['type' => 'object']) : ['type' => 'object'];

    if ($useExamples && is_array($media) && array_key_exists('example', $media)) {
        $value = $media['example'];
    } elseif ($useExamples && is_array($media) && isset($media['examples']) && is_array($media['examples']) && $media['examples']) {
        $example = reset($media['examples']);
        $value = is_array($example) && array_key_exists('value', $example) ? $example['value'] : $example;
    } else {
        $value = $mode === 'negative' ? generateInvalidValue($schema, $components) : generateValue($schema, $components);
    }

    if (isJsonMediaType($mediaType)) {
        return ['body' => json_encode($value), 'content_type' => $mediaType];
    }
    if ($mediaType === 'application/x-www-form-urlencoded') {
        return ['body' => http_build_query(is_array($value) ? $value : ['value' => $value]), 'content_type' => $mediaType];
    }
    if ($mediaType === 'multipart/form-data') {
        return multipartPayload(is_array($value) ? $value : ['value' => $value]);
    }
    if (str_starts_with($mediaType, 'text/')) {
        return ['body' => scalarParameterValue($value), 'content_type' => $mediaType];
    }
    if ($mediaType === 'application/octet-stream') {
        return ['body' => is_string($value) ? $value : random_bytes(8), 'content_type' => $mediaType];
    }
    return ['body' => is_string($value) ? $value : json_encode($value), 'content_type' => $mediaType];
}

function normalizePayload($payload): array {
    if (is_array($payload) && array_key_exists('body', $payload)) {
        return ['body' => $payload['body'], 'content_type' => $payload['content_type'] ?? null];
    }
    return ['body' => $payload, 'content_type' => $payload === null ? null : 'application/json'];
}

function selectRequestMediaType(array $content): array {
    foreach (['application/json', 'application/x-www-form-urlencoded', 'multipart/form-data', 'text/plain', 'application/octet-stream'] as $preferred) {
        if (isset($content[$preferred])) return [$preferred, $content[$preferred]];
    }
    foreach ($content as $mediaType => $media) return [(string)$mediaType, $media];
    return ['application/json', ['schema' => ['type' => 'object']]];
}

function isJsonMediaType(string $mediaType): bool {
    if (in_array(strtolower($mediaType), JSON_MEDIA_TYPES, true)) return true;
    return str_ends_with(strtolower($mediaType), '+json');
}

function multipartPayload(array $fields): array {
    $boundary = '----openapi-contract-' . bin2hex(random_bytes(8));
    $lines = [];
    foreach ($fields as $name => $value) {
        $lines[] = "--{$boundary}";
        $lines[] = 'Content-Disposition: form-data; name="' . addcslashes((string)$name, '"\\') . '"';
        $lines[] = '';
        $lines[] = scalarParameterValue($value);
    }
    $lines[] = "--{$boundary}--";
    return ['body' => implode("\r\n", $lines) . "\r\n", 'content_type' => 'multipart/form-data; boundary=' . $boundary];
}

function graphqlQueryForOperation(array $operation, array $components, string $mode): string {
    $operationType = (string)($operation['x-graphql-operation'] ?? 'query');
    $field = (string)($operation['x-graphql-field'] ?? 'field');
    $args = [];
    foreach (($operation['x-graphql-args'] ?? []) as $name => $type) {
        $args[] = $name . ': ' . graphqlLiteral(graphqlValueForType((string)$type, $mode));
    }
    $selection = graphqlSelectionForType((string)($operation['x-graphql-return'] ?? 'String'), $operation['x-graphql-types'] ?? []);
    return trim($operationType . ' { ' . $field . ($args ? '(' . implode(', ', $args) . ')' : '') . $selection . ' }');
}

function graphqlValueForType(string $type, string $mode) {
    $clean = trim($type, "[]! \t\n\r\0\x0B");
    if ($mode === 'negative') return match ($clean) {
        'Int', 'Float', 'Boolean', 'ID' => '"invalid"',
        default => 12345
    };
    return match ($clean) {
        'Int' => mt_rand(1, 100),
        'Float' => mt_rand(1, 100) / 10,
        'Boolean' => (bool)mt_rand(0, 1),
        'ID' => (string)mt_rand(1, 100),
        default => 'value' . mt_rand(1, 100)
    };
}

function graphqlLiteral($value): string {
    if (is_bool($value)) return $value ? 'true' : 'false';
    if (is_int($value) || is_float($value)) return (string)$value;
    return json_encode((string)$value);
}

function graphqlSelectionForType(string $type, array $types): string {
    $clean = trim($type, "[]! \t\n\r\0\x0B");
    if (!isset($types[$clean]) || in_array($clean, ['String', 'ID', 'Int', 'Float', 'Boolean'], true)) return '';
    $fields = [];
    foreach ($types[$clean] as $name => $definition) {
        $return = trim((string)($definition['return'] ?? ''), "[]! \t\n\r\0\x0B");
        if (in_array($return, ['String', 'ID', 'Int', 'Float', 'Boolean'], true)) $fields[] = $name;
        if (count($fields) >= 5) break;
    }
    return $fields ? ' { ' . implode(' ', $fields) . ' }' : ' { __typename }';
}

function runCase(array $op, array &$state, string $phase, $payload, bool $useExamples, array &$result, string $caseMode = 'positive', array $context = []): ?array {
    $method = $op['method'];
    $payload = normalizePayload($payload);
    $path = concretePath($op['path'], $op['operation'], $useExamples, $state['components'], $context['path_parameters'] ?? []);
    if (isset($op['operation']['x-graphql-endpoint-path'])) $path = (string)$op['operation']['x-graphql-endpoint-path'];
    $query = queryString($op['operation'], $state['components'], $useExamples, $caseMode, $context['query_parameters'] ?? [], $state['schema'], $state['options']);
    $pathQuery = $path . $query;
    $url = $state['base_url'] . $pathQuery;
    $headers = $context['headers'] ?? $state['headers'];
    foreach (operationParameterHeaders($op['operation'], $state['components'], $useExamples, $caseMode, $context['skip_headers'] ?? []) as $header) $headers[] = $header;
    foreach (apiKeyCookieHeaders($state['schema'], $state['options']) as $header) $headers[] = $header;
    if ($payload['body'] !== null && $payload['content_type'] !== null && !hasHeader($headers, 'content-type')) $headers[] = 'Content-Type: ' . $payload['content_type'];
    $body = $payload['body'];
    $request = buildRequestRecord($phase, $op, $method, $url, $pathQuery, $headers, $body, $caseMode);

    try {
        $response = requestWithState($method, $url, $headers, $body, $state);
    } catch (Throwable $e) {
        $case = recordCase($state, $request, null, "{$phase} {$method} {$op['path']} request failed: {$e->getMessage()}");
        recordFailure($state, $result, "{$phase} {$method} {$op['path']} request failed: {$e->getMessage()}", $case);
        return $case;
    }

    $state['cases']++;
    $failure = validateResponse($op, $response, $state['components'], $state['checks'], $state['max_response_time'], $caseMode);
    if ($failure && $caseMode === 'positive' && $phase === 'fuzzing' && !($state['options']['no-shrink'] ?? false)) {
        [$body, $response, $failure] = shrinkFailingPayload($op, $state, $headers, $pathQuery, $payload, $response, $failure, $caseMode);
        $request['body'] = $body;
    }
    $case = recordCase($state, $request, $response, $failure);
    learnFromCase($state, $case);
    if ($failure) {
        recordFailure($state, $result, "{$phase} {$method} {$op['path']}: {$failure}", $case);
    } else {
        $result['passed']++;
    }
    return $case;
}

function shrinkFailingPayload(array $op, array &$state, array $headers, string $pathQuery, array $payload, array $currentResponse, string $currentFailure, string $caseMode): array {
    if ($payload['body'] === null || !isset($payload['content_type']) || !isJsonMediaType((string)$payload['content_type'])) {
        return [$payload['body'], $currentResponse, $currentFailure];
    }
    $decoded = json_decode((string)$payload['body'], true);
    if (!is_array($decoded)) return [$payload['body'], $currentResponse, $currentFailure];
    $bestBody = (string)$payload['body'];
    $bestResponse = $currentResponse;
    $bestFailure = $currentFailure;
    foreach (shrinkCandidates($decoded) as $candidate) {
        $body = json_encode($candidate);
        try {
            $response = requestWithState($op['method'], $state['base_url'] . $pathQuery, $headers, $body, $state);
        } catch (Throwable) {
            continue;
        }
        $failure = validateResponse($op, $response, $state['components'], $state['checks'], $state['max_response_time'], $caseMode);
        if ($failure !== null) {
            $bestBody = (string)$body;
            $bestResponse = $response;
            $bestFailure = $failure;
        }
    }
    return [$bestBody, $bestResponse, $bestFailure];
}

function shrinkCandidates(array $value): array {
    $candidates = [];
    if (isAssocArray($value)) {
        foreach (array_keys($value) as $key) {
            $candidate = $value;
            unset($candidate[$key]);
            $candidates[] = $candidate;
        }
        foreach ($value as $key => $item) {
            $candidate = $value;
            $candidate[$key] = minimalValue($item);
            $candidates[] = $candidate;
        }
    } else {
        $candidates[] = [];
        if ($value) $candidates[] = [minimalValue($value[0])];
    }
    return $candidates;
}

function minimalValue($value) {
    if (is_string($value)) return '';
    if (is_int($value) || is_float($value)) return 0;
    if (is_bool($value)) return false;
    if (is_array($value)) return isAssocArray($value) ? [] : [];
    return null;
}

function runInvalidPathCase(array $op, array &$state, array &$result): void {
    if (!str_contains($op['path'], '{')) return;
    $path = preg_replace('/\{[^}]+\}/', 'not-an-id', $op['path'], 1);
    $url = $state['base_url'] . $path;
    $headers = $state['headers'];
    foreach (operationParameterHeaders($op['operation'], $state['components'], true, 'positive') as $header) $headers[] = $header;
    foreach (apiKeyCookieHeaders($state['schema'], $state['options']) as $header) $headers[] = $header;
    $request = buildRequestRecord('coverage', $op, $op['method'], $url, $path, $headers, null);
    try {
        $response = requestWithState($op['method'], $url, $headers, null, $state);
    } catch (Throwable $e) {
        $case = recordCase($state, $request, null, "coverage {$op['method']} {$path} request failed: {$e->getMessage()}");
        recordFailure($state, $result, "coverage {$op['method']} {$path} request failed: {$e->getMessage()}", $case);
        return;
    }
    $state['cases']++;
    $contentType = strtolower($response['headers']['content-type'] ?? '');
    if ($response['status'] === 404 && str_contains($contentType, 'application/json')) {
        recordCase($state, $request, $response, null);
        $result['passed']++;
    } else {
        $failure = "coverage {$op['method']} {$path}: expected JSON 404, got HTTP {$response['status']} {$contentType}";
        $case = recordCase($state, $request, $response, $failure);
        recordFailure($state, $result, $failure, $case);
    }
}

function runMissingRequiredHeaderCases(array $op, array &$state, array &$result): void {
    if (!in_array('missing_required_header', $state['checks'], true)) return;
    foreach (operationParameters($op['operation']) as $parameter) {
        if (($parameter['in'] ?? '') !== 'header' || !($parameter['required'] ?? false)) continue;
        executeProbeCase(
            $op,
            $state,
            'coverage',
            requestBodyPayload($op['operation'], $state['components'], 'positive', true),
            true,
            'negative',
            ['skip_headers' => [strtolower((string)$parameter['name'])]],
            function(array $response) use ($parameter): ?string {
                return ($response['status'] >= 400 && $response['status'] < 500)
                    ? null
                    : "missing required request header '{$parameter['name']}' was accepted with HTTP {$response['status']}";
            },
            $result
        );
        if (failureLimitReached($state)) return;
    }
}

function runIgnoredAuthCases(array $op, array &$state, array &$result): void {
    if (!in_array('ignored_auth', $state['checks'], true) || !operationRequiresAuth($op['operation'], $state['schema'])) return;
    $baseHeaders = stripSecurityHeaders($state['headers'], $state['schema']);
    foreach ([
        'without credentials' => $baseHeaders,
        'with invalid credentials' => mergeHeaders($baseHeaders, invalidSecurityHeaders($state['schema']))
    ] as $label => $headers) {
        executeProbeCase(
            $op,
            $state,
            'coverage',
            requestBodyPayload($op['operation'], $state['components'], 'positive', true),
            true,
            'negative',
            ['headers' => $headers],
            function(array $response) use ($label): ?string {
                return in_array($response['status'], [401, 403], true)
                    ? null
                    : "authenticated operation accepted request {$label}; expected 401 or 403, got HTTP {$response['status']}";
            },
            $result
        );
        if (failureLimitReached($state)) return;
    }
}

function executeProbeCase(array $op, array &$state, string $phase, $payload, bool $useExamples, string $caseMode, array $context, callable $validator, array &$result): ?array {
    $method = $op['method'];
    $payload = normalizePayload($payload);
    $path = concretePath($op['path'], $op['operation'], $useExamples, $state['components'], $context['path_parameters'] ?? []);
    if (isset($op['operation']['x-graphql-endpoint-path'])) $path = (string)$op['operation']['x-graphql-endpoint-path'];
    $query = queryString($op['operation'], $state['components'], $useExamples, $caseMode, $context['query_parameters'] ?? [], $state['schema'], $state['options']);
    $pathQuery = $path . $query;
    $url = $state['base_url'] . $pathQuery;
    $headers = $context['headers'] ?? $state['headers'];
    foreach (operationParameterHeaders($op['operation'], $state['components'], $useExamples, $caseMode, $context['skip_headers'] ?? []) as $header) $headers[] = $header;
    foreach (apiKeyCookieHeaders($state['schema'], $state['options']) as $header) $headers[] = $header;
    if ($payload['body'] !== null && $payload['content_type'] !== null && !hasHeader($headers, 'content-type')) $headers[] = 'Content-Type: ' . $payload['content_type'];
    $request = buildRequestRecord($phase, $op, $method, $url, $pathQuery, $headers, $payload['body'], $caseMode);

    try {
        $response = requestWithState($method, $url, $headers, $payload['body'], $state);
    } catch (Throwable $e) {
        $case = recordCase($state, $request, null, "{$phase} {$method} {$op['path']} probe failed: {$e->getMessage()}");
        recordFailure($state, $result, "{$phase} {$method} {$op['path']} probe failed: {$e->getMessage()}", $case);
        return $case;
    }

    $state['cases']++;
    $failure = $validator($response);
    $case = recordCase($state, $request, $response, $failure);
    learnFromCase($state, $case);
    if ($failure) recordFailure($state, $result, "{$phase} {$method} {$op['path']}: {$failure}", $case);
    else $result['passed']++;
    return $case;
}

function operationRequiresAuth(array $operation, array $schema): bool {
    if (array_key_exists('security', $operation)) return is_array($operation['security']) && $operation['security'] !== [];
    return is_array($schema['security'] ?? null) && $schema['security'] !== [];
}

function runUnsupportedMethodCase(array $op, array &$state, array &$result): void {
    if (!in_array('unsupported_method', $state['checks'], true)) return;
    $allowed = allowedMethodsForPathItem($op['path_item']);
    if (!$allowed) return;
    $path = concretePath($op['path'], $op['operation'], true);
    $url = $state['base_url'] . $path;
    $headers = $state['headers'];
    foreach (operationParameterHeaders($op['operation'], $state['components'], true, 'positive') as $header) $headers[] = $header;
    foreach (apiKeyCookieHeaders($state['schema'], $state['options']) as $header) $headers[] = $header;
    $request = buildRequestRecord('coverage', $op, 'TRACE', $url, $path, $headers, null);
    try {
        $response = requestWithState('TRACE', $url, $headers, null, $state);
    } catch (Throwable $e) {
        $case = recordCase($state, $request, null, "coverage TRACE {$op['path']} request failed: {$e->getMessage()}");
        recordFailure($state, $result, "coverage TRACE {$op['path']} request failed: {$e->getMessage()}", $case);
        return;
    }
    $state['cases']++;
    $allow = $response['headers']['allow'] ?? '';
    $missing = array_filter($allowed, fn($method) => !str_contains($allow, $method));
    if ($response['status'] === 405 && !$missing) {
        recordCase($state, $request, $response, null);
        $result['passed']++;
    } else {
        $failure = "coverage TRACE {$op['path']}: expected 405 with Allow [" . implode(', ', $allowed) . "], got HTTP {$response['status']} Allow '{$allow}'";
        $case = recordCase($state, $request, $response, $failure);
        recordFailure($state, $result, $failure, $case);
    }
}

function requestWithState(string $method, string $url, array $headers, ?string $body, array &$state): array {
    $interval = $state['transport']['rate_limit_interval'] ?? null;
    if ($interval !== null && $state['last_request_at'] !== null) {
        $wait = $interval - (microtime(true) - $state['last_request_at']);
        if ($wait > 0) usleep((int)round($wait * 1000000));
    }

    $retries = (int)($state['transport']['request_retries'] ?? 0);
    $attempt = 0;
    do {
        try {
            $response = httpRequest($method, $url, $headers, $body, $state['timeout'], $state['transport']);
            $state['last_request_at'] = microtime(true);
            return $response;
        } catch (Throwable $e) {
            if ($attempt >= $retries) throw $e;
            usleep((int)(100000 * (2 ** $attempt)));
            $attempt++;
        }
    } while (true);
}

function validateResponse(array $op, array $response, array $components, array $checks, ?float $maxResponseTime, string $caseMode = 'positive'): ?string {
    $status = $response['status'];
    if ($maxResponseTime !== null && ($response['duration'] ?? 0.0) > $maxResponseTime) {
        return sprintf('response time %.6fs exceeded %.6fs', $response['duration'], $maxResponseTime);
    }

    if ($caseMode === 'negative' && in_array('negative_data_rejection', $checks, true) && ($status < 400 || $status >= 500)) {
        return "negative input was not rejected with a 4xx response; got HTTP {$status}";
    }
    if ($caseMode === 'positive' && in_array('positive_data_acceptance', $checks, true) && $status >= 400 && $status < 500 && !isDocumentedResourceMiss($op, $response)) {
        return "positive input was rejected with HTTP {$status}";
    }

    if (in_array('not_a_server_error', $checks, true) && $status >= 500) {
        return "server error HTTP {$status}";
    }

    $responses = $op['operation']['responses'] ?? [];
    $documented = documentedResponseForStatus($responses, $status);
    if (in_array('status_code_conformance', $checks, true) && $documented === null) {
        return "undocumented HTTP {$status}";
    }

    if (!$documented) return null;

    if (in_array('response_headers_conformance', $checks, true)) {
        $headerFailure = validateResponseHeaders($documented['headers'] ?? [], $response['headers'], $components);
        if ($headerFailure !== null) return $headerFailure;
    }

    $contentType = strtolower($response['headers']['content-type'] ?? '');
    $documentedMedia = documentedMediaForContentType($documented['content'] ?? [], $contentType);
    if (in_array('content_type_conformance', $checks, true) && ($documented['content'] ?? []) && $documentedMedia === null) {
        return "undocumented Content-Type '{$contentType}'";
    }
    if ($documentedMedia === null) return null;

    $mediaType = $documentedMedia['media_type'];
    $media = $documentedMedia['media'];
    $value = $response['body'];
    if (isJsonMediaType($mediaType)) {
        if (trim((string)$response['body']) === '') return 'empty JSON response body';
        $decoded = json_decode($response['body'], true);
        if (json_last_error() !== JSON_ERROR_NONE) return 'invalid JSON response body';
        if (isset($op['operation']['x-graphql-field']) && is_array($decoded) && isset($decoded['errors']) && is_array($decoded['errors']) && $decoded['errors']) {
            return 'GraphQL response contains errors';
        }
        $value = $decoded;
    }

    if (in_array('response_schema_conformance', $checks, true)) {
        $errors = validateSchema($value, $media['schema'] ?? [], $components);
        if ($errors) return 'response schema mismatch: ' . $errors[0];
    }
    return null;
}

function isDocumentedResourceMiss(array $op, array $response): bool {
    if ((int)($response['status'] ?? 0) !== 404) return false;
    foreach (operationParameters($op['operation']) as $parameter) {
        if (($parameter['in'] ?? '') === 'path') {
            return documentedResponseForStatus($op['operation']['responses'] ?? [], 404) !== null;
        }
    }
    return false;
}

function documentedMediaForContentType(array $content, string $actualContentType): ?array {
    if (!$content) return null;
    $actual = strtolower(trim(explode(';', $actualContentType)[0] ?? $actualContentType));
    foreach ($content as $mediaType => $media) {
        $candidate = strtolower((string)$mediaType);
        if ($actual === $candidate || ($actual !== '' && str_ends_with($actual, '+json') && str_ends_with($candidate, '+json'))) {
            return ['media_type' => (string)$mediaType, 'media' => is_array($media) ? $media : []];
        }
    }
    if ($actual === '' && isset($content['application/json'])) return ['media_type' => 'application/json', 'media' => $content['application/json']];
    return null;
}

function documentedResponseForStatus(array $responses, int $status): ?array {
    $statusKey = (string)$status;
    $wildcard = substr($statusKey, 0, 1) . 'XX';
    foreach ([$statusKey, $wildcard, strtolower($wildcard), 'default'] as $key) {
        if (isset($responses[$key]) && is_array($responses[$key])) return $responses[$key];
    }
    return null;
}

function validateResponseHeaders(array $documentedHeaders, array $actualHeaders, array $components): ?string {
    foreach ($documentedHeaders as $name => $header) {
        if (!is_array($header)) continue;
        $header = resolveHeaderRef($header, $components);
        $lookup = strtolower((string)$name);
        $present = array_key_exists($lookup, $actualHeaders);

        if (($header['required'] ?? false) && !$present) {
            return "missing required response header '{$name}'";
        }
        if (!$present || !isset($header['schema']) || !is_array($header['schema'])) {
            continue;
        }

        $schema = resolveSchemaRef($header['schema'], $components);
        $value = coerceHeaderValue($actualHeaders[$lookup], $schema, $components);
        $errors = validateSchema($value, $schema, $components, '$headers.' . $name);
        if ($errors) {
            return "response header '{$name}' schema mismatch: {$errors[0]}";
        }
    }
    return null;
}

function resolveHeaderRef(array $header, array $components): array {
    if (!isset($header['$ref'])) return $header;
    $prefix = '#/components/headers/';
    $ref = (string)$header['$ref'];
    if (!str_starts_with($ref, $prefix)) return $header;
    $name = substr($ref, strlen($prefix));
    return $components['headers'][$name] ?? $header;
}

function coerceHeaderValue(string $value, array $schema, array $components) {
    $schema = resolveSchemaRef($schema, $components);
    $type = $schema['type'] ?? null;
    if (is_array($type)) {
        foreach ($type as $candidate) {
            if ($candidate === 'null' && strtolower($value) === 'null') return null;
            $candidateSchema = $schema;
            $candidateSchema['type'] = $candidate;
            $coerced = coerceHeaderValue($value, $candidateSchema, $components);
            if (!validateSchema($coerced, $candidateSchema, $components)) return $coerced;
        }
        return $value;
    }

    return match ($type) {
        'array' => coerceHeaderArray($value, $schema, $components),
        'integer' => preg_match('/^-?\d+$/', $value) ? (int)$value : $value,
        'number' => is_numeric($value) ? (float)$value : $value,
        'boolean' => coerceHeaderBoolean($value),
        default => $value
    };
}

function coerceHeaderArray(string $value, array $schema, array $components): array {
    $itemSchema = $schema['items'] ?? ['type' => 'string'];
    return array_map(
        fn(string $item) => coerceHeaderValue(trim($item), $itemSchema, $components),
        $value === '' ? [] : explode(',', $value)
    );
}

function coerceHeaderBoolean(string $value) {
    return match (strtolower($value)) {
        'true', '1' => true,
        'false', '0' => false,
        default => $value
    };
}

function buildRequestRecord(string $phase, array $op, string $method, string $url, string $pathQuery, array $headers, ?string $body, string $mode = 'positive'): array {
    return [
        'phase' => $phase,
        'mode' => $mode,
        'operation' => $op,
        'method' => $method,
        'url' => $url,
        'path_query' => $pathQuery,
        'headers' => $headers,
        'body' => $body
    ];
}

function recordCase(array &$state, array $request, ?array $response, ?string $failure): array {
    $id = caseId($request, $response, $failure, count($state['case_records'] ?? []));
    $sanitize = (bool)($state['output_sanitize'] ?? true);
    $truncate = (bool)($state['output_truncate'] ?? true);
    $normalizedRequest = normalizeRequestForRecord($request, $sanitize, $truncate);
    $case = [
        'id' => $id,
        'time' => gmdate('c'),
        'schema_location' => $state['schema_location'] ?? null,
        'base_url' => $state['base_url'] ?? null,
        'checks' => $state['checks'] ?? [],
        'max_response_time' => $state['max_response_time'] ?? null,
        'components' => $state['components'] ?? [],
        'request' => $normalizedRequest,
        'response' => normalizeResponseForRecord($response, $sanitize, $truncate),
        'failure' => $failure,
        'curl' => curlCommandFromRequest($normalizedRequest)
    ];
    $state['case_records'][] = $case;
    return $case;
}

function caseId(array $request, ?array $response, ?string $failure, int $index): string {
    return substr(hash('sha256', json_encode([
        $request['method'] ?? '',
        $request['url'] ?? '',
        $request['body'] ?? '',
        $response['status'] ?? null,
        $failure,
        microtime(true),
        $index,
        random_int(1, PHP_INT_MAX)
    ])), 0, 12);
}

function normalizeRequestForRecord(array $request, bool $sanitize, bool $truncate): array {
    $request['headers'] = normalizeHeadersForRecord($request['headers'] ?? [], $sanitize);
    if (isset($request['body']) && is_string($request['body'])) $request['body'] = normalizeBodyForRecord($request['body'], $sanitize, $truncate);
    return $request;
}

function curlCommandFromRequest(array $request): string {
    $parts = ['curl', '-i', '-sS', '-X', escapeshellarg((string)($request['method'] ?? 'GET')), escapeshellarg((string)($request['url'] ?? ''))];
    foreach (($request['headers'] ?? []) as $header) {
        $header = trim((string)$header);
        if ($header === '' || !str_contains($header, ':')) continue;
        $parts[] = '-H';
        $parts[] = escapeshellarg($header);
    }
    if (array_key_exists('body', $request) && $request['body'] !== null) {
        $parts[] = '--data-raw';
        $parts[] = escapeshellarg((string)$request['body']);
    }
    return implode(' ', $parts);
}

function normalizeResponseForRecord(?array $response, bool $sanitize = true, bool $truncate = true): ?array {
    if ($response === null) return null;
    return [
        'status' => $response['status'] ?? 0,
        'headers' => normalizeAssocHeadersForRecord($response['headers'] ?? [], $sanitize),
        'body' => normalizeBodyForRecord((string)($response['body'] ?? ''), $sanitize, $truncate),
        'duration' => $response['duration'] ?? 0.0
    ];
}

function normalizeHeadersForRecord(array $headers, bool $sanitize): array {
    if (!$sanitize) return $headers;
    return array_map(function($header) {
        if (!str_contains((string)$header, ':')) return $header;
        [$name, $value] = explode(':', (string)$header, 2);
        return isSensitiveHeader($name) ? trim($name) . ': [redacted]' : trim($name) . ':' . $value;
    }, $headers);
}

function normalizeAssocHeadersForRecord(array $headers, bool $sanitize): array {
    if (!$sanitize) return $headers;
    foreach ($headers as $name => $value) {
        if (isSensitiveHeader((string)$name)) $headers[$name] = '[redacted]';
    }
    return $headers;
}

function normalizeBodyForRecord(string $body, bool $sanitize, bool $truncate): string {
    if ($sanitize) {
        $body = preg_replace('/("?(?:password|token|secret|api[_-]?key|authorization)"?\s*[:=]\s*)("[^"]+"|[^,\s}]+)/i', '$1"[redacted]"', $body) ?? $body;
    }
    if ($truncate && strlen($body) > 12000) return substr($body, 0, 12000) . "\n[truncated]";
    return $body;
}

function isSensitiveHeader(string $name): bool {
    return in_array(strtolower(trim($name)), ['authorization', 'proxy-authorization', 'x-api-key', 'api-key', 'cookie', 'set-cookie'], true);
}

function learnFromCase(array &$state, array $case): void {
    $response = $case['response'] ?? null;
    if (!is_array($response) || !isSuccessfulResponse($response)) return;
    if (isset($response['headers']['location'])) {
        $state['resource_values']['location'][] = (string)$response['headers']['location'];
        $segments = array_values(array_filter(explode('/', parse_url((string)$response['headers']['location'], PHP_URL_PATH) ?: '')));
        if ($segments) $state['resource_values']['id'][] = end($segments);
    }
    $body = json_decode((string)($response['body'] ?? ''), true);
    if (is_array($body)) learnResourceValuesFromValue($state, $body);
}

function learnResourceValuesFromValue(array &$state, $value, string $prefix = ''): void {
    if (!is_array($value)) return;
    foreach ($value as $key => $item) {
        $name = strtolower((string)$key);
        if (is_scalar($item) && ($name === 'id' || str_ends_with($name, 'id') || str_ends_with($name, '_id'))) {
            foreach (parameterResourceNames((string)$key) as $resourceName) {
                $state['resource_values'][$resourceName][] = (string)$item;
            }
        } elseif (is_array($item)) {
            learnResourceValuesFromValue($state, $item, $prefix . '.' . $name);
        }
    }
}

function discoverStatefulLinks(array $schema): array {
    $links = [];
    foreach (($schema['paths'] ?? []) as $pathItem) {
        if (!is_array($pathItem)) continue;
        foreach (HTTP_OPERATION_METHODS as $method) {
            $operation = $pathItem[$method] ?? null;
            if (!is_array($operation)) continue;
            $sourceOperationId = $operation['operationId'] ?? null;
            if ($sourceOperationId === null) continue;
            foreach (($operation['responses'] ?? []) as $response) {
                if (!is_array($response)) continue;
                foreach (($response['links'] ?? []) as $link) {
                    if (is_array($link) && isset($link['operationId'])) $links[$sourceOperationId][] = $link;
                }
            }
        }
    }
    return $links;
}

function extractLinkValue($expression, array $case) {
    if (!is_string($expression)) return $expression;
    if (str_starts_with($expression, '$response.body#')) {
        $body = json_decode((string)($case['response']['body'] ?? ''), true);
        if (!is_array($body)) return null;
        return jsonPointer($body, substr($expression, strlen('$response.body#')));
    }
    if (str_starts_with($expression, '$response.header.')) {
        $rest = substr($expression, strlen('$response.header.'));
        $regex = null;
        if (str_contains($rest, '#regex:')) {
            [$headerName, $regex] = explode('#regex:', $rest, 2);
        } else {
            $headerName = $rest;
        }
        $value = $case['response']['headers'][strtolower($headerName)] ?? null;
        if ($value === null) return null;
        if ($regex !== null && @preg_match('#' . str_replace('#', '\#', $regex) . '#', (string)$value, $match)) return $match[1] ?? $match[0] ?? null;
        return $value;
    }
    return $expression;
}

function recordFailure(array &$state, array &$result, string $message, ?array $case = null): void {
    $result['failed']++;
    $state['failures'][] = $case ? "{$message} (case {$case['id']})" : $message;
    $state['failure_reproducers'][] = $case['curl'] ?? null;
    if ($case !== null) saveCrashFile($state, $case);
}

function saveCrashFile(array $state, array $case): void {
    $dir = rtrim((string)($state['cache_dir'] ?? DEFAULT_CACHE_DIR), DIRECTORY_SEPARATOR) . DIRECTORY_SEPARATOR . 'crashes';
    if (!is_dir($dir) && !mkdir($dir, 0777, true) && !is_dir($dir)) return;
    $path = $dir . DIRECTORY_SEPARATOR . $case['id'] . '.json';
    $crash = [
        'id' => $case['id'],
        'created_at' => $case['time'],
        'schema_location' => $case['schema_location'],
        'base_url' => $case['base_url'],
        'checks' => $case['checks'],
        'max_response_time' => $case['max_response_time'],
        'components' => $case['components'],
        'operation' => $case['request']['operation']['operation'] ?? null,
        'operation_path' => $case['request']['operation']['path'] ?? null,
        'request' => $case['request'],
        'failure' => $case['failure'],
        'curl' => $case['curl'] ?? null
    ];
    file_put_contents($path, json_encode($crash, JSON_PRETTY_PRINT | JSON_UNESCAPED_SLASHES));
}

function failureLimitReached(array $state): bool {
    return $state['max_failures'] !== null && count($state['failures']) >= $state['max_failures'];
}

function concretePath(string $path, array $operation, bool $useExamples, array $components = [], array $overrides = []): string {
    return preg_replace_callback('/\{([^}]+)\}/', function(array $match) use ($operation, $useExamples, $components, $overrides) {
        $name = $match[1];
        foreach (operationParameters($operation) as $parameter) {
            if (($parameter['in'] ?? '') === 'path' && ($parameter['name'] ?? '') === $name) {
                $value = $overrides[$name] ?? null;
                if ($value === null && $useExamples && array_key_exists('example', $parameter)) $value = $parameter['example'];
                if ($value === null) $value = generateValue($parameter['schema'] ?? ['type' => 'integer'], $components);
                return serializePathParameter($value, $parameter);
            }
        }
        return '1';
    }, $path);
}

function queryString(array $operation, array $components, bool $useExamples, string $caseMode = 'positive', array $overrides = [], array $schema = [], array $options = []): string {
    $query = [];
    foreach (operationParameters($operation) as $parameter) {
        if (($parameter['in'] ?? '') !== 'query') continue;
        $required = (bool)($parameter['required'] ?? false);
        if (!$required && !$useExamples && mt_rand(0, 1) === 0) continue;
        if (array_key_exists((string)$parameter['name'], $overrides)) {
            $value = $overrides[(string)$parameter['name']];
        } elseif ($useExamples && array_key_exists('example', $parameter)) {
            $value = $parameter['example'];
        } elseif ($required || !$useExamples) {
            $value = $caseMode === 'negative'
                ? generateInvalidValue($parameter['schema'] ?? ['type' => 'string'], $components)
                : generateValue($parameter['schema'] ?? ['type' => 'string'], $components);
        } else {
            continue;
        }
        appendSerializedQueryParameter($query, $parameter, $value);
    }
    appendApiKeyQueryParameters($query, $schema, $options);
    return $query ? '?' . http_build_query($query) : '';
}

function operationParameterHeaders(array $operation, array $components, bool $useExamples, string $caseMode, array $skipHeaders = []): array {
    $headers = [];
    $cookies = [];
    $skipHeaders = array_map('strtolower', $skipHeaders);
    foreach (operationParameters($operation) as $parameter) {
        $location = $parameter['in'] ?? '';
        if ($location !== 'header' && $location !== 'cookie') continue;
        if ($location === 'header' && in_array(strtolower((string)$parameter['name']), $skipHeaders, true)) continue;
        $required = (bool)($parameter['required'] ?? false);
        if (!$required && !$useExamples && mt_rand(0, 1) === 0) continue;
        $value = parameterValue($parameter, $components, $useExamples, $caseMode);
        if ($location === 'header') {
            $headers[] = $parameter['name'] . ': ' . serializeParameterValue($value);
        } else {
            $cookies[] = rawurlencode((string)$parameter['name']) . '=' . rawurlencode(serializeParameterValue($value));
        }
    }
    if ($cookies) $headers[] = 'Cookie: ' . implode('; ', $cookies);
    return $headers;
}

function operationParameters(array $operation): array {
    return array_values(array_filter($operation['parameters'] ?? [], 'is_array'));
}

function parameterValue(array $parameter, array $components, bool $useExamples, string $caseMode) {
    if ($useExamples && array_key_exists('example', $parameter)) return $parameter['example'];
    $schema = $parameter['schema'] ?? ['type' => 'string'];
    return $caseMode === 'negative' ? generateInvalidValue($schema, $components) : generateValue($schema, $components);
}

function serializePathParameter($value, array $parameter): string {
    $style = (string)($parameter['style'] ?? 'simple');
    $explode = (bool)($parameter['explode'] ?? false);
    if ($style === 'label') return '.' . rawurlencode(serializeParameterValue($value));
    if ($style === 'matrix') {
        $name = (string)($parameter['name'] ?? 'value');
        if (is_array($value)) {
            if (isAssocArray($value)) {
                $items = [];
                foreach ($value as $key => $item) $items[] = $explode ? "{$key}={$item}" : "{$key},{$item}";
                return ';' . ($explode ? implode(';', $items) : $name . '=' . implode(',', $items));
            }
            return ';' . $name . '=' . implode($explode ? ';' . $name . '=' : ',', array_map('rawurlencode', array_map('strval', $value)));
        }
        return ';' . $name . '=' . rawurlencode((string)$value);
    }
    return rawurlencode(serializeParameterValue($value));
}

function appendSerializedQueryParameter(array &$query, array $parameter, $value): void {
    $name = (string)($parameter['name'] ?? 'param');
    $style = (string)($parameter['style'] ?? 'form');
    $explode = array_key_exists('explode', $parameter) ? (bool)$parameter['explode'] : $style === 'form';

    if ($style === 'deepObject' && is_array($value) && isAssocArray($value)) {
        foreach ($value as $key => $item) $query[$name . '[' . $key . ']'] = scalarParameterValue($item);
        return;
    }
    if (is_array($value)) {
        if ($explode && $style === 'form' && !isAssocArray($value)) {
            $query[$name] = array_map('scalarParameterValue', $value);
            return;
        }
        $separator = match ($style) {
            'spaceDelimited' => ' ',
            'pipeDelimited' => '|',
            default => ','
        };
        $query[$name] = serializeParameterValueWithSeparator($value, $separator);
        return;
    }
    $query[$name] = scalarParameterValue($value);
}

function appendApiKeyQueryParameters(array &$query, array $schema, array $options): void {
    foreach (($schema['components']['securitySchemes'] ?? []) as $schemeName => $scheme) {
        if (!is_array($scheme) || strtolower((string)($scheme['type'] ?? '')) !== 'apikey' || strtolower((string)($scheme['in'] ?? '')) !== 'query') continue;
        $value = apiKeyValueForScheme((string)$schemeName, $options);
        if ($value !== null) $query[(string)($scheme['name'] ?? $schemeName)] = $value;
    }
}

function serializeParameterValueWithSeparator(array $value, string $separator): string {
    if (isAssocArray($value)) {
        $items = [];
        foreach ($value as $key => $item) {
            $items[] = (string)$key;
            $items[] = scalarParameterValue($item);
        }
        return implode($separator, $items);
    }
    return implode($separator, array_map('scalarParameterValue', $value));
}

function scalarParameterValue($value): string {
    if (is_bool($value)) return $value ? 'true' : 'false';
    if ($value === null) return 'null';
    if (is_array($value)) return json_encode($value, JSON_UNESCAPED_SLASHES);
    return (string)$value;
}

function serializeParameterValue($value): string {
    if (is_array($value)) {
        if (isAssocArray($value)) return implode(',', array_map(fn($key, $item) => $key . ',' . $item, array_keys($value), $value));
        return implode(',', array_map('strval', $value));
    }
    if (is_bool($value)) return $value ? 'true' : 'false';
    return (string)$value;
}

function allowedMethodsForPathItem(array $pathItem): array {
    $methods = [];
    foreach (HTTP_OPERATION_METHODS as $method) {
        if (isset($pathItem[$method])) $methods[] = strtoupper($method);
    }
    return $methods;
}

function resolveSchemaRef(array $schema, array $components): array {
    if (!isset($schema['$ref'])) return $schema;
    $ref = (string)$schema['$ref'];
    foreach ([
        '#/components/schemas/' => $components['schemas'] ?? [],
        '#/definitions/' => $components['schemas'] ?? []
    ] as $prefix => $source) {
        if (str_starts_with($ref, $prefix)) {
            $name = substr($ref, strlen($prefix));
            return is_array($source[$name] ?? null) ? $source[$name] : $schema;
        }
    }
    return $schema;
}

function generateValue(array $schema, array $components) {
    $schema = resolveSchemaRef($schema, $components);
    if (($schema['nullable'] ?? false) && mt_rand(0, 5) === 0) return null;
    if (isset($schema['enum']) && is_array($schema['enum']) && $schema['enum']) {
        return $schema['enum'][array_rand($schema['enum'])];
    }
    if (isset($schema['oneOf'][0])) return generateValue($schema['oneOf'][array_rand($schema['oneOf'])], $components);
    if (isset($schema['allOf'][0])) return generateValue($schema['allOf'][0], $components);

    $type = $schema['type'] ?? 'string';
    if (is_array($type)) $type = $type[array_rand($type)];
    return match ($type) {
        'object' => generateObject($schema, $components),
        'array' => generateArrayValue($schema, $components),
        'integer' => generateInteger($schema),
        'number' => generateNumber($schema),
        'boolean' => (bool)mt_rand(0, 1),
        default => generateString($schema)
    };
}

function generateInvalidValue(array $schema, array $components) {
    $schema = resolveSchemaRef($schema, $components);
    if (isset($schema['enum']) && is_array($schema['enum'])) return '__invalid_enum_' . mt_rand(1, 100000);
    if (isset($schema['oneOf'][0])) return generateInvalidValue($schema['oneOf'][0], $components);
    if (isset($schema['allOf'][0])) return generateInvalidValue($schema['allOf'][0], $components);

    $type = $schema['type'] ?? 'string';
    if (is_array($type)) $type = $type[0] ?? 'string';
    return match ($type) {
        'object' => generateInvalidObject($schema, $components),
        'array' => 'not-an-array',
        'integer' => 'not-an-integer',
        'number' => 'not-a-number',
        'boolean' => 'not-a-boolean',
        'string' => generateInvalidString($schema),
        default => null
    };
}

function generateInvalidObject(array $schema, array $components): array {
    $properties = $schema['properties'] ?? [];
    $required = $schema['required'] ?? [];
    $value = [];
    foreach ($properties as $name => $propertySchema) {
        if (in_array($name, $required, true) && mt_rand(0, 1) === 0) continue;
        $value[$name] = mt_rand(0, 2) === 0 ? generateInvalidValue($propertySchema, $components) : generateValue($propertySchema, $components);
    }
    if (($schema['additionalProperties'] ?? null) === false) {
        $value['__unexpected_' . mt_rand(1, 1000)] = true;
    }
    if (!$value && $properties) {
        $firstName = array_key_first($properties);
        $value[$firstName] = generateInvalidValue($properties[$firstName], $components);
    }
    return $value;
}

function generateInvalidString(array $schema) {
    if (isset($schema['maxLength'])) return str_repeat('x', max(1, (int)$schema['maxLength'] + 1));
    if (isset($schema['minLength']) && (int)$schema['minLength'] > 0) return '';
    if (($schema['format'] ?? '') === 'uri') return 'not a uri';
    return 12345;
}

function generateObject(array $schema, array $components): array {
    $value = [];
    $required = $schema['required'] ?? [];
    foreach (($schema['properties'] ?? []) as $name => $propertySchema) {
        if (in_array($name, $required, true) || mt_rand(0, 1) === 1) {
            $value[$name] = generateValue($propertySchema, $components);
        }
    }
    return $value;
}

function generateArrayValue(array $schema, array $components): array {
    $min = max(0, (int)($schema['minItems'] ?? 0));
    $max = max($min, min(5, (int)($schema['maxItems'] ?? max(2, $min + 2))));
    $count = mt_rand($min, $max);
    $items = [];
    for ($i = 0; $i < $count; $i++) $items[] = generateValue($schema['items'] ?? ['type' => 'string'], $components);
    if (($schema['uniqueItems'] ?? false) === true) $items = array_values(array_unique($items, SORT_REGULAR));
    return $items;
}

function generateInteger(array $schema): int {
    $min = isset($schema['minimum']) ? (int)$schema['minimum'] : 0;
    if (($schema['exclusiveMinimum'] ?? false) === true) $min++;
    elseif (isset($schema['exclusiveMinimum']) && !is_bool($schema['exclusiveMinimum'])) $min = (int)$schema['exclusiveMinimum'] + 1;
    $max = isset($schema['maximum']) ? (int)$schema['maximum'] : $min + 100;
    if (($schema['exclusiveMaximum'] ?? false) === true) $max--;
    elseif (isset($schema['exclusiveMaximum']) && !is_bool($schema['exclusiveMaximum'])) $max = (int)$schema['exclusiveMaximum'] - 1;
    if ($max < $min) $max = $min;
    $value = mt_rand($min, $max);
    if (isset($schema['multipleOf']) && (int)$schema['multipleOf'] > 0) {
        $multiple = (int)$schema['multipleOf'];
        $value = max($min, (int)(ceil($value / $multiple) * $multiple));
        if ($value > $max) $value = max($min, (int)(floor($max / $multiple) * $multiple));
    }
    return $value;
}

function generateNumber(array $schema): float {
    $value = generateInteger($schema) + (mt_rand(0, 99) / 100);
    if (isset($schema['multipleOf']) && (float)$schema['multipleOf'] > 0.0) {
        $multiple = (float)$schema['multipleOf'];
        $value = round($value / $multiple) * $multiple;
    }
    return $value;
}

function generateString(array $schema): string {
    if (($schema['format'] ?? '') === 'uri') return 'https://example.com/' . mt_rand(1, 100000);
    if (($schema['format'] ?? '') === 'email') return 'user' . mt_rand(1, 100000) . '@example.com';
    if (($schema['format'] ?? '') === 'uuid') return sprintf('%08x-%04x-4%03x-%04x-%012x', mt_rand(), mt_rand(0, 0xffff), mt_rand(0, 0xfff), mt_rand(0x8000, 0xbfff), mt_rand());
    $max = min(32, max(1, (int)($schema['maxLength'] ?? 12)));
    $min = min($max, max(1, (int)($schema['minLength'] ?? 1)));
    $length = mt_rand($min, $max);
    $alphabet = 'abcdefghijklmnopqrstuvwxyz0123456789-_';
    $value = '';
    for ($i = 0; $i < $length; $i++) $value .= $alphabet[mt_rand(0, strlen($alphabet) - 1)];
    return $value;
}

function isAssocArray($value): bool {
    return is_array($value) && array_keys($value) !== range(0, count($value) - 1);
}

function validateSchema($value, array $schema, array $components, string $path = '$'): array {
    $schema = resolveSchemaRef($schema, $components);
    if (($schema['nullable'] ?? false) && $value === null) return [];
    if (isset($schema['const']) && $value !== $schema['const']) return ["{$path} does not equal const"];
    if (isset($schema['allOf']) && is_array($schema['allOf'])) {
        foreach ($schema['allOf'] as $part) {
            $errors = validateSchema($value, $part, $components, $path);
            if ($errors) return $errors;
        }
        return [];
    }
    if (isset($schema['anyOf']) && is_array($schema['anyOf'])) {
        foreach ($schema['anyOf'] as $part) {
            if (!validateSchema($value, $part, $components, $path)) return [];
        }
        return ["{$path} did not match any anyOf schema"];
    }
    if (isset($schema['oneOf']) && is_array($schema['oneOf'])) {
        $matches = 0;
        foreach ($schema['oneOf'] as $part) {
            if (!validateSchema($value, $part, $components, $path)) $matches++;
        }
        return $matches === 1 ? [] : ["{$path} matched {$matches} oneOf schemas"];
    }
    if (isset($schema['not']) && is_array($schema['not']) && !validateSchema($value, $schema['not'], $components, $path)) {
        return ["{$path} matched forbidden not schema"];
    }
    if (array_key_exists('enum', $schema) && !in_array($value, $schema['enum'], true)) return ["{$path} is not in enum"];

    $type = $schema['type'] ?? null;
    if ($type === null) return [];
    if (is_array($type)) {
        foreach ($type as $candidate) {
            $candidateSchema = $schema;
            $candidateSchema['type'] = $candidate;
            if (!validateSchema($value, $candidateSchema, $components, $path)) return [];
        }
        return ["{$path} did not match any type"];
    }

    return match ($type) {
        'object' => validateObjectSchema($value, $schema, $components, $path),
        'array' => validateArraySchema($value, $schema, $components, $path),
        'integer' => validateNumberSchema($value, $schema, $path, true),
        'number' => validateNumberSchema($value, $schema, $path, false),
        'string' => validateStringSchema($value, $schema, $path),
        'boolean' => is_bool($value) ? [] : ["{$path} is not a boolean"],
        default => []
    };
}

function validateNumberSchema($value, array $schema, string $path, bool $integer): array {
    if ($integer && !is_int($value)) return ["{$path} is not an integer"];
    if (!$integer && !(is_int($value) || is_float($value))) return ["{$path} is not a number"];
    if (isset($schema['minimum']) && $value < $schema['minimum']) return ["{$path} is less than minimum {$schema['minimum']}"];
    if (isset($schema['exclusiveMinimum'])) {
        $exclusive = is_bool($schema['exclusiveMinimum']) ? ($schema['exclusiveMinimum'] ? ($schema['minimum'] ?? null) : null) : $schema['exclusiveMinimum'];
        if ($exclusive !== null && $value <= $exclusive) return ["{$path} is not greater than exclusiveMinimum {$exclusive}"];
    }
    if (isset($schema['maximum']) && $value > $schema['maximum']) return ["{$path} is greater than maximum {$schema['maximum']}"];
    if (isset($schema['exclusiveMaximum'])) {
        $exclusive = is_bool($schema['exclusiveMaximum']) ? ($schema['exclusiveMaximum'] ? ($schema['maximum'] ?? null) : null) : $schema['exclusiveMaximum'];
        if ($exclusive !== null && $value >= $exclusive) return ["{$path} is not less than exclusiveMaximum {$exclusive}"];
    }
    if (isset($schema['multipleOf']) && (float)$schema['multipleOf'] > 0.0) {
        $ratio = $value / (float)$schema['multipleOf'];
        if (abs($ratio - round($ratio)) > 0.0000001) return ["{$path} is not a multiple of {$schema['multipleOf']}"];
    }
    return [];
}

function validateStringSchema($value, array $schema, string $path): array {
    if (!is_string($value)) return ["{$path} is not a string"];
    $length = strlen($value);
    if (isset($schema['minLength']) && $length < (int)$schema['minLength']) return ["{$path} is shorter than minLength {$schema['minLength']}"];
    if (isset($schema['maxLength']) && $length > (int)$schema['maxLength']) return ["{$path} is longer than maxLength {$schema['maxLength']}"];
    if (isset($schema['pattern']) && @preg_match('/' . str_replace('/', '\/', (string)$schema['pattern']) . '/', '') !== false) {
        if (!preg_match('/' . str_replace('/', '\/', (string)$schema['pattern']) . '/', $value)) return ["{$path} does not match pattern"];
    }
    if (($schema['format'] ?? null) === 'email' && filter_var($value, FILTER_VALIDATE_EMAIL) === false) return ["{$path} is not a valid email"];
    if (in_array(($schema['format'] ?? null), ['uri', 'url'], true) && filter_var($value, FILTER_VALIDATE_URL) === false) return ["{$path} is not a valid URI"];
    if (($schema['format'] ?? null) === 'uuid' && !preg_match('/^[0-9a-f]{8}-[0-9a-f]{4}-[1-5][0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}$/i', $value)) return ["{$path} is not a valid UUID"];
    return [];
}

function validateObjectSchema($value, array $schema, array $components, string $path): array {
    if (!isAssocArray($value)) return ["{$path} is not an object"];
    if (isset($schema['minProperties']) && count($value) < (int)$schema['minProperties']) return ["{$path} has fewer properties than minProperties {$schema['minProperties']}"];
    if (isset($schema['maxProperties']) && count($value) > (int)$schema['maxProperties']) return ["{$path} has more properties than maxProperties {$schema['maxProperties']}"];
    foreach (($schema['required'] ?? []) as $required) {
        if (!array_key_exists($required, $value)) return ["{$path}.{$required} is required"];
    }
    foreach (($schema['properties'] ?? []) as $name => $propertySchema) {
        if (array_key_exists($name, $value)) {
            $errors = validateSchema($value[$name], $propertySchema, $components, "{$path}.{$name}");
            if ($errors) return $errors;
        }
    }
    if (($schema['additionalProperties'] ?? null) === false) {
        $known = array_keys($schema['properties'] ?? []);
        foreach (array_keys($value) as $name) {
            if (!in_array($name, $known, true)) return ["{$path}.{$name} is not documented"];
        }
    } elseif (is_array($schema['additionalProperties'] ?? null)) {
        $known = array_keys($schema['properties'] ?? []);
        foreach ($value as $name => $item) {
            if (in_array($name, $known, true)) continue;
            $errors = validateSchema($item, $schema['additionalProperties'], $components, "{$path}.{$name}");
            if ($errors) return $errors;
        }
    }
    return [];
}

function validateArraySchema($value, array $schema, array $components, string $path): array {
    if (!is_array($value) || isAssocArray($value)) return ["{$path} is not an array"];
    if (isset($schema['minItems']) && count($value) < (int)$schema['minItems']) return ["{$path} has fewer items than minItems {$schema['minItems']}"];
    if (isset($schema['maxItems']) && count($value) > (int)$schema['maxItems']) return ["{$path} has more items than maxItems {$schema['maxItems']}"];
    if (($schema['uniqueItems'] ?? false) === true && count(array_unique(array_map(fn($item) => json_encode($item), $value))) !== count($value)) {
        return ["{$path} items are not unique"];
    }
    foreach ($value as $index => $item) {
        $errors = validateSchema($item, $schema['items'] ?? [], $components, "{$path}[{$index}]");
        if ($errors) return $errors;
    }
    return [];
}

function printPhaseResult(string $phase, array $result): void {
    $icon = $result['failed'] > 0 ? 'FAIL' : 'OK';
    $label = ucfirst($phase);
    printf(" %s  %s (in %.2fs)\n", $icon, $label, $result['duration']);
    echo "     {$result['passed']} passed";
    if ($result['failed']) echo "  {$result['failed']} failed";
    if ($result['skipped']) echo "  {$result['skipped']} skipped";
    echo "\n\n";
}

function printFailures(array $state): void {
    if (!$state['failures']) return;
    echo "=================================== FAILURES ===================================\n";
    foreach ($state['failures'] as $index => $failure) {
        $number = $index + 1;
        echo "{$number}. {$failure}\n";
        $curl = $state['failure_reproducers'][$index] ?? null;
        if (is_string($curl) && $curl !== '') echo "   Reproduce: {$curl}\n";
    }
    echo "\n";
}

function printWarnings(array $state): void {
    if (!$state['warnings']) return;
    echo "=================================== WARNINGS ===================================\n";
    foreach ($state['warnings'] as $warning) echo "- {$warning}\n";
    echo "\n";
}

function printSummary(array $operations, array $phaseResults, array $state): void {
    $failed = count($state['failures']);
    $passed = array_sum(array_column($phaseResults, 'passed'));
    $skipped = array_sum(array_column($phaseResults, 'skipped'));
    echo "=================================== SUMMARY ====================================\n";
    echo "API Operations:\n";
    echo "  Selected: " . count($operations) . '/' . ($state['total_operations'] ?? count($operations)) . "\n";
    echo "  Tested cases: {$state['cases']}\n\n";
    echo "Test Phases:\n";
    foreach ($phaseResults as $phase => $result) {
        echo '  ' . ($result['failed'] ? 'FAIL' : 'OK') . ' ' . ucfirst($phase) . "\n";
    }
    echo "\n";
    echo "Test cases:\n";
    echo "  {$passed} passed";
    if ($failed) echo ", {$failed} failed";
    if ($skipped) echo ", {$skipped} skipped";
    echo "\n";
    echo "Seed: {$state['seed']}\n";
}

function runSummary(array $operations, array $phaseResults, array $state): array {
    return [
        'operations_selected' => count($operations),
        'operations_total' => (int)($state['total_operations'] ?? count($operations)),
        'cases' => (int)($state['cases'] ?? 0),
        'passed' => (int)array_sum(array_column($phaseResults, 'passed')),
        'failed' => count($state['failures'] ?? []),
        'skipped' => (int)array_sum(array_column($phaseResults, 'skipped')),
        'seed' => $state['seed'] ?? null,
        'phases' => $phaseResults,
        'warnings' => $state['warnings'] ?? [],
        'failure_messages' => $state['failures'] ?? []
    ];
}

function writeReports(array $state, array $phaseResults): void {
    $report = $state['report'] ?? ['formats' => []];
    foreach (($report['formats'] ?? []) as $format) {
        $path = (string)($report['paths'][$format] ?? '');
        if ($path === '') continue;
        $dir = dirname($path);
        if (!is_dir($dir) && !mkdir($dir, 0777, true) && !is_dir($dir)) {
            fwrite(STDERR, "Could not create report directory: {$dir}\n");
            continue;
        }
        $content = match ($format) {
            'junit' => junitReport($state, $phaseResults),
            'har' => harReport($state),
            'ndjson' => ndjsonReport($state, $phaseResults),
            'vcr' => vcrReport($state),
            'html' => htmlReport($state, $phaseResults),
            'curl' => curlReport($state),
            default => null
        };
        if ($content !== null) {
            file_put_contents($path, $content);
            if ($format === 'curl') @chmod($path, 0755);
            echo "Report written: {$path}\n";
        }
    }
}

function junitReport(array $state, array $phaseResults): string {
    $cases = $state['case_records'] ?? [];
    $failures = array_values(array_filter($cases, fn(array $case) => $case['failure'] !== null));
    $time = array_sum(array_map(fn(array $case) => (float)($case['response']['duration'] ?? 0.0), $cases));
    $xml = [];
    $xml[] = '<?xml version="1.0" encoding="UTF-8"?>';
    $xml[] = sprintf(
        '<testsuite name="openapi-contract-php" tests="%d" failures="%d" errors="0" skipped="0" time="%.6f">',
        count($cases),
        count($failures),
        $time
    );
    foreach ($cases as $case) {
        $name = trim(($case['request']['method'] ?? '') . ' ' . (($case['request']['operation']['path'] ?? $case['request']['path_query'] ?? '')));
        $xml[] = sprintf(
            '  <testcase classname="%s" name="%s" time="%.6f">',
            xmlEscape((string)($case['request']['phase'] ?? 'case')),
            xmlEscape($name),
            (float)($case['response']['duration'] ?? 0.0)
        );
        if ($case['failure'] !== null) {
            $xml[] = sprintf('    <failure message="%s">%s</failure>', xmlEscape($case['failure']), xmlEscape(json_encode($case, JSON_PRETTY_PRINT | JSON_UNESCAPED_SLASHES)));
        }
        $xml[] = '  </testcase>';
    }
    $xml[] = '</testsuite>';
    return implode("\n", $xml) . "\n";
}

function harReport(array $state): string {
    $entries = [];
    foreach (($state['case_records'] ?? []) as $case) {
        $request = $case['request'];
        $response = $case['response'] ?? [];
        $entries[] = [
            'startedDateTime' => $case['time'],
            'time' => round((float)($response['duration'] ?? 0.0) * 1000, 3),
            'request' => [
                'method' => $request['method'],
                'url' => $request['url'],
                'httpVersion' => 'HTTP/1.1',
                'headers' => headerLinesToHar($request['headers'] ?? []),
                'queryString' => queryStringToHar((string)parse_url($request['url'], PHP_URL_QUERY)),
                'cookies' => [],
                'headersSize' => -1,
                'bodySize' => $request['body'] === null ? 0 : strlen((string)$request['body']),
                'postData' => $request['body'] === null ? null : ['mimeType' => 'application/json', 'text' => $request['body']]
            ],
            'response' => [
                'status' => (int)($response['status'] ?? 0),
                'statusText' => '',
                'httpVersion' => 'HTTP/1.1',
                'headers' => assocHeadersToHar($response['headers'] ?? []),
                'cookies' => [],
                'content' => [
                    'size' => strlen((string)($response['body'] ?? '')),
                    'mimeType' => $response['headers']['content-type'] ?? '',
                    'text' => (string)($response['body'] ?? '')
                ],
                'redirectURL' => '',
                'headersSize' => -1,
                'bodySize' => strlen((string)($response['body'] ?? ''))
            ],
            'cache' => new stdClass(),
            'timings' => ['send' => 0, 'wait' => round((float)($response['duration'] ?? 0.0) * 1000, 3), 'receive' => 0]
        ];
    }
    return json_encode(['log' => ['version' => '1.2', 'creator' => ['name' => 'openapi-contract-php', 'version' => '0.1'], 'entries' => $entries]], JSON_PRETTY_PRINT | JSON_UNESCAPED_SLASHES) . "\n";
}

function ndjsonReport(array $state, array $phaseResults): string {
    $lines = [];
    foreach (($state['case_records'] ?? []) as $case) {
        $lines[] = json_encode(['type' => 'case', 'case' => $case], JSON_UNESCAPED_SLASHES);
    }
    $lines[] = json_encode([
        'type' => 'summary',
        'cases' => $state['cases'],
        'failures' => count($state['failures'] ?? []),
        'phases' => $phaseResults,
        'seed' => $state['seed'] ?? null
    ], JSON_UNESCAPED_SLASHES);
    return implode("\n", $lines) . "\n";
}

function vcrReport(array $state): string {
    $lines = ["interactions:"];
    foreach (($state['case_records'] ?? []) as $case) {
        $request = $case['request'];
        $response = $case['response'] ?? [];
        $lines[] = "  - id: " . yamlScalar($case['id']);
        $lines[] = "    request:";
        $lines[] = "      method: " . yamlScalar($request['method']);
        $lines[] = "      uri: " . yamlScalar($request['url']);
        $lines[] = "      body: " . yamlScalar((string)($request['body'] ?? ''));
        $lines[] = "    response:";
        $lines[] = "      status: " . (int)($response['status'] ?? 0);
        $lines[] = "      body: " . yamlScalar((string)($response['body'] ?? ''));
        if ($case['failure'] !== null) $lines[] = "    failure: " . yamlScalar($case['failure']);
    }
    return implode("\n", $lines) . "\n";
}

function htmlReport(array $state, array $phaseResults): string {
    $cases = $state['case_records'] ?? [];
    $failures = array_values(array_filter($cases, fn(array $case): bool => $case['failure'] !== null));
    $passed = (int)array_sum(array_column($phaseResults, 'passed'));
    $failed = count($failures);
    $skipped = (int)array_sum(array_column($phaseResults, 'skipped'));
    $phaseRows = '';
    foreach ($phaseResults as $phase => $result) {
        $phaseRows .= '<tr><td>' . htmlEscape((string)$phase) . '</td><td>' . ($result['failed'] ? 'FAIL' : 'OK') . '</td><td>' . (int)$result['passed'] . '</td><td>' . (int)$result['failed'] . '</td><td>' . (int)$result['skipped'] . '</td><td>' . htmlEscape(sprintf('%.3fs', (float)($result['duration'] ?? 0))) . '</td></tr>';
    }
    $failureRows = '';
    foreach ($failures as $case) {
        $failureRows .= '<tr><td>' . htmlEscape($case['id'] ?? '') . '</td><td>' . htmlEscape(($case['request']['method'] ?? '') . ' ' . ($case['request']['path_query'] ?? $case['request']['url'] ?? '')) . '</td><td>' . htmlEscape((string)$case['failure']) . '</td><td><pre>' . htmlEscape((string)($case['curl'] ?? '')) . '</pre></td></tr>';
    }
    if ($failureRows === '') $failureRows = '<tr><td colspan="4">No failures.</td></tr>';
    $caseRows = '';
    foreach (array_slice($cases, 0, 500) as $case) {
        $response = $case['response'] ?? [];
        $caseRows .= '<tr><td>' . htmlEscape($case['id'] ?? '') . '</td><td>' . htmlEscape((string)($case['request']['phase'] ?? '')) . '</td><td>' . htmlEscape((string)($case['request']['method'] ?? '')) . '</td><td>' . htmlEscape((string)($case['request']['path_query'] ?? $case['request']['url'] ?? '')) . '</td><td>' . htmlEscape((string)($response['status'] ?? '')) . '</td><td>' . htmlEscape($case['failure'] === null ? 'OK' : 'FAIL') . '</td></tr>';
    }
    $warnings = '';
    foreach (($state['warnings'] ?? []) as $warning) $warnings .= '<li>' . htmlEscape((string)$warning) . '</li>';
    if ($warnings === '') $warnings = '<li>No warnings.</li>';

    return '<!doctype html><html><head><meta charset="utf-8"><title>openapi-contract-php report</title><style>'
        . 'body{font-family:Arial,sans-serif;margin:32px;color:#17202a;background:#f7f9fb}h1{margin:0 0 8px}h2{margin-top:28px}.meta{color:#52616f}.metrics{display:grid;grid-template-columns:repeat(auto-fit,minmax(140px,1fr));gap:12px;margin:20px 0}.metric{background:#fff;border:1px solid #d8e1ea;border-radius:6px;padding:14px}.metric b{display:block;font-size:24px;margin-top:4px}table{width:100%;border-collapse:collapse;background:#fff;border:1px solid #d8e1ea}th,td{text-align:left;border-bottom:1px solid #e7edf3;padding:8px;vertical-align:top}th{background:#eef3f7}pre{white-space:pre-wrap;word-break:break-word;margin:0;font-size:12px}@media print{body{background:#fff;margin:16px}.metric,table{break-inside:avoid}}'
        . '</style></head><body>'
        . '<h1>openapi-contract-php report</h1>'
        . '<p class="meta">Schema: ' . htmlEscape((string)($state['schema_location'] ?? '')) . ' | Base URL: ' . htmlEscape((string)($state['base_url'] ?? '')) . ' | Seed: ' . htmlEscape((string)($state['seed'] ?? '')) . '</p>'
        . '<section class="metrics">'
        . htmlMetric('Cases', (string)($state['cases'] ?? count($cases)))
        . htmlMetric('Passed', (string)$passed)
        . htmlMetric('Failed', (string)$failed)
        . htmlMetric('Skipped', (string)$skipped)
        . '</section>'
        . '<h2>Failures</h2><table><thead><tr><th>Case</th><th>Operation</th><th>Failure</th><th>Reproducer</th></tr></thead><tbody>' . $failureRows . '</tbody></table>'
        . '<h2>Phases</h2><table><thead><tr><th>Phase</th><th>Status</th><th>Passed</th><th>Failed</th><th>Skipped</th><th>Runtime</th></tr></thead><tbody>' . $phaseRows . '</tbody></table>'
        . '<h2>Cases</h2><table><thead><tr><th>Case</th><th>Phase</th><th>Method</th><th>Path</th><th>Status</th><th>Result</th></tr></thead><tbody>' . $caseRows . '</tbody></table>'
        . '<h2>Warnings</h2><ul>' . $warnings . '</ul>'
        . '</body></html>';
}

function curlReport(array $state): string {
    $lines = ['#!/usr/bin/env sh', 'set -eu', ''];
    $failures = array_values(array_filter($state['case_records'] ?? [], fn(array $case): bool => $case['failure'] !== null));
    if (!$failures) {
        $lines[] = "echo 'No failing cases were recorded.'";
        return implode("\n", $lines) . "\n";
    }
    foreach ($failures as $index => $case) {
        $number = $index + 1;
        $lines[] = '# Failure ' . $number . ': case ' . ($case['id'] ?? '');
        $lines[] = '# ' . str_replace(["\r", "\n"], ' ', (string)($case['failure'] ?? ''));
        $lines[] = (string)($case['curl'] ?? '');
        $lines[] = '';
    }
    return implode("\n", $lines) . "\n";
}

function htmlMetric(string $label, string $value): string {
    return '<div class="metric"><span>' . htmlEscape($label) . '</span><b>' . htmlEscape($value) . '</b></div>';
}

function headerLinesToHar(array $headers): array {
    $result = [];
    foreach ($headers as $header) {
        if (!str_contains((string)$header, ':')) continue;
        [$name, $value] = explode(':', (string)$header, 2);
        $result[] = ['name' => trim($name), 'value' => trim($value)];
    }
    return $result;
}

function assocHeadersToHar(array $headers): array {
    $result = [];
    foreach ($headers as $name => $value) $result[] = ['name' => (string)$name, 'value' => (string)$value];
    return $result;
}

function queryStringToHar(string $query): array {
    if ($query === '') return [];
    $result = [];
    parse_str($query, $values);
    foreach ($values as $name => $value) {
        $result[] = ['name' => (string)$name, 'value' => is_array($value) ? json_encode($value) : (string)$value];
    }
    return $result;
}

function xmlEscape(string $value): string {
    return htmlspecialchars($value, ENT_QUOTES | ENT_XML1, 'UTF-8');
}

function htmlEscape(string $value): string {
    return htmlspecialchars($value, ENT_QUOTES | ENT_SUBSTITUTE, 'UTF-8');
}

function yamlScalar(string $value): string {
    return json_encode($value, JSON_UNESCAPED_SLASHES);
}
